' ====================================================
' MAKRO: HAFTALIK PLAN
' ====================================================
Sub HaftalikPlan()
On Error GoTo Hata

If gPlanUcakSayisi = 0 Then
    MsgBox "Once PlanOlustur makrosunu calistirin!", vbExclamation
    Exit Sub
End If

Dim basStr As String
Dim bitStr As String

basStr = InputBox("Baslangic tarihi (GG.AA.YYYY):", "Haftalik Plan", Format(Date, "DD.MM.YYYY"))
If basStr = "" Then Exit Sub

bitStr = InputBox("Bitis tarihi (GG.AA.YYYY):", "Haftalik Plan", Format(Date + 6, "DD.MM.YYYY"))
If bitStr = "" Then Exit Sub

Dim basTarihH As Date
Dim bitTarihH As Date

basTarihH = CDate(basStr)
bitTarihH = CDate(bitStr)

Application.ScreenUpdating = False

Dim ws As Worksheet

Application.DisplayAlerts = False
On Error Resume Next
ThisWorkbook.Sheets("HaftalikPlan").Delete
On Error GoTo Hata
Application.DisplayAlerts = True

Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
ws.Name = "HaftalikPlan"
ws.Cells.Font.Name = "Calibri"

ws.Cells(1, 1).Value = Format(basTarihH, "DD.MM.YYYY") & " - " & Format(bitTarihH, "DD.MM.YYYY") & " HAFTALIK PLAN"
ws.Range("A1:H1").Merge

With ws.Cells(1, 1)
    .Font.Bold = True
    .Font.Size = 14
    .Font.Color = RGB(255, 255, 255)
    .Interior.Color = RGB(31, 78, 121)
    .HorizontalAlignment = xlCenter
End With

ws.Cells(3, 1).Value = "Ucak"
ws.Cells(3, 2).Value = "Istasyon"
ws.Cells(3, 3).Value = "Hat"
ws.Cells(3, 4).Value = "Op"
ws.Cells(3, 5).Value = "Baslangic"
ws.Cells(3, 6).Value = "Bitis"

With ws.Range("A3:F3")
    .Font.Bold = True
    .Interior.Color = RGB(214, 228, 240)
    .Borders.LineStyle = xlContinuous
End With

Dim r As Long
r = 4

Dim ui As Long
Dim ki As Long

For ui = 0 To gPlanUcakSayisi - 1
    For ki = 0 To A2C_MAX_KAYIT - 1
        If gPlanVerisi(ui, ki, 0) = -1 Then Exit For
        
        Dim pIst As Integer
        Dim pHat As Integer
        Dim pOp As Integer
        Dim pBg As Long
        Dim pBs As Double
        Dim pEg As Long
        Dim pEs As Double
        
        pIst = CInt(gPlanVerisi(ui, ki, 0))
        pHat = CInt(gPlanVerisi(ui, ki, 1))
        pOp = CInt(gPlanVerisi(ui, ki, 2))
        pBg = CLng(gPlanVerisi(ui, ki, 3))
        pBs = CDbl(gPlanVerisi(ui, ki, 4))
        pEg = CLng(gPlanVerisi(ui, ki, 5))
        pEs = CDbl(gPlanVerisi(ui, ki, 6))
        
        Dim basDt As Date
        Dim bitDt As Date
        
        basDt = A2C_DateTimeYaz(gPlanBasTarih, pBg, pBs)
        bitDt = A2C_DateTimeYaz(gPlanBasTarih, pEg, pEs)
        
        If basDt <= bitTarihH + 1 And bitDt >= basTarihH Then
            ws.Cells(r, 1).Value = gPlanIlkUcak + ui
            ws.Cells(r, 2).Value = A2C_StageAdi(pIst)
            ws.Cells(r, 3).Value = pHat
            ws.Cells(r, 4).Value = pOp + 1
            ws.Cells(r, 5).Value = basDt
            ws.Cells(r, 6).Value = bitDt
            
            ws.Cells(r, 5).NumberFormat = "DD.MM.YYYY HH:MM"
            ws.Cells(r, 6).NumberFormat = "DD.MM.YYYY HH:MM"
            
            ws.Range(ws.Cells(r, 1), ws.Cells(r, 6)).Borders.LineStyle = xlContinuous
            
            r = r + 1
        End If
    Next ki
Next ui

ws.Columns("A:F").AutoFit

Application.ScreenUpdating = True
MsgBox "Haftalik plan olusturuldu!", vbInformation
Exit Sub
Hata:
Application.ScreenUpdating = True
MsgBox "Hata: " & Err.Description, vbCritical
End Sub

