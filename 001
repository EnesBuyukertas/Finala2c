Sub A2C_PlanDetayOlusturVeyaGuncelle(ilkUcak As Long, ucakSayisi As Long)
Dim ws As Worksheet

If Not A2C_SheetVarMi("PlanDetay") Then
    Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
    ws.Name = "PlanDetay"
    ws.Cells.Font.Name = "Calibri"
    Call A2C_PlanDetayBaslikYaz(ws)
Else
    Set ws = ThisWorkbook.Sheets("PlanDetay")
    If Trim(CStr(ws.Cells(1, 1).Value)) = "" Then
        Call A2C_PlanDetayBaslikYaz(ws)
    End If
End If

Dim i As Long
Dim ucakNo As Long
Dim bulunanSatir As Long
Dim c As Long

For i = 0 To ucakSayisi - 1
    ucakNo = ilkUcak + i
    bulunanSatir = A2C_UcakSatiriBul(ws, ucakNo)

    If bulunanSatir = 0 Then
        bulunanSatir = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row + 1
        ws.Cells(bulunanSatir, 1).Value = ucakNo

        ws.Cells(bulunanSatir, 2).Value = 0

        For c = 3 To 10
            ws.Cells(bulunanSatir, c).Value = 0
        Next c

        For c = 11 To 18
            ws.Cells(bulunanSatir, c).Value = 0
        Next c
    End If
Next i

ws.Columns("A:AK").AutoFit
End Sub

Sub A2C_DetayOku(ilkUcak As Long, ucakSayisi As Long, _
durusSaat() As Double, ekSaat() As Double, pinTarih() As Double)

Dim ws As Worksheet
Set ws = ThisWorkbook.Sheets("PlanDetay")

ReDim durusSaat(0 To ucakSayisi - 1)
ReDim ekSaat(0 To ucakSayisi - 1, 0 To A2C_STAGE_COUNT - 1)
ReDim pinTarih(0 To ucakSayisi - 1, 0 To A2C_STAGE_COUNT - 1)

Dim i As Long
Dim s As Integer
Dim ucakNo As Long
Dim r As Long
Dim v As Variant

For i = 0 To ucakSayisi - 1
    ucakNo = ilkUcak + i
    r = A2C_UcakSatiriBul(ws, ucakNo)

    If r > 0 Then
        If IsNumeric(ws.Cells(r, 2).Value) Then
            durusSaat(i) = CDbl(ws.Cells(r, 2).Value)
        Else
            durusSaat(i) = 0
        End If

        For s = 0 To A2C_STAGE_COUNT - 1
            If IsNumeric(ws.Cells(r, 3 + s).Value) Then
                ekSaat(i, s) = CDbl(ws.Cells(r, 3 + s).Value)
            Else
                ekSaat(i, s) = 0
            End If

            v = ws.Cells(r, 11 + s).Value

            If IsDate(v) Then
                pinTarih(i, s) = CDbl(CDate(v))
            ElseIf IsNumeric(v) Then
                If CDbl(v) > 0 Then
                    pinTarih(i, s) = CDbl(v)
                Else
                    pinTarih(i, s) = 0
                End If
            Else
                pinTarih(i, s) = 0
            End If
        Next s
    End If
Next i
End Sub

