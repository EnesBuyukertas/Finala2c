    gunAdlari(6) = "Paz"

    Dim gun_idx As Long
    Dim si As Integer

    For gun_idx = 0 To gunSayisi - 1
        
        Dim dd As Date
        Dim gun_adi As String
        Dim is_tatil As Boolean
        Dim bas_col As Long
        Dim bit_col As Long
        Dim gunVardiya As Integer
        
        dd = basTarih + gun_idx
        gun_adi = gunAdlari(Weekday(dd, vbMonday) - 1)
        is_tatil = TatilMiGun(gun_idx, basTarih)
        gunVardiya = GunVardiyaSayisi(gun_idx, basTarih)
        
        bas_col = VERI_COL + gun_idx * saat_sayisi
        bit_col = bas_col + saat_sayisi - 1
        
        ws.Range(ws.Cells(1, bas_col), ws.Cells(1, bit_col)).Merge
        
        With ws.Cells(1, bas_col)
            .Value = gun_adi & " " & Format(dd, "DD.MM.YYYY")
            .Font.Bold = True
            .Font.Size = 8
            .Font.Color = RGB(255, 255, 255)
            
            If is_tatil Or gunVardiya = 0 Then
                .Interior.Color = RGB(160, 160, 160)
            Else
                .Interior.Color = RGB(31, 78, 121)
            End If
            
            .HorizontalAlignment = xlCenter
            .VerticalAlignment = xlCenter
        End With
        
        Dim v As Integer
        
        For v = 1 To maxVardiya
            
            Dim vBas As Double
            Dim vBit As Double
            Dim vBitG As Double
            Dim v_bas_col As Long
            Dim v_bit_col As Long
            
            vBas = VardiyaBas(v)
            vBit = VardiyaBit(v)
            
            If vBit >= 24 Then
                vBitG = vBit - 24
            Else
                vBitG = vBit
            End If
            
            v_bas_col = -1
            v_bit_col = -1
            
            For si = 0 To saat_sayisi - 1
                If saatlerD(si) >= vBas And saatlerD(si) < vBit Then
                    If v_bas_col = -1 Then v_bas_col = bas_col + si
                    v_bit_col = bas_col + si
                End If
            Next si
            
            If v_bas_col > 0 Then
                
                ws.Range(ws.Cells(2, v_bas_col), ws.Cells(2, v_bit_col)).Merge
                
                With ws.Cells(2, v_bas_col)
                    
                    If v <= gunVardiya And Not is_tatil Then
                        
                        Dim vrenk As String
                        
                        Select Case v
                            Case 1: vrenk = "2E75B6"
                            Case 2: vrenk = "375623"
                            Case 3: vrenk = "7030A0"
                        End Select
                        
                        Dim vb_s As Integer
                        Dim vb_dk As Integer
                        Dim vbt_s As Integer
                        Dim vbt_dk As Integer
                        
                        vb_s = CInt(Int(vBas))
                        vb_dk = CInt((vBas - Int(vBas)) * 60)
                        vbt_s = CInt(Int(vBitG))
                        vbt_dk = CInt((vBitG - Int(vBitG)) * 60)
                        
                        .Value = "S" & v & " (" & Format(vb_s, "00") & ":" & Format(vb_dk, "00") & "-" & Format(vbt_s, "00") & ":" & Format(vbt_dk, "00") & ")"
                        .Interior.Color = RGB(CLng("&H" & Left(vrenk, 2)), CLng("&H" & Mid(vrenk, 3, 2)), CLng("&H" & Right(vrenk, 2)))
                        
                    Else
                        .Value = ""
                        .Interior.Color = RGB(217, 217, 217)
                    End If
                    
                    .Font.Bold = True
                    .Font.Size = 7
                    .Font.Color = RGB(255, 255, 255)
                    .HorizontalAlignment = xlCenter
                    .VerticalAlignment = xlCenter
                End With
            End If
        Next v

        For si = 0 To saat_sayisi - 1
            
            Dim scol As Long
            Dim sdVal As Double
            Dim sdGoster As Double
            Dim s_h As Integer
            Dim s_m As Integer
            Dim is_mola As Boolean
            Dim mv As Integer
            
            scol = bas_col + si
            sdVal = saatlerD(si)
            sdGoster = sdVal
            
            If sdGoster >= 24 Then sdGoster = sdGoster - 24
            
            s_h = CInt(Int(sdGoster))
            s_m = CInt((sdGoster - Int(sdGoster)) * 60)
            
            is_mola = False
            
            If Not is_tatil Then
                For mv = 1 To gunVardiya
                    If sdVal >= VardiyaMolaBas(mv) And sdVal < VardiyaMolaBit(mv) Then
                        is_mola = True
                        Exit For
                    End If
                Next mv
            End If
            
            With ws.Cells(3, scol)
                .Value = Format(s_h, "00") & ":" & Format(s_m, "00")
                .Font.Size = 6
                .Font.Bold = True
                
                If is_mola Then
                    .Interior.Color = RGB(255, 200, 0)
                    .Font.Color = RGB(100, 60, 0)
                ElseIf is_tatil Or HangiVardiyaGun(sdVal, gun_idx, basTarih) = 0 Then
                    .Interior.Color = RGB(230, 230, 230)
                    .Font.Color = RGB(120, 120, 120)
                Else
                    .Interior.Color = RGB(214, 228, 240)
                    .Font.Color = RGB(0, 0, 0)
                End If
                
                .HorizontalAlignment = xlCenter
                .VerticalAlignment = xlCenter
                .Borders.LineStyle = xlContinuous
                .Borders.Weight = xlHairline
                .Borders.Color = RGB(180, 180, 180)
            End With
            
            ws.Columns(scol).ColumnWidth = 3.2
        Next si
    Next gun_idx

    ws.Columns(IST_COL).ColumnWidth = 22
    ws.Columns(OP_COL).ColumnWidth = 42

    Dim rr As Integer
    Dim cc As Integer
    
    For rr = 1 To 3
        For cc = 1 To 2
            With ws.Cells(rr, cc)
                .Font.Bold = True
                .Font.Size = 9
                .Font.Color = RGB(255, 255, 255)
                .Interior.Color = RGB(31, 78, 121)
                .HorizontalAlignment = xlCenter
                .VerticalAlignment = xlCenter
            End With
        Next cc
    Next rr
    
    ws.Cells(1, IST_COL).Value = "ISTASYON / HAT"
    ws.Cells(1, OP_COL).Value = "OPERASYON"
    
    ws.Range(ws.Cells(1, IST_COL), ws.Cells(3, IST_COL)).Merge
    ws.Range(ws.Cells(1, OP_COL), ws.Cells(3, OP_COL)).Merge

    Dim ist_adlari(0 To 7) As String
    
    ist_adlari(0) = "COJI 1"
    ist_adlari(1) = "COJI 2 WINDSHIELD"
    ist_adlari(2) = "COJI 2 MATE"
    ist_adlari(3) = "OUT OF COJI"
    ist_adlari(4) = "LAY OFF"
    ist_adlari(5) = "BOYA"
    ist_adlari(6) = "SEALANT"
    ist_adlari(7) = "FINAL"

    Dim ist_hatlar(0 To 7) As Integer
    
    ist_hatlar(0) = 2
    ist_hatlar(1) = 5
    ist_hatlar(2) = 5
    ist_hatlar(3) = 1
    ist_hatlar(4) = 1
    ist_hatlar(5) = 1
    ist_hatlar(6) = 1
    ist_hatlar(7) = 1

    Dim op_sayilari(0 To 7) As Integer
    
    op_sayilari(0) = 6
    op_sayilari(1) = 2
    op_sayilari(2) = 3
    op_sayilari(3) = 5
    op_sayilari(4) = 6
    op_sayilari(5) = 2
    op_sayilari(6) = 1
    op_sayilari(7) = 1

    Dim op_adlar(0 To 7, 0 To 5) As String
    
    op_adlar(0, 0) = " CANOPY-TOPSKIN-0100 | LOCATION OF PARTS"
    op_adlar(0, 1) = " CANOPY-TOPSKIN-0150 | PRE-ARM INSTALL&ARM OPERATION"
    op_adlar(0, 2) = " CANOPY-TOPSKIN-0200 | ARM OPERATION"
    op_adlar(0, 3) = " CANOPY-TOPSKIN-0250 | FRAME INSTALLATION AFTER ARM"
    op_adlar(0, 4) = " CANOPY-TOPSKIN-0300 | OTHERS"
    op_adlar(0, 5) = " CANOPY-TOPSKIN-0350 | OUT OF COJI PROCESS"
    
    op_adlar(1, 0) = " CANOPY-0070 | COLD WORKING OF HOLES"
    op_adlar(1, 1) = " CANOPY-0075 | WINDSHIELD INSTALLATION"
    
    op_adlar(2, 0) = " CANOPY-0080 | INTEGRATION"
    op_adlar(2, 1) = " CANOPY-0084 | SILL EXT INTERCOSTAL AND STRAP INSTALLATION"
    op_adlar(2, 2) = " CANOPY-0086 | COJI 2 WINDSHIELD OPERATIONS"
    
    op_adlar(3, 0) = " CANOPY-0078 | OUT OF COJI-4 - OOC"
    op_adlar(3, 1) = " CANOPY-0087 | FR10 SECTOR CENTER EXT AND GUSSET INST - OOC"
    op_adlar(3, 2) = " CANOPY-0090 | WINDSHIELD OPERATIONS - OOC"
    op_adlar(3, 3) = " CANOPY-0140 | GTI MEASUREMENT - LAZER"
    op_adlar(3, 4) = " CANOPY-0091 | RETAINER INSTALLATION - OOC"
    
    op_adlar(4, 0) = " CANOPY-0097 | OVERHEAD AND HUD BRACKETS"
    op_adlar(4, 1) = " CANOPY-0092 | RETAINER NUT INSTALLATION"
    op_adlar(4, 2) = " CANOPY-0111 | OUT OF COJI-2"
    op_adlar(4, 3) = " CANOPY-0150 | ID PLATE&GROUND STUD OPS & ELECTRICAL BONDING"
    op_adlar(4, 4) = " CANOPY-1041 | OUT OF COJI"
    op_adlar(4, 5) = " CANOPY-1072 | OUT OF COJI-3"
    
    op_adlar(5, 0) = " CANOPY-0120 | TOUCH UP OPERATIONS"
    op_adlar(5, 1) = " CANOPY-0125 | TOUCH UP OPERATIONS"
    
    op_adlar(6, 0) = " CANOPY-0130 | SEALANT OPERATIONS"
    op_adlar(7, 0) = " FINAL | FINAL OPERATIONS"

    Dim satir_harita As Object
    Set satir_harita = CreateObject("Scripting.Dictionary")

    Dim mevcut_satir As Long
    mevcut_satir = BASLIK_SATIR + 1

    Dim ist_idx As Integer
    Dim hat_no As Integer
    Dim op_idx As Integer

    For ist_idx = 0 To 7
        For hat_no = 1 To ist_hatlar(ist_idx)
            
            Dim hat_label As String
            
            If ist_hatlar(ist_idx) > 1 Then
                hat_label = ist_adlari(ist_idx) & " - Hat " & hat_no
            Else
                hat_label = ist_adlari(ist_idx)
            End If
            
            With ws.Cells(mevcut_satir, IST_COL)
                .Value = hat_label
                .Font.Bold = True
                .Font.Size = 9
                .Font.Color = RGB(255, 255, 255)
                .Interior.Color = RGB(46, 64, 87)
                .VerticalAlignment = xlCenter
                .WrapText = True
            End With
            
            With ws.Cells(mevcut_satir, OP_COL)
                .Interior.Color = RGB(46, 64, 87)
            End With
            
            For gun_idx = 0 To gunSayisi - 1
                Dim bc As Long
                bc = VERI_COL + gun_idx * saat_sayisi
                ws.Range(ws.Cells(mevcut_satir, bc), ws.Cells(mevcut_satir, bc + saat_sayisi - 1)).Interior.Color = RGB(46, 64, 87)
            Next gun_idx
            
            ws.Rows(mevcut_satir).RowHeight = 18
            mevcut_satir = mevcut_satir + 1
            
            For op_idx = 0 To op_sayilari(ist_idx) - 1
                
                Dim key As String
                key = CStr(ist_idx * 1000 + hat_no * 10 + op_idx)
                satir_harita(key) = mevcut_satir
                
                With ws.Cells(mevcut_satir, IST_COL)
                    .Interior.Color = RGB(242, 242, 242)
                End With
                
                With ws.Cells(mevcut_satir, OP_COL)
                    .Value = op_adlar(ist_idx, op_idx)
                    .Font.Size = 7
                    .Interior.Color = RGB(242, 242, 242)
                    .VerticalAlignment = xlCenter
                End With
                
                ws.Rows(mevcut_satir).RowHeight = 15
                mevcut_satir = mevcut_satir + 1
            Next op_idx
        Next hat_no
    Next ist_idx

    Dim ui As Long

    For ui = 0 To ucakSayisi - 1
        
        Dim ucak_no As Long
        Dim renk As String
        Dim r_val As Long
        Dim g_val As Long
        Dim b_val As Long
        
        ucak_no = ilkUcak + ui
        renk = renkler(ui Mod 20)
        
        r_val = CLng("&H" & Left(renk, 2))
        g_val = CLng("&H" & Mid(renk, 3, 2))
        b_val = CLng("&H" & Right(renk, 2))
        
        Dim kayit_idx As Long
        
        For kayit_idx = 0 To A2C_MAX_KAYIT - 1
            
            If plan(ui, kayit_idx, 0) = -1 Then Exit For
            
            Dim p_ist As Integer
            Dim p_hat As Integer
            Dim p_op As Integer
            Dim p_bas_gun As Long
            Dim p_bas_saat As Double
            Dim p_bit_gun As Long
            Dim p_bit_saat As Double
            
            p_ist = CInt(plan(ui, kayit_idx, 0))
            p_hat = CInt(plan(ui, kayit_idx, 1))
            p_op = CInt(plan(ui, kayit_idx, 2))
            p_bas_gun = CLng(plan(ui, kayit_idx, 3))
            p_bas_saat = CDbl(plan(ui, kayit_idx, 4))
            p_bit_gun = CLng(plan(ui, kayit_idx, 5))
            p_bit_saat = CDbl(plan(ui, kayit_idx, 6))
            
            Dim s_key As String
            s_key = CStr(p_ist * 1000 + p_hat * 10 + p_op)
            
            If Not satir_harita.Exists(s_key) Then GoTo sonraki_kayit
            
            Dim s_no As Long
            s_no = CLng(satir_harita(s_key))
            
            Dim cg As Long
            Dim cs As Double
            
            cg = p_bas_gun
            cs = Int(p_bas_saat * 2) / 2
            
            Dim ilk_hucre As Boolean
            ilk_hucre = True
            
            Do While (cg < p_bit_gun) Or (cg = p_bit_gun And cs < p_bit_saat)
                
                If cg >= gunSayisi Then Exit Do
                
                Dim found_si As Integer
                found_si = -1
                
                For si = 0 To saat_sayisi - 1
                    If Abs(saatlerD(si) - cs) < 0.001 Then
                        found_si = si
                        Exit For
                    End If
                Next si
                
                If found_si >= 0 Then
                    
                    If Not TatilMiGun(cg, basTarih) Then
                        
                        If HangiVardiyaGun(cs, cg, basTarih) > 0 Then
                            
                            Dim s_col As Long
                            s_col = VERI_COL + cg * saat_sayisi + found_si
                            
                            Dim is_mola_saat As Boolean
                            is_mola_saat = False
                            
                            Dim mv2 As Integer
                            
                            For mv2 = 1 To GunVardiyaSayisi(cg, basTarih)
                                If cs >= VardiyaMolaBas(mv2) And cs < VardiyaMolaBit(mv2) Then
                                    is_mola_saat = True
                                    Exit For
                                End If
                            Next mv2
                            
                            Dim sonraki_cs As Double
                            Dim sonraki_cg As Long
                            
                            sonraki_cs = cs + 0.5
                            sonraki_cg = cg
                            
                            If maxVardiya = 1 Then
                                If sonraki_cs >= 15# Then
                                    sonraki_cs = 7#
                                    sonraki_cg = cg + 1
                                End If
                            ElseIf maxVardiya = 2 Then
                                If sonraki_cs >= 23# Then
                                    sonraki_cs = 7#
                                    sonraki_cg = cg + 1
                                End If
                            Else
                                If sonraki_cs >= 31# Then
                                    sonraki_cs = 7#
                                    sonraki_cg = cg + 1
                                End If
                            End If
                            
                            Dim son_hucre As Boolean
                            son_hucre = (sonraki_cg > p_bit_gun) Or (sonraki_cg = p_bit_gun And sonraki_cs >= p_bit_saat)
                            
                            Dim bas_s As Integer
                            Dim bas_dk As Integer
                            Dim bit_s As Integer
                            Dim bit_dk As Integer
                            
                            bas_s = CInt(Int(p_bas_saat)) Mod 24
                            bas_dk = CInt((p_bas_saat - Int(p_bas_saat)) * 60)
                            bit_s = CInt(Int(p_bit_saat)) Mod 24
                            bit_dk = CInt((p_bit_saat - Int(p_bit_saat)) * 60)
                            
                            If is_mola_saat Then
                                With ws.Cells(s_no, s_col)
                                    .Interior.Color = RGB(CLng(r_val + (255 - r_val) * 0.5), CLng(g_val + (255 - g_val) * 0.5), CLng(b_val + (255 - b_val) * 0.5))
                                    .Value = "M"
                                    .Font.Size = 6
                                    .HorizontalAlignment = xlCenter
                                    .VerticalAlignment = xlCenter
                                    .Borders.LineStyle = xlContinuous
                                    .Borders.Weight = xlHairline
                                    .Borders.Color = RGB(150, 150, 150)
                                End With
                            Else
                                With ws.Cells(s_no, s_col)
                                    .Interior.Color = RGB(r_val, g_val, b_val)
                                    .Borders.LineStyle = xlContinuous
                                    .Borders.Weight = xlHairline
                                    .Borders.Color = RGB(150, 150, 150)
                                    
                                    If ilk_hucre And son_hucre Then
                                        .Value = ucak_no & " " & Format(bas_s, "00") & ":" & Format(bas_dk, "00") & "-" & Format(bit_s, "00") & ":" & Format(bit_dk, "00") & " " & op_kodlar(p_ist, p_op)
                                        .Font.Size = 6
                                        .Font.Bold = True
                                        .HorizontalAlignment = xlLeft
                                        .VerticalAlignment = xlCenter
                                        ilk_hucre = False
                                        
                                    ElseIf ilk_hucre Then
                                        .Value = ucak_no & " " & Format(bas_s, "00") & ":" & Format(bas_dk, "00") & " " & op_kodlar(p_ist, p_op)
                                        .Font.Size = 6
                                        .Font.Bold = True
                                        .HorizontalAlignment = xlLeft
                                        .VerticalAlignment = xlCenter
                                        ilk_hucre = False
                                        
                                    ElseIf son_hucre Then
                                        .Value = Format(bit_s, "00") & ":" & Format(bit_dk, "00")
                                        .Font.Size = 6
                                        .Font.Bold = True
                                        .HorizontalAlignment = xlRight
                                        .VerticalAlignment = xlCenter
                                    End If
                                End With
                            End If
                        End If
                    End If
                End If
                
                cs = cs + 0.5
                
                If maxVardiya = 1 Then
                    If cs >= 15# Then
                        cs = 7#
                        cg = cg + 1
                    End If
                ElseIf maxVardiya = 2 Then
                    If cs >= 23# Then
                        cs = 7#
                        cg = cg + 1
                    End If
                Else
                    If cs >= 31# Then
                        cs = 7#
                        cg = cg + 1
                    End If
                End If
            Loop
            
sonraki_kayit:
        Next kayit_idx
    Next ui

    ws.Activate
    ws.Cells(1, VERI_COL).Select
    ActiveWindow.FreezePanes = True
    ws.Cells(1, 1).Select
    
    ws.Rows(1).RowHeight = 20
    ws.Rows(2).RowHeight = 16
    ws.Rows(3).RowHeight = 14
End Sub

