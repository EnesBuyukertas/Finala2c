Function A2C_MaxVardiya() As Integer
Dim mx As Integer

mx = gNormalVardiya
If gCumartesiCalisiyorMu Then If gCumartesiVardiya > mx Then mx = gCumartesiVardiya
If gPazarCalisiyorMu Then If gPazarVardiya > mx Then mx = gPazarVardiya

If mx < 1 Then mx = 1
If mx > 3 Then mx = 3

A2C_MaxVardiya = mx
End Function

Function A2C_GunSutunSayisi(gunIdx As Long, basTarih As Date) As Integer
Dim gv As Integer
gv = GunVardiyaSayisi(gunIdx, basTarih)

If gv <= 0 Or TatilMiGun(gunIdx, basTarih) Then
    A2C_GunSutunSayisi = A2C_MaxVardiya()
Else
    A2C_GunSutunSayisi = gv
End If
End Function

Sub A2C_AySutunHaritasi(ayBas As Date, aySon As Date, planBasTarih As Date, colMap() As Long)
Dim gunSay As Long
Dim j As Long
Dim gunIdx As Long

gunSay = CLng(aySon - ayBas) + 1
ReDim colMap(0 To gunSay)

colMap(0) = 3

For j = 0 To gunSay - 1
    gunIdx = CLng((ayBas + j) - planBasTarih)
    colMap(j + 1) = colMap(j) + A2C_GunSutunSayisi(gunIdx, planBasTarih)
Next j
End Sub

Function A2C_VardiyaBasDate(dd As Date, vNoZeroBased As Integer) As Date
Select Case vNoZeroBased
Case 0: A2C_VardiyaBasDate = dd + TimeSerial(7, 0, 0)
Case 1: A2C_VardiyaBasDate = dd + TimeSerial(15, 0, 0)
Case 2: A2C_VardiyaBasDate = dd + TimeSerial(23, 0, 0)
End Select
End Function

Function A2C_VardiyaBitDate(dd As Date, vNoZeroBased As Integer) As Date
Select Case vNoZeroBased
Case 0: A2C_VardiyaBitDate = dd + TimeSerial(15, 0, 0)
Case 1: A2C_VardiyaBitDate = dd + TimeSerial(23, 0, 0)
Case 2: A2C_VardiyaBitDate = dd + 1 + TimeSerial(7, 0, 0)
End Select
End Function

Function A2C_PlanDateTime(planBasTarih As Date, gunIdx As Long, saatVal As Double) As Date
