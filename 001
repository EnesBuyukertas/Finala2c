Sub A2C_PinUygula(ByRef gun As Long, ByRef saat As Double, pinDeger As Double, basTarih As Date)
If pinDeger <= 0 Then Exit Sub

Dim pinT As Date
Dim pinGun As Long
Dim pinSaat As Double

pinT = CDate(pinDeger)
pinGun = CLng(pinT - basTarih)
pinSaat = 7#

If pinGun > gun Or (pinGun = gun And pinSaat > saat) Then
    gun = pinGun
    saat = pinSaat
    Call IlkUygunZaman(gun, saat, basTarih)
End If
End Sub

