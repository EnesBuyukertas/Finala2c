' ====================================================
' PLAN OLUSTUR
' ====================================================
Sub PlanOlustur()
On Error GoTo Hata

Application.ScreenUpdating = False

Dim ilkUcak As Long, ucakSayisi As Long
Dim c1BasGun As Long, c2BasGun As Long
Dim c1BasSaat As Double, c2BasSaat As Double
Dim basTarih As Date, gunSayisi As Long

Call AyarlariOku(ilkUcak, ucakSayisi, c1BasGun, c1BasSaat, c2BasGun, c2BasSaat, basTarih, gunSayisi)

Call A2C_PlanDetayOlusturVeyaGuncelle(ilkUcak, ucakSayisi)

Dim a2cDurusSaat() As Double
Dim a2cEkSaat() As Double
Dim a2cPinTarih() As Double

Call A2C_DetayOku(ilkUcak, ucakSayisi, a2cDurusSaat, a2cEkSaat, a2cPinTarih)

Dim c1Sureler(0 To 5) As Double
c1Sureler(0) = C1_OP1_SURE
c1Sureler(1) = C1_OP2_SURE
c1Sureler(2) = C1_OP3_SURE
c1Sureler(3) = C1_OP4_SURE
c1Sureler(4) = C1_OP5_SURE
c1Sureler(5) = C1_OP6_SURE

Dim winSureler(0 To 1) As Double
winSureler(0) = WIN_OP1_SURE
winSureler(1) = WIN_OP2_SURE

Dim mateSureler(0 To 2) As Double
mateSureler(0) = MATE_OP1_SURE
mateSureler(1) = MATE_OP2_SURE
mateSureler(2) = MATE_OP3_SURE

Dim istSur(3 To 7, 0 To 5) As Double

istSur(3, 0) = OOC_OP1_SURE
istSur(3, 1) = OOC_OP2_SURE
istSur(3, 2) = OOC_OP3_SURE
istSur(3, 3) = OOC_OP4_SURE
istSur(3, 4) = OOC_OP5_SURE

istSur(4, 0) = LAY_OP1_SURE
istSur(4, 1) = LAY_OP2_SURE
istSur(4, 2) = LAY_OP3_SURE
istSur(4, 3) = LAY_OP4_SURE
istSur(4, 4) = LAY_OP5_SURE
istSur(4, 5) = LAY_OP6_SURE

istSur(5, 0) = BOYA_OP1_SURE
istSur(5, 1) = BOYA_OP2_SURE
istSur(6, 0) = SEAL_OP1_SURE
istSur(7, 0) = FINAL_OP1_SURE

Dim istOpSay(3 To 7) As Integer
istOpSay(3) = 5
istOpSay(4) = 6
istOpSay(5) = 2
istOpSay(6) = 1
istOpSay(7) = 1

Dim c1HatGun(1 To COJI1_HAT) As Long
Dim c1HatSaat(1 To COJI1_HAT) As Double
Dim c2HatGun(1 To COJI2_HAT) As Long
Dim c2HatSaat(1 To COJI2_HAT) As Double
Dim tekHatGun(3 To 7) As Long
Dim tekHatSaat(3 To 7) As Double

Dim h As Integer

For h = 1 To COJI1_HAT
    c1HatGun(h) = c1BasGun
    c1HatSaat(h) = c1BasSaat
Next h

For h = 1 To COJI2_HAT
    c2HatGun(h) = c2BasGun
    c2HatSaat(h) = c2BasSaat
Next h

Dim enErkenGun As Long
Dim enErkenSaat As Double

If c1BasGun < c2BasGun Or (c1BasGun = c2BasGun And c1BasSaat <= c2BasSaat) Then
    enErkenGun = c1BasGun
    enErkenSaat = c1BasSaat
Else
    enErkenGun = c2BasGun
    enErkenSaat = c2BasSaat
End If

For h = 3 To 7
    tekHatGun(h) = enErkenGun
    tekHatSaat(h) = enErkenSaat
Next h

Dim plan() As Variant
ReDim plan(0 To ucakSayisi - 1, 0 To A2C_MAX_KAYIT - 1, 0 To 6)

Dim pi As Long, pj As Long

For pi = 0 To ucakSayisi - 1
    For pj = 0 To A2C_MAX_KAYIT - 1
        plan(pi, pj, 0) = -1
    Next pj
Next pi

Dim ui As Long

For ui = 0 To ucakSayisi - 1
    Dim kayitIdx As Long
    kayitIdx = 0
    
    Dim c1S(0 To 5) As Double
    Dim ws(0 To 1) As Double
    Dim mS(0 To 2) As Double
    Dim istS(3 To 7, 0 To 5) As Double
    
    Dim op As Integer
    Dim istIdx As Integer
    
    For op = 0 To 5
        c1S(op) = c1Sureler(op)
    Next op
    
    For op = 0 To 1
        ws(op) = winSureler(op)
    Next op
    
    For op = 0 To 2
        mS(op) = mateSureler(op)
    Next op
    
    For istIdx = 3 To 7
        For op = 0 To 5
            istS(istIdx, op) = istSur(istIdx, op)
        Next op
    Next istIdx
    
    c1S(5) = A2C_SurePozitif(c1S(5) + a2cEkSaat(ui, A2C_STAGE_C1))
    ws(1) = A2C_SurePozitif(ws(1) + a2cEkSaat(ui, A2C_STAGE_WIN))
    mS(2) = A2C_SurePozitif(mS(2) + a2cEkSaat(ui, A2C_STAGE_MATE))
    istS(3, 4) = A2C_SurePozitif(istS(3, 4) + a2cEkSaat(ui, A2C_STAGE_OUT))
    istS(4, 5) = A2C_SurePozitif(istS(4, 5) + a2cEkSaat(ui, A2C_STAGE_LAY))
    istS(5, 1) = A2C_SurePozitif(istS(5, 1) + a2cEkSaat(ui, A2C_STAGE_BOYA))
    istS(6, 0) = A2C_SurePozitif(istS(6, 0) + a2cEkSaat(ui, A2C_STAGE_SEAL))
    istS(7, 0) = A2C_SurePozitif(istS(7, 0) + a2cEkSaat(ui, A2C_STAGE_FINAL))
    
    ' COJI 1
    Dim c1H As Integer
    Dim c1EnG As Long
    Dim c1EnS As Double
    
    c1H = 1
    c1EnG = c1HatGun(1)
    c1EnS = c1HatSaat(1)
    
    For h = 2 To COJI1_HAT
        If c1HatGun(h) < c1EnG Or (c1HatGun(h) = c1EnG And c1HatSaat(h) < c1EnS) Then
            c1EnG = c1HatGun(h)
            c1EnS = c1HatSaat(h)
            c1H = h
        End If
    Next h
    
    Dim c1BasG As Long
    Dim c1BasS As Double
    
    c1BasG = c1EnG
    c1BasS = c1EnS
    
    Call IlkUygunZaman(c1BasG, c1BasS, basTarih)
    
    If a2cDurusSaat(ui) > 0 Then
        Call SaatEkle(c1BasG, c1BasS, a2cDurusSaat(ui), basTarih)
    End If
    
    Call A2C_PinUygula(c1BasG, c1BasS, a2cPinTarih(ui, A2C_STAGE_C1), basTarih)
    
    Dim c1SonG As Long
    Dim c1SonS As Double
    
    c1SonG = c1BasG
    c1SonS = c1BasS
    
    For op = 0 To 5
        Dim og As Long
        Dim os As Double
        Dim bg As Long
        Dim bs As Double
        
        og = c1SonG
        os = c1SonS
        
        Call IlkUygunZaman(og, os, basTarih)
        
        bg = og
        bs = os
        
        Call SaatEkle(og, os, c1S(op), basTarih)
        Call A2C_KayitEkle(plan, ui, kayitIdx, 0, c1H, op, bg, bs, og, os)
        
        c1SonG = og
        c1SonS = os
    Next op
    
    c1HatGun(c1H) = c1SonG
    c1HatSaat(c1H) = c1SonS
    
    Dim c1BitG As Long
    Dim c1BitS As Double
    
    c1BitG = c1SonG
    c1BitS = c1SonS
    
    ' WINDSHIELD
    Dim c2HWin As Integer
    Dim c2EnG As Long
    Dim c2EnS As Double
    
    c2HWin = 1
    c2EnG = c2HatGun(1)
    c2EnS = c2HatSaat(1)
    
    For h = 2 To COJI2_HAT
        If c2HatGun(h) < c2EnG Or (c2HatGun(h) = c2EnG And c2HatSaat(h) < c2EnS) Then
            c2EnG = c2HatGun(h)
            c2EnS = c2HatSaat(h)
            c2HWin = h
        End If
    Next h
    
    Dim winBasG As Long
    Dim winBasS As Double
    
    If c2EnG > c1BasG Or (c2EnG = c1BasG And c2EnS > c1BasS) Then
        winBasG = c2EnG
        winBasS = c2EnS
    Else
        winBasG = c1BasG
        winBasS = c1BasS
    End If
    
    Call IlkUygunZaman(winBasG, winBasS, basTarih)
    Call A2C_PinUygula(winBasG, winBasS, a2cPinTarih(ui, A2C_STAGE_WIN), basTarih)
    
    Dim winSonG As Long
    Dim winSonS As Double
    
    winSonG = winBasG
    winSonS = winBasS
    
    For op = 0 To 1
        og = winSonG
        os = winSonS
        
        Call IlkUygunZaman(og, os, basTarih)
        
        bg = og
        bs = os
        
        Call SaatEkle(og, os, ws(op), basTarih)
        Call A2C_KayitEkle(plan, ui, kayitIdx, 1, c2HWin, op, bg, bs, og, os)
        
        winSonG = og
        winSonS = os
    Next op
    
    c2HatGun(c2HWin) = winSonG
    c2HatSaat(c2HWin) = winSonS
    
    Dim winBitG As Long
    Dim winBitS As Double
    
    winBitG = winSonG
    winBitS = winSonS
    
    ' MATE
    Dim c2HMate As Integer
    
    c2HMate = 1
    c2EnG = c2HatGun(1)
    c2EnS = c2HatSaat(1)
    
    For h = 2 To COJI2_HAT
        If c2HatGun(h) < c2EnG Or (c2HatGun(h) = c2EnG And c2HatSaat(h) < c2EnS) Then
            c2EnG = c2HatGun(h)
            c2EnS = c2HatSaat(h)
            c2HMate = h
        End If
    Next h
    
    Dim mateReqG As Long
    Dim mateReqS As Double
    
    If c1BitG > winBitG Or (c1BitG = winBitG And c1BitS >= winBitS) Then
        mateReqG = c1BitG
        mateReqS = c1BitS
    Else
        mateReqG = winBitG
        mateReqS = winBitS
    End If
    
    Dim mateBasG As Long
    Dim mateBasS As Double
    
    If c2EnG > mateReqG Or (c2EnG = mateReqG And c2EnS > mateReqS) Then
        mateBasG = c2EnG
        mateBasS = c2EnS
    Else
        mateBasG = mateReqG
        mateBasS = mateReqS
    End If
    
    Call IlkUygunZaman(mateBasG, mateBasS, basTarih)
    Call A2C_PinUygula(mateBasG, mateBasS, a2cPinTarih(ui, A2C_STAGE_MATE), basTarih)
    
    Dim mateSonG As Long
    Dim mateSonS As Double
    
    mateSonG = mateBasG
    mateSonS = mateBasS
    
    For op = 0 To 2
        og = mateSonG
        os = mateSonS
        
        Call IlkUygunZaman(og, os, basTarih)
        
        bg = og
        bs = os
        
        Call SaatEkle(og, os, mS(op), basTarih)
        Call A2C_KayitEkle(plan, ui, kayitIdx, 2, c2HMate, op, bg, bs, og, os)
        
        mateSonG = og
        mateSonS = os
    Next op
    
    c2HatGun(c2HMate) = mateSonG
    c2HatSaat(c2HMate) = mateSonS
    
    Dim oncekiG As Long
    Dim oncekiS As Double
    
    oncekiG = mateSonG
    oncekiS = mateSonS
    
    ' TEK HATLI ISTASYONLAR
    For istIdx = 3 To 7
        Dim hatG As Long
        Dim hatS As Double
        
        hatG = tekHatGun(istIdx)
        hatS = tekHatSaat(istIdx)
        
        Dim istBasG As Long
        Dim istBasS As Double
        
        If hatG > oncekiG Or (hatG = oncekiG And hatS > oncekiS) Then
            istBasG = hatG
            istBasS = hatS
        Else
            istBasG = oncekiG
            istBasS = oncekiS
        End If
        
        Call IlkUygunZaman(istBasG, istBasS, basTarih)
        
        Select Case istIdx
            Case 3: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_OUT), basTarih)
            Case 4: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_LAY), basTarih)
            Case 5: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_BOYA), basTarih)
            Case 6: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_SEAL), basTarih)
            Case 7: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_FINAL), basTarih)
        End Select
        
        Dim istSonG As Long
        Dim istSonS As Double
        
        istSonG = istBasG
        istSonS = istBasS
        
        For op = 0 To istOpSay(istIdx) - 1
            og = istSonG
            os = istSonS
            
            Call IlkUygunZaman(og, os, basTarih)
            
            bg = og
            bs = os
            
            Call SaatEkle(og, os, istS(istIdx, op), basTarih)
            Call A2C_KayitEkle(plan, ui, kayitIdx, istIdx, 1, op, bg, bs, og, os)
            
            istSonG = og
            istSonS = os
        Next op
        
        tekHatGun(istIdx) = istSonG
        tekHatSaat(istIdx) = istSonS
        
        oncekiG = istSonG
        oncekiS = istSonS
    Next istIdx
Next ui

gPlanVerisi = plan
gPlanUcakSayisi = ucakSayisi
gPlanIlkUcak = ilkUcak
gPlanBasTarih = basTarih
gPlanGunSayisi = gunSayisi

gPlanVerisi = plan
gPlanUcakSayisi = ucakSayisi
gPlanIlkUcak = ilkUcak
gPlanBasTarih = basTarih
gPlanGunSayisi = gunSayisi

GorselOlustur plan, ucakSayisi, ilkUcak, basTarih, gunSayisi
A2C_AylikPlanOlustur plan, ucakSayisi, ilkUcak, basTarih, gunSayisi
A2C_PlanDetaySonuclariYaz plan, ilkUcak, ucakSayisi, basTarih

Application.ScreenUpdating = True
MsgBox ucakSayisi & " ucak planlandi!", vbInformation, "Tamam"
Exit Sub

Application.ScreenUpdating = True
MsgBox ucakSayisi & " ucak planlandi!", vbInformation, "Tamam"
