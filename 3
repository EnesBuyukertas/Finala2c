' ====================================================
' MAKRO 4: STEP TARIH DEGISIMI
' ====================================================
' PlanDetay'da her ucak icin sutun 30-37 = Pin tarihleri
' (0 = serbest, dolu = o adim en erken bu tarihte baslar)
' Bu makro ilgili hucreyi gunceller, GuncelleVeCizPin cagrilir
 
Sub StepTarihDegisimi()
   On Error GoTo Hata4
   If Not AyarlariOku() Then MsgBox "Once UretimPlaniOlustur calistirin!", vbExclamation: Exit Sub
 
   Dim wsAy As Worksheet: Set wsAy = ThisWorkbook.Sheets("Ayarlar")
   Dim aySayisi As Integer: aySayisi = CInt(wsAy.Cells(1, 7).Value)
   Dim wsP As Worksheet: Set wsP = ThisWorkbook.Sheets("PlanDetay")
   Dim ucakSayisi As Long: ucakSayisi = wsP.Cells(wsP.Rows.Count, 1).End(xlUp).Row - 1
   If ucakSayisi < 1 Then MsgBox "PlanDetay bos!", vbExclamation: Exit Sub
 
   ' Ucak sec
   Dim hedefUcak As Long: hedefUcak = CLng(InputBox("Ucak numarasi:", "Step Tarih Degisimi"))
   Dim hedefIdx As Long: hedefIdx = -1
   Dim i As Long
   For i = 0 To ucakSayisi - 1
       If CLng(wsP.Cells(i + 2, 1).Value) = hedefUcak Then hedefIdx = i: Exit For
   Next i
   If hedefIdx = -1 Then MsgBox "Ucak bulunamadi!", vbExclamation: Exit Sub
 
   ' Adim sec
   Dim adimStr As String
   adimStr = InputBox("Hangi adim?" & vbCrLf & _
                      "1 = COJI 1" & vbCrLf & _
                      "2 = WINDSHIELD" & vbCrLf & _
                      "3 = MATE" & vbCrLf & _
                      "4 = OUT OF" & vbCrLf & _
                      "5 = LAY OFF" & vbCrLf & _
                      "6 = BOYA" & vbCrLf & _
                      "7 = SEALANT" & vbCrLf & _
                      "8 = FINAL", "Step Tarih Degisimi", "1")
   Dim adimNo As Integer: adimNo = CInt(adimStr)
   If adimNo < 1 Or adimNo > 8 Then MsgBox "Gecersiz adim!", vbExclamation: Exit Sub
 
   ' Yeni baslangic tarihi
   Dim yeniTarihStr As String
   Dim adimAdlari(1 To 8) As String
   adimAdlari(1) = "COJI 1": adimAdlari(2) = "WINDSHIELD": adimAdlari(3) = "MATE"
   adimAdlari(4) = "OUT OF": adimAdlari(5) = "LAY OFF": adimAdlari(6) = "BOYA"
   adimAdlari(7) = "SEALANT": adimAdlari(8) = "FINAL"
 
   ' Mevcut pin tarihini varsayilan olarak goster
   Dim mevcutPin As String
   Dim pinHucre As Variant: pinHucre = wsP.Cells(hedefIdx + 2, 29 + adimNo).Value
   If pinHucre = 0 Or pinHucre = "" Then
       mevcutPin = Format(Now, "DD.MM.YYYY")
   Else
       mevcutPin = Format(CDate(pinHucre), "DD.MM.YYYY")
   End If
 
   yeniTarihStr = InputBox("Ucak " & hedefUcak & " - " & adimAdlari(adimNo) & vbCrLf & _
                           "Yeni baslangic tarihi (GG.AA.YYYY):" & vbCrLf & _
                           "(Bos birakir veya 0 girerseniz sabitleme kaldirilir)", _
                           "Step Tarih Degisimi", mevcutPin)
 
   ' Tum plani yeniden hesapla (pin bilgileriyle)
   Application.ScreenUpdating = False
 
   Dim ucNo() As Long, ucDurus() As Integer
   Dim ucCoji1Sure() As Integer, ucWindSure() As Integer, ucMateSure() As Integer
   Dim ucOutSure() As Integer, ucLaySure() As Integer, ucBoyaSure() As Integer
   Dim ucSealSure() As Integer, ucFinalSure() As Integer
   ReDim ucNo(0 To ucakSayisi - 1):        ReDim ucDurus(0 To ucakSayisi - 1)
   ReDim ucCoji1Sure(0 To ucakSayisi - 1): ReDim ucWindSure(0 To ucakSayisi - 1)
   ReDim ucMateSure(0 To ucakSayisi - 1):  ReDim ucOutSure(0 To ucakSayisi - 1)
   ReDim ucLaySure(0 To ucakSayisi - 1):   ReDim ucBoyaSure(0 To ucakSayisi - 1)
   ReDim ucSealSure(0 To ucakSayisi - 1):  ReDim ucFinalSure(0 To ucakSayisi - 1)
   Call PlanDetayOku(ucNo, ucDurus, ucCoji1Sure, ucWindSure, ucMateSure, ucOutSure, ucLaySure, ucBoyaSure, ucSealSure, ucFinalSure, ucakSayisi)
 
   ' Once mevcut pin tarihlerini oku
   Dim ucPinT() As Double
   ReDim ucPinT(0 To ucakSayisi - 1, 0 To 7)
   Dim j As Long, adm As Integer
   For j = 0 To ucakSayisi - 1
       For adm = 0 To 7
           Dim pv As Variant: pv = wsP.Cells(j + 2, 30 + adm).Value
           If IsNumeric(pv) Then
               If CDbl(pv) > 0 Then ucPinT(j, adm) = CDbl(pv)
           End If
       Next adm
   Next j
 
   ' Sonra yeni pin degerini diziye yaz (PlanDetay silinecegi icin onceden al)
   If yeniTarihStr = "" Or yeniTarihStr = "0" Then
       ucPinT(hedefIdx, adimNo - 1) = 0
   Else
       ucPinT(hedefIdx, adimNo - 1) = CDbl(CDate(yeniTarihStr))
   End If
 
   Call GuncelleVeCizPin(ucNo, ucDurus, ucCoji1Sure, ucWindSure, ucMateSure, ucOutSure, ucLaySure, ucBoyaSure, ucSealSure, ucFinalSure, ucakSayisi, aySayisi, ucPinT)
 
   Application.ScreenUpdating = True
   If yeniTarihStr = "" Or yeniTarihStr = "0" Then
       MsgBox "Ucak " & hedefUcak & " - " & adimAdlari(adimNo) & " sabitleme kaldirildi!", vbInformation
   Else
       MsgBox "Ucak " & hedefUcak & " - " & adimAdlari(adimNo) & " baslangici " & Format(CDate(yeniTarihStr), "DD.MM.YYYY") & " olarak sabitlendi!", vbInformation
   End If
   Exit Sub
Hata4:
   Application.ScreenUpdating = True
   MsgBox "Hata: " & Err.Description, vbCritical
End Sub
 
' ====================================================
' GuncelleVeCizPin - Pin tarihleriyle hesaplama
' ====================================================
Sub GuncelleVeCizPin( _
   ucNo() As Long, ucDurus() As Integer, _
   ucCoji1Sure() As Integer, ucWindSure() As Integer, ucMateSure() As Integer, _
   ucOutSure() As Integer, ucLaySure() As Integer, ucBoyaSure() As Integer, _
   ucSealSure() As Integer, ucFinalSure() As Integer, _
   ucakSayisi As Long, aySayisi As Integer, ucPinT() As Double)
 
   Dim wsAy As Worksheet: Set wsAy = ThisWorkbook.Sheets("Ayarlar")
   Dim c1BasT As Date, c1BasV As Integer, c2BasT As Date, c2BasV As Integer
   Call BaslangicBilgisiOku(c1BasT, c1BasV, c2BasT, c2BasV)
   Dim enErken As Date
   If c1BasT <= c2BasT Then enErken = c1BasT Else enErken = c2BasT
 
   Dim ucDurusBasT() As Date, ucDurusBasV() As Integer, ucDurusBitT() As Date, ucDurusBitV() As Integer
   Dim ucC1BasT() As Date, ucC1BasV() As Integer, ucC1BitT() As Date, ucC1BitV() As Integer, ucC1Hat() As Integer
   Dim ucWinBasT() As Date, ucWinBasV() As Integer, ucWinBitT() As Date, ucWinBitV() As Integer, ucWinHat() As Integer
   Dim ucMateBasT() As Date, ucMateBasV() As Integer, ucMateBitT() As Date, ucMateBitV() As Integer, ucMateHat() As Integer
   Dim ucOutBasT() As Date, ucOutBasV() As Integer, ucOutBitT() As Date, ucOutBitV() As Integer
   Dim ucLayBasT() As Date, ucLayBasV() As Integer, ucLayBitT() As Date, ucLayBitV() As Integer
   Dim ucBoyaBasT() As Date, ucBoyaBasV() As Integer, ucBoyaBitT() As Date, ucBoyaBitV() As Integer
   Dim ucSealBasT() As Date, ucSealBasV() As Integer, ucSealBitT() As Date, ucSealBitV() As Integer
   Dim ucFinalBasT() As Date, ucFinalBasV() As Integer, ucFinalBitT() As Date, ucFinalBitV() As Integer
 
   Call TumHesaplaPin(ucNo, ucDurus, ucCoji1Sure, ucWindSure, ucMateSure, ucOutSure, ucLaySure, ucBoyaSure, ucSealSure, ucFinalSure, _
                   ucakSayisi, c1BasT, c1BasV, c2BasT, c2BasV, ucPinT, _
                   ucDurusBasT, ucDurusBasV, ucDurusBitT, ucDurusBitV, _
                   ucC1BasT, ucC1BasV, ucC1BitT, ucC1BitV, ucC1Hat, _
                   ucWinBasT, ucWinBasV, ucWinBitT, ucWinBitV, ucWinHat, _
                   ucMateBasT, ucMateBasV, ucMateBitT, ucMateBitV, ucMateHat, _
                   ucOutBasT, ucOutBasV, ucOutBitT, ucOutBitV, _
                   ucLayBasT, ucLayBasV, ucLayBitT, ucLayBitV, _
                   ucBoyaBasT, ucBoyaBasV, ucBoyaBitT, ucBoyaBitV, _
                   ucSealBasT, ucSealBasV, ucSealBitT, ucSealBitV, _
                   ucFinalBasT, ucFinalBasV, ucFinalBitT, ucFinalBitV)
 
   Call GorselOlustur(ucNo, ucDurus, _
                      ucC1BasT, ucC1BasV, ucC1BitT, ucC1BitV, ucC1Hat, _
                      ucWinBasT, ucWinBasV, ucWinBitT, ucWinBitV, ucWinHat, _
                      ucMateBasT, ucMateBasV, ucMateBitT, ucMateBitV, ucMateHat, _
                      ucOutBasT, ucOutBasV, ucOutBitT, ucOutBitV, _
                      ucLayBasT, ucLayBasV, ucLayBitT, ucLayBitV, _
                      ucBoyaBasT, ucBoyaBasV, ucBoyaBitT, ucBoyaBitV, _
                      ucSealBasT, ucSealBasV, ucSealBitT, ucSealBitV, _
                      ucFinalBasT, ucFinalBasV, ucFinalBitT, ucFinalBitV, _
                      ucDurusBasT, ucDurusBasV, ucDurusBitT, ucDurusBitV, _
                      ucakSayisi, aySayisi, enErken)
 
   ' PlanDetay'i tamamen yeniden olustur (pin bilgilerini de yaz)
   On Error Resume Next: Application.DisplayAlerts = False
   ThisWorkbook.Sheets("PlanDetay").Delete
   Application.DisplayAlerts = True: On Error GoTo 0
   Dim wsP As Worksheet
   Set wsP = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   wsP.Name = "PlanDetay": wsP.Cells.Font.Name = "Calibri"
 
   Dim basliklar As Variant
   basliklar = Array("Ucak", "Durus", "C1Sure", "WinSure", "MateSure", "OutSure", "LaySure", "BoyaSure", "SealSure", "FinalSure", _
                     "C1Hat", "C1Bas", "C1Bit", "WinHat", "WinBas", "WinBit", "MateHat", "MateBas", "MateBit", _
                     "OutBas", "OutBit", "LayBas", "LayBit", "BoyaBas", "BoyaBit", "SealBas", "SealBit", "FinalBas", "FinalBit", _
                     "PinC1", "PinWin", "PinMate", "PinOut", "PinLay", "PinBoya", "PinSeal", "PinFinal")
   Dim k As Integer
   For k = 0 To UBound(basliklar)
       wsP.Cells(1, k + 1).Value = basliklar(k)
   Next k
   wsP.Range(wsP.Cells(1, 1), wsP.Cells(1, UBound(basliklar) + 1)).Font.Bold = True
   wsP.Range(wsP.Cells(1, 1), wsP.Cells(1, UBound(basliklar) + 1)).Interior.Color = RGB(0, 80, 160)
   wsP.Range(wsP.Cells(1, 1), wsP.Cells(1, UBound(basliklar) + 1)).Font.Color = RGB(255, 255, 255)
 
   Dim i As Long
   For i = 0 To ucakSayisi - 1
       Dim r As Long: r = i + 2
       wsP.Cells(r, 1).Value = ucNo(i)
       wsP.Cells(r, 2).Value = ucDurus(i)
       wsP.Cells(r, 3).Value = ucCoji1Sure(i)
       wsP.Cells(r, 4).Value = ucWindSure(i)
       wsP.Cells(r, 5).Value = ucMateSure(i)
       wsP.Cells(r, 6).Value = ucOutSure(i)
       wsP.Cells(r, 7).Value = ucLaySure(i)
       wsP.Cells(r, 8).Value = ucBoyaSure(i)
       wsP.Cells(r, 9).Value = ucSealSure(i)
       wsP.Cells(r, 10).Value = ucFinalSure(i)
       wsP.Cells(r, 11).Value = ucC1Hat(i)
       wsP.Cells(r, 12).Value = ucC1BasT(i):   wsP.Cells(r, 12).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 13).Value = ucC1BitT(i):   wsP.Cells(r, 13).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 14).Value = ucWinHat(i)
       wsP.Cells(r, 15).Value = ucWinBasT(i):  wsP.Cells(r, 15).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 16).Value = ucWinBitT(i):  wsP.Cells(r, 16).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 17).Value = ucMateHat(i)
       wsP.Cells(r, 18).Value = ucMateBasT(i): wsP.Cells(r, 18).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 19).Value = ucMateBitT(i): wsP.Cells(r, 19).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 20).Value = ucOutBasT(i):  wsP.Cells(r, 20).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 21).Value = ucOutBitT(i):  wsP.Cells(r, 21).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 22).Value = ucLayBasT(i):  wsP.Cells(r, 22).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 23).Value = ucLayBitT(i):  wsP.Cells(r, 23).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 24).Value = ucBoyaBasT(i): wsP.Cells(r, 24).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 25).Value = ucBoyaBitT(i): wsP.Cells(r, 25).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 26).Value = ucSealBasT(i): wsP.Cells(r, 26).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 27).Value = ucSealBitT(i): wsP.Cells(r, 27).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 28).Value = ucFinalBasT(i):wsP.Cells(r, 28).NumberFormat = "DD.MM.YYYY"
       wsP.Cells(r, 29).Value = ucFinalBitT(i):wsP.Cells(r, 29).NumberFormat = "DD.MM.YYYY"
       ' Pin tarihleri (30-37)
       Dim adm2 As Integer
       For adm2 = 0 To 7
           If ucPinT(i, adm2) <> 0 Then
               wsP.Cells(r, 30 + adm2).Value = ucPinT(i, adm2)
               wsP.Cells(r, 30 + adm2).NumberFormat = "DD.MM.YYYY"
               wsP.Cells(r, 30 + adm2).Interior.Color = RGB(255, 220, 150)
           Else
               wsP.Cells(r, 30 + adm2).Value = 0
           End If
       Next adm2
       wsP.Range(wsP.Cells(r, 1), wsP.Cells(r, 29)).Interior.Color = UcakRenk(i)
   Next i
   wsP.Columns("A:AK").AutoFit
End Sub
 
' ====================================================
' TumHesaplaPin - Pin tarihleri destekli hesaplama
' ucPinT(i, 0..7): 0=C1, 1=Win, 2=Mate, 3=Out, 4=Lay, 5=Boya, 6=Seal, 7=Final
' ====================================================
Sub TumHesaplaPin( _
   ucNo() As Long, ucDurus() As Integer, _
   ucCoji1Sure() As Integer, ucWindSure() As Integer, ucMateSure() As Integer, _
   ucOutSure() As Integer, ucLaySure() As Integer, ucBoyaSure() As Integer, _
   ucSealSure() As Integer, ucFinalSure() As Integer, _
   ucakSayisi As Long, _
   c1BasT As Date, c1BasV As Integer, _
   c2BasT As Date, c2BasV As Integer, _
   ucPinT() As Double, _
   ucDurusBasT() As Date, ucDurusBasV() As Integer, ucDurusBitT() As Date, ucDurusBitV() As Integer, _
   ucC1BasT() As Date, ucC1BasV() As Integer, ucC1BitT() As Date, ucC1BitV() As Integer, _
   ucC1Hat() As Integer, _
   ucWinBasT() As Date, ucWinBasV() As Integer, ucWinBitT() As Date, ucWinBitV() As Integer, _
   ucWinHat() As Integer, _
   ucMateBasT() As Date, ucMateBasV() As Integer, ucMateBitT() As Date, ucMateBitV() As Integer, _
   ucMateHat() As Integer, _
   ucOutBasT() As Date, ucOutBasV() As Integer, ucOutBitT() As Date, ucOutBitV() As Integer, _
   ucLayBasT() As Date, ucLayBasV() As Integer, ucLayBitT() As Date, ucLayBitV() As Integer, _
   ucBoyaBasT() As Date, ucBoyaBasV() As Integer, ucBoyaBitT() As Date, ucBoyaBitV() As Integer, _
   ucSealBasT() As Date, ucSealBasV() As Integer, ucSealBitT() As Date, ucSealBitV() As Integer, _
   ucFinalBasT() As Date, ucFinalBasV() As Integer, ucFinalBitT() As Date, ucFinalBitV() As Integer)
 
   ReDim ucDurusBasT(0 To ucakSayisi - 1): ReDim ucDurusBasV(0 To ucakSayisi - 1)
   ReDim ucDurusBitT(0 To ucakSayisi - 1): ReDim ucDurusBitV(0 To ucakSayisi - 1)
   ReDim ucC1BasT(0 To ucakSayisi - 1):    ReDim ucC1BasV(0 To ucakSayisi - 1)
   ReDim ucC1BitT(0 To ucakSayisi - 1):    ReDim ucC1BitV(0 To ucakSayisi - 1)
   ReDim ucC1Hat(0 To ucakSayisi - 1)
   ReDim ucWinBasT(0 To ucakSayisi - 1):   ReDim ucWinBasV(0 To ucakSayisi - 1)
   ReDim ucWinBitT(0 To ucakSayisi - 1):   ReDim ucWinBitV(0 To ucakSayisi - 1)
   ReDim ucWinHat(0 To ucakSayisi - 1)
   ReDim ucMateBasT(0 To ucakSayisi - 1):  ReDim ucMateBasV(0 To ucakSayisi - 1)
   ReDim ucMateBitT(0 To ucakSayisi - 1):  ReDim ucMateBitV(0 To ucakSayisi - 1)
   ReDim ucMateHat(0 To ucakSayisi - 1)
   ReDim ucOutBasT(0 To ucakSayisi - 1):   ReDim ucOutBasV(0 To ucakSayisi - 1)
   ReDim ucOutBitT(0 To ucakSayisi - 1):   ReDim ucOutBitV(0 To ucakSayisi - 1)
   ReDim ucLayBasT(0 To ucakSayisi - 1):   ReDim ucLayBasV(0 To ucakSayisi - 1)
   ReDim ucLayBitT(0 To ucakSayisi - 1):   ReDim ucLayBitV(0 To ucakSayisi - 1)
   ReDim ucBoyaBasT(0 To ucakSayisi - 1):  ReDim ucBoyaBasV(0 To ucakSayisi - 1)
   ReDim ucBoyaBitT(0 To ucakSayisi - 1):  ReDim ucBoyaBitV(0 To ucakSayisi - 1)
   ReDim ucSealBasT(0 To ucakSayisi - 1):  ReDim ucSealBasV(0 To ucakSayisi - 1)
   ReDim ucSealBitT(0 To ucakSayisi - 1):  ReDim ucSealBitV(0 To ucakSayisi - 1)
   ReDim ucFinalBasT(0 To ucakSayisi - 1): ReDim ucFinalBasV(0 To ucakSayisi - 1)
   ReDim ucFinalBitT(0 To ucakSayisi - 1): ReDim ucFinalBitV(0 To ucakSayisi - 1)
 
   Dim c1SonT(1 To COJI1_HAT) As Date, c1SonV(1 To COJI1_HAT) As Integer
   Dim h As Integer
   For h = 1 To COJI1_HAT: c1SonT(h) = c1BasT: c1SonV(h) = c1BasV: Next h
 
   Dim c2SonT(1 To COJI2_HAT) As Date, c2SonV(1 To COJI2_HAT) As Integer
   For h = 1 To COJI2_HAT: c2SonT(h) = c2BasT: c2SonV(h) = c2BasV: Next h
 
   Dim enErkenT As Date
   If c1BasT <= c2BasT Then enErkenT = c1BasT Else enErkenT = c2BasT
 
   Dim outSonT As Date, outSonV As Integer
   Dim laySonT As Date, laySonV As Integer
   Dim boyaSonT As Date, boyaSonV As Integer
   Dim sealSonT As Date, sealSonV As Integer
   Dim finalSonT As Date, finalSonV As Integer
   outSonT = enErkenT:   outSonV = 0
   laySonT = enErkenT:   laySonV = 0
   boyaSonT = enErkenT:  boyaSonV = 0
   sealSonT = enErkenT:  sealSonV = 0
   finalSonT = enErkenT: finalSonV = 0
 
   Dim i As Long
   Dim startT As Date, startV As Integer, bitT As Date, bitV As Integer
   Dim c1H As Integer, c2H_win As Integer, c2H_mate As Integer
   Dim enDusukKod As Double, kod As Double
 
   ' Pin tarihi uygulama yardimcisi
   ' Eger pin > hesaplanan baslangic ise pini kullan
   Dim pinT As Date
 
   For i = 0 To ucakSayisi - 1
 
       ' --- DURUS ---
       If ucDurus(i) > 0 Then
           enDusukKod = PozKod(c1SonT(1), c1SonV(1)): c1H = 1
           For h = 2 To COJI1_HAT
               kod = PozKod(c1SonT(h), c1SonV(h))
               If kod < enDusukKod Then enDusukKod = kod: c1H = h
           Next h
           startT = c1SonT(c1H): startV = c1SonV(c1H)
           Call SonrakiBos(startT, startV)
           ucDurusBasT(i) = startT: ucDurusBasV(i) = startV
           Call Tuket(startT, startV, ucDurus(i), bitT, bitV)
           ucDurusBitT(i) = bitT: ucDurusBitV(i) = bitV
           c1SonT(c1H) = startT: c1SonV(c1H) = startV
       End If
 
       ' --- COJI1 (pin: adim 0) ---
       enDusukKod = PozKod(c1SonT(1), c1SonV(1)): c1H = 1
       For h = 2 To COJI1_HAT
           kod = PozKod(c1SonT(h), c1SonV(h))
           If kod < enDusukKod Then enDusukKod = kod: c1H = h
       Next h
       startT = c1SonT(c1H): startV = c1SonV(c1H)
       Call SonrakiBos(startT, startV)
       ' Pin uygula
       If ucPinT(i, 0) > 0 Then
           pinT = CDate(ucPinT(i, 0))
           If pinT > startT Then startT = pinT: startV = 0
           Call SonrakiBos(startT, startV)
       End If
       ucC1BasT(i) = startT: ucC1BasV(i) = startV
       ucC1Hat(i) = c1H
       Call Tuket(startT, startV, ucCoji1Sure(i), bitT, bitV)
       ucC1BitT(i) = bitT: ucC1BitV(i) = bitV
       c1SonT(c1H) = startT: c1SonV(c1H) = startV
       Dim c1BitKod As Double: c1BitKod = PozKod(ucC1BitT(i), ucC1BitV(i))
 
       ' --- WINDSHIELD (pin: adim 1) ---
       Dim winReqT As Date: winReqT = ucC1BasT(i)
       enDusukKod = PozKod(c2SonT(1), c2SonV(1)): c2H_win = 1
       For h = 2 To COJI2_HAT
           kod = PozKod(c2SonT(h), c2SonV(h))
           If kod < enDusukKod Then enDusukKod = kod: c2H_win = h
       Next h
       If PozKod(c2SonT(c2H_win), c2SonV(c2H_win)) > PozKod(winReqT, 0) Then
           startT = c2SonT(c2H_win): startV = c2SonV(c2H_win)
       Else
           startT = winReqT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       If ucPinT(i, 1) > 0 Then
           pinT = CDate(ucPinT(i, 1))
           If pinT > startT Then startT = pinT: startV = 0
           Call SonrakiBos(startT, startV)
       End If
       ucWinBasT(i) = startT: ucWinBasV(i) = startV
       ucWinHat(i) = c2H_win
       Call Tuket(startT, startV, ucWindSure(i), bitT, bitV)
       ucWinBitT(i) = bitT: ucWinBitV(i) = bitV
       c2SonT(c2H_win) = startT: c2SonV(c2H_win) = startV
       Dim winBitKod As Double: winBitKod = PozKod(ucWinBitT(i), ucWinBitV(i))
 
       ' --- MATE (pin: adim 2) ---
       Dim mateReqT As Date
       If c1BitKod >= winBitKod Then
           mateReqT = SonrakiIsGunu(ucC1BitT(i) + 1)
       Else
           mateReqT = SonrakiIsGunu(ucWinBitT(i) + 1)
       End If
       enDusukKod = PozKod(c2SonT(1), c2SonV(1)): c2H_mate = 1
       For h = 2 To COJI2_HAT
           kod = PozKod(c2SonT(h), c2SonV(h))
           If kod < enDusukKod Then enDusukKod = kod: c2H_mate = h
       Next h
       If PozKod(c2SonT(c2H_mate), c2SonV(c2H_mate)) > PozKod(mateReqT, 0) Then
           startT = c2SonT(c2H_mate): startV = c2SonV(c2H_mate)
       Else
           startT = mateReqT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       If ucPinT(i, 2) > 0 Then
           pinT = CDate(ucPinT(i, 2))
           If pinT > startT Then startT = pinT: startV = 0
           Call SonrakiBos(startT, startV)
       End If
       ucMateBasT(i) = startT: ucMateBasV(i) = startV
       ucMateHat(i) = c2H_mate
       Call Tuket(startT, startV, ucMateSure(i), bitT, bitV)
       ucMateBitT(i) = bitT: ucMateBitV(i) = bitV
       c2SonT(c2H_mate) = startT: c2SonV(c2H_mate) = startV
 
       Dim sonrakiT As Date: sonrakiT = SonrakiIsGunu(ucMateBitT(i) + 1)
 
       ' --- OUT OF (pin: adim 3) ---
       If PozKod(outSonT, outSonV) > PozKod(sonrakiT, 0) Then
           startT = outSonT: startV = outSonV
       Else
           startT = sonrakiT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       If ucPinT(i, 3) > 0 Then
           pinT = CDate(ucPinT(i, 3))
           If pinT > startT Then startT = pinT: startV = 0
           Call SonrakiBos(startT, startV)
       End If
       ucOutBasT(i) = startT: ucOutBasV(i) = startV
       Call Tuket(startT, startV, ucOutSure(i), bitT, bitV)
       ucOutBitT(i) = bitT: ucOutBitV(i) = bitV
       outSonT = startT: outSonV = startV
       sonrakiT = SonrakiIsGunu(ucOutBitT(i) + 1)
 
       ' --- LAY OFF (pin: adim 4) ---
       If PozKod(laySonT, laySonV) > PozKod(sonrakiT, 0) Then
           startT = laySonT: startV = laySonV
       Else
           startT = sonrakiT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       If ucPinT(i, 4) > 0 Then
           pinT = CDate(ucPinT(i, 4))
           If pinT > startT Then startT = pinT: startV = 0
           Call SonrakiBos(startT, startV)
       End If
       ucLayBasT(i) = startT: ucLayBasV(i) = startV
       Call Tuket(startT, startV, ucLaySure(i), bitT, bitV)
       ucLayBitT(i) = bitT: ucLayBitV(i) = bitV
       laySonT = startT: laySonV = startV
       sonrakiT = SonrakiIsGunu(ucLayBitT(i) + 1)
 
       ' --- BOYA (pin: adim 5) ---
       If PozKod(boyaSonT, boyaSonV) > PozKod(sonrakiT, 0) Then
           startT = boyaSonT: startV = boyaSonV
       Else
           startT = sonrakiT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       If ucPinT(i, 5) > 0 Then
           pinT = CDate(ucPinT(i, 5))
           If pinT > startT Then startT = pinT: startV = 0
           Call SonrakiBos(startT, startV)
       End If
       ucBoyaBasT(i) = startT: ucBoyaBasV(i) = startV
       Call Tuket(startT, startV, ucBoyaSure(i), bitT, bitV)
       ucBoyaBitT(i) = bitT: ucBoyaBitV(i) = bitV
       boyaSonT = startT: boyaSonV = startV
       sonrakiT = SonrakiIsGunu(ucBoyaBitT(i) + 1)
 
       ' --- SEALANT (pin: adim 6) ---
       If PozKod(sealSonT, sealSonV) > PozKod(sonrakiT, 0) Then
           startT = sealSonT: startV = sealSonV
       Else
           startT = sonrakiT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       If ucPinT(i, 6) > 0 Then
           pinT = CDate(ucPinT(i, 6))
           If pinT > startT Then startT = pinT: startV = 0
           Call SonrakiBos(startT, startV)
       End If
       ucSealBasT(i) = startT: ucSealBasV(i) = startV
       Call Tuket(startT, startV, ucSealSure(i), bitT, bitV)
       ucSealBitT(i) = bitT: ucSealBitV(i) = bitV
       sealSonT = startT: sealSonV = startV
       sonrakiT = SonrakiIsGunu(ucSealBitT(i) + 1)
 
       ' --- FINAL (pin: adim 7) ---
       If PozKod(finalSonT, finalSonV) > PozKod(sonrakiT, 0) Then
           startT = finalSonT: startV = finalSonV
       Else
           startT = sonrakiT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       If ucPinT(i, 7) > 0 Then
           pinT = CDate(ucPinT(i, 7))
           If pinT > startT Then startT = pinT: startV = 0
           Call SonrakiBos(startT, startV)
       End If
       ucFinalBasT(i) = startT: ucFinalBasV(i) = startV
       Call Tuket(startT, startV, ucFinalSure(i), bitT, bitV)
       ucFinalBitT(i) = bitT: ucFinalBitV(i) = bitV
       finalSonT = startT: finalSonV = startV
 
   Next i
End Sub
