   Select Case idx
       Case 0: TatilAdi = "1 Ocak 2026 - Yilbasi"
       Case 1: TatilAdi = "Ramazan Bayrami 2026 (20-22 Mart)"
       Case 2: TatilAdi = "23 Nisan 2026 - Ulusal Egemenlik"
       Case 3: TatilAdi = "1 Mayis 2026 - Isci Bayrami"
       Case 4: TatilAdi = "19 Mayis 2026 - Genclik Bayrami"
       Case 5: TatilAdi = "Kurban Bayrami 2026 (26-30 Mayis)"
       Case 6: TatilAdi = "15 Temmuz 2026 - Demokrasi Gunu"
       Case 7: TatilAdi = "30 Agustos 2026 - Zafer Bayrami"
       Case Else: TatilAdi = ""
   End Select
End Function
 
' ====================================================
' TAKVIM YARDIMCILARI
' ====================================================
Function ResmiTatilVardiya(dd As Date) As Integer
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       If dd >= gTatilTarihBas(tt) And dd <= gTatilTarihBit(tt) Then
           If gTatilCalis(tt) Then
               ResmiTatilVardiya = gTatilVardiya(tt)
           Else
               ResmiTatilVardiya = 0
           End If
           Exit Function
       End If
   Next tt
   ResmiTatilVardiya = -1
End Function
 
Function TatilMi(dd As Date) As Boolean
   TatilMi = False
   If Weekday(dd, vbMonday) = 7 Then TatilMi = True: Exit Function
   If ResmiTatilVardiya(dd) = 0 Then TatilMi = True
End Function
 
Function AktifVardiya(dd As Date) As Integer
   If TatilMi(dd) Then AktifVardiya = 0: Exit Function
   Dim rv As Integer: rv = ResmiTatilVardiya(dd)
   If rv > 0 Then AktifVardiya = rv Else AktifVardiya = gNormalVardiya
End Function
 
Function GunSutunSayisi(dd As Date) As Integer
   If TatilMi(dd) Then GunSutunSayisi = gNormalVardiya: Exit Function
   Dim rv As Integer: rv = ResmiTatilVardiya(dd)
   If rv > 0 Then GunSutunSayisi = rv Else GunSutunSayisi = gNormalVardiya
End Function
 
Function SonrakiIsGunu(dd As Date) As Date
   Dim s As Date: s = dd
   Do While TatilMi(s): s = s + 1: Loop
   SonrakiIsGunu = s
End Function
 
Function PozKod(t As Date, v As Integer) As Double
   PozKod = CDbl(t) * 10 + v
End Function
 
Sub SonrakiBos(ByRef t As Date, ByRef v As Integer)
   Do
       If TatilMi(t) Then
           t = t + 1: v = 0
       ElseIf v >= AktifVardiya(t) Then
           t = t + 1: v = 0
       Else
           Exit Do
       End If
   Loop
End Sub
 
Sub Tuket(ByRef t As Date, ByRef v As Integer, n As Integer, ByRef bitT As Date, ByRef bitV As Integer)
   Dim k As Integer: k = n
   Do While k > 0
       Call SonrakiBos(t, v)
       bitT = t: bitV = v: k = k - 1: v = v + 1
   Loop
   Call SonrakiBos(t, v)
End Sub
 
' ====================================================
' RENK VE GORUNUM
' ====================================================
Function UcakRenk(idx As Long) As Long
   Dim r(0 To 17) As Long
   r(0) = RGB(255, 255, 0):   r(1) = RGB(255, 100, 100): r(2) = RGB(0, 176, 240)
   r(3) = RGB(255, 192, 0):   r(4) = RGB(146, 208, 80):  r(5) = RGB(255, 102, 255)
   r(6) = RGB(0, 204, 153):   r(7) = RGB(255, 153, 204): r(8) = RGB(153, 204, 255)
   r(9) = RGB(255, 204, 0):   r(10) = RGB(204, 153, 255):r(11) = RGB(0, 204, 204)
   r(12) = RGB(255, 204, 153):r(13) = RGB(146, 208, 80): r(14) = RGB(255, 153, 0)
   r(15) = RGB(153, 255, 204):r(16) = RGB(255, 204, 255):r(17) = RGB(204, 255, 153)
   UcakRenk = r(idx Mod 18)
End Function
 
