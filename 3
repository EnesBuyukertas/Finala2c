Sub YazTekHucre(ws As Worksheet, satir As Long, sutun As Long, deger As Long, renk As Long)
   With ws.Cells(satir, sutun)
       .Value = deger: .Interior.Color = renk: .Font.Size = 7: .Font.Bold = True
       .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
       .Borders.LineStyle = xlContinuous: .Borders.Weight = xlThin
       .Borders.Color = RGB(120, 120, 120)
   End With
End Sub
 
Sub YazSiyahHucre(ws As Worksheet, satir As Long, sutun As Long)
   With ws.Cells(satir, sutun)
       .Value = "": .Interior.Color = RGB(30, 30, 30)
       .Borders.LineStyle = xlContinuous: .Borders.Weight = xlThin
       .Borders.Color = RGB(80, 80, 80)
   End With
End Sub
 
Sub AySutunHaritasi(ayBas As Date, gunSay As Long, colMap() As Long)
   ReDim colMap(0 To gunSay)
   colMap(0) = C_VERI
   Dim j As Long
   For j = 0 To gunSay - 1
       colMap(j + 1) = colMap(j) + GunSutunSayisi(ayBas + j)
   Next j
End Sub
 
' ====================================================
' CIZIM YARDIMCILARI
' ====================================================
Sub CizVardiyalar(ws As Worksheet, satir As Long, _
                 basT As Date, basV As Integer, bitT As Date, bitV As Integer, _
                 ucakNo As Long, renk As Long, ayBas As Date, aySon As Date, colMap() As Long)
   Dim dT As Date: dT = basT
   Dim dV As Integer: dV = basV
   Dim aV As Integer, c As Long
   Do
       If dT > bitT Then Exit Do
       If dT = bitT And dV > bitV Then Exit Do
       If TatilMi(dT) Then
           dT = dT + 1: dV = 0
       Else
           aV = AktifVardiya(dT)
           If dV < aV Then
               If dT >= ayBas And dT <= aySon Then
                   c = colMap(CLng(dT - ayBas)) + dV
                   Call YazTekHucre(ws, satir, c, ucakNo, renk)
               End If
               dV = dV + 1
               If dV >= aV Then dT = dT + 1: dV = 0
           Else
               dT = dT + 1: dV = 0
           End If
       End If
   Loop
End Sub
 
Sub CizDurus(ws As Worksheet, satir As Long, _
            basT As Date, basV As Integer, bitT As Date, bitV As Integer, _
            ayBas As Date, aySon As Date, colMap() As Long)
   Dim dT As Date: dT = basT
   Dim dV As Integer: dV = basV
   Dim aV As Integer, c As Long
   Do
       If dT > bitT Then Exit Do
       If dT = bitT And dV > bitV Then Exit Do
       If TatilMi(dT) Then
           dT = dT + 1: dV = 0
       Else
           aV = AktifVardiya(dT)
           If dV < aV Then
               If dT >= ayBas And dT <= aySon Then
                   c = colMap(CLng(dT - ayBas)) + dV
                   Call YazSiyahHucre(ws, satir, c)
               End If
               dV = dV + 1
               If dV >= aV Then dT = dT + 1: dV = 0
           Else
               dT = dT + 1: dV = 0
           End If
       End If
   Loop
End Sub
 
' ====================================================
' AYARLAR KAYDET / OKU
' ====================================================
Sub AyarlariKaydet(c1BasT As Date, c1BasV As Integer, c2BasT As Date, c2BasV As Integer)
   Dim wsA As Worksheet
   On Error Resume Next: Application.DisplayAlerts = False
   ThisWorkbook.Sheets("Ayarlar").Delete
   Application.DisplayAlerts = True: On Error GoTo 0
   Set wsA = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   wsA.Name = "Ayarlar": wsA.Visible = xlSheetHidden
   wsA.Cells(1, 1).Value = gNormalVardiya
   wsA.Cells(1, 2).Value = gTatilSayisi
   wsA.Cells(1, 3).Value = CDbl(c1BasT)   ' COJI1 baslangic tarihi
   wsA.Cells(1, 4).Value = c1BasV          ' COJI1 baslangic vardiya (0=S1)
   wsA.Cells(1, 5).Value = CDbl(c2BasT)   ' COJI2 baslangic tarihi
   wsA.Cells(1, 6).Value = c2BasV          ' COJI2 baslangic vardiya (0=S1)
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       wsA.Cells(tt + 2, 1).Value = CDbl(gTatilTarihBas(tt))
       wsA.Cells(tt + 2, 2).Value = CDbl(gTatilTarihBit(tt))
       If gTatilCalis(tt) Then wsA.Cells(tt + 2, 3).Value = 1 Else wsA.Cells(tt + 2, 3).Value = 0
       wsA.Cells(tt + 2, 4).Value = gTatilVardiya(tt)
   Next tt
End Sub
 
Function AyarlariOku() As Boolean
   On Error GoTo AyarYok
   Dim wsA As Worksheet: Set wsA = ThisWorkbook.Sheets("Ayarlar")
   gNormalVardiya = CInt(wsA.Cells(1, 1).Value)
   gTatilSayisi = CInt(wsA.Cells(1, 2).Value)
   Call TatilleriOlustur
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       gTatilCalis(tt) = (wsA.Cells(tt + 2, 3).Value = 1)
       gTatilVardiya(tt) = CInt(wsA.Cells(tt + 2, 4).Value)
   Next tt
   AyarlariOku = True: Exit Function
AyarYok:
   AyarlariOku = False
End Function
 
' COJI1 ve COJI2 baslangic bilgilerini Ayarlar'dan oku
Sub BaslangicBilgisiOku(ByRef c1BasT As Date, ByRef c1BasV As Integer, ByRef c2BasT As Date, ByRef c2BasV As Integer)
   Dim wsA As Worksheet: Set wsA = ThisWorkbook.Sheets("Ayarlar")
   c1BasT = CDate(wsA.Cells(1, 3).Value)
   c1BasV = CInt(wsA.Cells(1, 4).Value)
   c2BasT = CDate(wsA.Cells(1, 5).Value)
   c2BasV = CInt(wsA.Cells(1, 6).Value)
End Sub
 
' ====================================================
' ANA HESAPLAMA
' ====================================================
' Her ucak icin:
'   - COJI1 ve WINDSHIELD paralel baslar (her ikisi de kendi hattini/COJI2'yi kullanir)
'   - MATE: MAX(coji1 bitis, windshield bitis) sonrasi COJI2 hattinda
'   - OUT OF, LAYOFF, BOYA, SEALANT, FINAL: tek hat, sirayla
'   - DURUS: COJI1 baslamadan once bekleme suresi
 
Sub TumHesapla( _
   ucNo() As Long, ucDurus() As Integer, _
   ucCoji1Sure() As Integer, ucWindSure() As Integer, ucMateSure() As Integer, _
   ucOutSure() As Integer, ucLaySure() As Integer, ucBoyaSure() As Integer, _
   ucSealSure() As Integer, ucFinalSure() As Integer, _
   ucakSayisi As Long, _
   c1BasT As Date, c1BasV As Integer, _
   c2BasT As Date, c2BasV As Integer, _
   ucDurusBasT() As Date, ucDurusBasV() As Integer, ucDurusBitT() As Date, ucDurusBitV() As Integer, _
   ucC1BasT() As Date, ucC1BasV() As Integer, ucC1BitT() As Date, ucC1BitV() As Integer, _
   ucC1Hat() As Integer, _
   ucWinBasT() As Date, ucWinBasV() As Integer, ucWinBitT() As Date, ucWinBitV() As Integer, _
   ucWinHat() As Integer, _
   ucMateBasT() As Date, ucMateBasV() As Integer, ucMateBitT() As Date, ucMateBitV() As Integer, _
   ucMateHat() As Integer, _
   ucOutBasT() As Date, ucOutBasV() As Integer, ucOutBitT() As Date, ucOutBitV() As Integer, _
   ucLayBasT() As Date, ucLayBasV() As Integer, ucLayBitT() As Date, ucLayBitV() As Integer, _
   ucBoyaBasT() As Date, ucBoyaBasV() As Integer, ucBoyaBitT() As Date, ucBoyaBitV() As Integer, _
   ucSealBasT() As Date, ucSealBasV() As Integer, ucSealBitT() As Date, ucSealBitV() As Integer, _
   ucFinalBasT() As Date, ucFinalBasV() As Integer, ucFinalBitT() As Date, ucFinalBitV() As Integer)
 
   ' --- Dizileri boyutlandir ---
   ReDim ucDurusBasT(0 To ucakSayisi - 1): ReDim ucDurusBasV(0 To ucakSayisi - 1)
   ReDim ucDurusBitT(0 To ucakSayisi - 1): ReDim ucDurusBitV(0 To ucakSayisi - 1)
   ReDim ucC1BasT(0 To ucakSayisi - 1):    ReDim ucC1BasV(0 To ucakSayisi - 1)
   ReDim ucC1BitT(0 To ucakSayisi - 1):    ReDim ucC1BitV(0 To ucakSayisi - 1)
   ReDim ucC1Hat(0 To ucakSayisi - 1)
   ReDim ucWinBasT(0 To ucakSayisi - 1):   ReDim ucWinBasV(0 To ucakSayisi - 1)
   ReDim ucWinBitT(0 To ucakSayisi - 1):   ReDim ucWinBitV(0 To ucakSayisi - 1)
   ReDim ucWinHat(0 To ucakSayisi - 1)
   ReDim ucMateBasT(0 To ucakSayisi - 1):  ReDim ucMateBasV(0 To ucakSayisi - 1)
   ReDim ucMateBitT(0 To ucakSayisi - 1):  ReDim ucMateBitV(0 To ucakSayisi - 1)
   ReDim ucMateHat(0 To ucakSayisi - 1)
   ReDim ucOutBasT(0 To ucakSayisi - 1):   ReDim ucOutBasV(0 To ucakSayisi - 1)
   ReDim ucOutBitT(0 To ucakSayisi - 1):   ReDim ucOutBitV(0 To ucakSayisi - 1)
   ReDim ucLayBasT(0 To ucakSayisi - 1):   ReDim ucLayBasV(0 To ucakSayisi - 1)
   ReDim ucLayBitT(0 To ucakSayisi - 1):   ReDim ucLayBitV(0 To ucakSayisi - 1)
   ReDim ucBoyaBasT(0 To ucakSayisi - 1):  ReDim ucBoyaBasV(0 To ucakSayisi - 1)
   ReDim ucBoyaBitT(0 To ucakSayisi - 1):  ReDim ucBoyaBitV(0 To ucakSayisi - 1)
   ReDim ucSealBasT(0 To ucakSayisi - 1):  ReDim ucSealBasV(0 To ucakSayisi - 1)
   ReDim ucSealBitT(0 To ucakSayisi - 1):  ReDim ucSealBitV(0 To ucakSayisi - 1)
   ReDim ucFinalBasT(0 To ucakSayisi - 1): ReDim ucFinalBasV(0 To ucakSayisi - 1)
   ReDim ucFinalBitT(0 To ucakSayisi - 1): ReDim ucFinalBitV(0 To ucakSayisi - 1)
 
   ' --- Hat kuyruk posizyonlari ---
   ' COJI1: 2 hat - kendi baslangic tarihi ve vardiyasi
   Dim c1SonT(1 To COJI1_HAT) As Date, c1SonV(1 To COJI1_HAT) As Integer
   Dim h As Integer
   For h = 1 To COJI1_HAT: c1SonT(h) = c1BasT: c1SonV(h) = c1BasV: Next h
 
   ' COJI2: 5 hat (windshield + mate ortak) - kendi baslangic tarihi ve vardiyasi
   Dim c2SonT(1 To COJI2_HAT) As Date, c2SonV(1 To COJI2_HAT) As Integer
   For h = 1 To COJI2_HAT: c2SonT(h) = c2BasT: c2SonV(h) = c2BasV: Next h
 
   ' Tek hatli istasyonlar - en erken baslangictan baslar
   Dim enErkenT As Date
   If c1BasT <= c2BasT Then enErkenT = c1BasT Else enErkenT = c2BasT
 
   ' Tek hatli istasyonlar
   Dim outSonT As Date, outSonV As Integer
   Dim laySonT As Date, laySonV As Integer
   Dim boyaSonT As Date, boyaSonV As Integer
   Dim sealSonT As Date, sealSonV As Integer
   Dim finalSonT As Date, finalSonV As Integer
   outSonT = enErkenT:   outSonV = 0
   laySonT = enErkenT:   laySonV = 0
   boyaSonT = enErkenT:  boyaSonV = 0
   sealSonT = enErkenT:  sealSonV = 0
   finalSonT = enErkenT: finalSonV = 0
 
   Dim i As Long
   Dim startT As Date, startV As Integer, bitT As Date, bitV As Integer
   Dim c1H As Integer, c2H_win As Integer, c2H_mate As Integer
   Dim enDusukKod As Double, kod As Double
 
   For i = 0 To ucakSayisi - 1
 
       ' --- 1) DURUS ---
       If ucDurus(i) > 0 Then
           ' En erken bos COJI1 hattin baslangicina gore durus yerlesir
           enDusukKod = PozKod(c1SonT(1), c1SonV(1)): c1H = 1
           For h = 2 To COJI1_HAT
               kod = PozKod(c1SonT(h), c1SonV(h))
               If kod < enDusukKod Then enDusukKod = kod: c1H = h
           Next h
           startT = c1SonT(c1H): startV = c1SonV(c1H)
           Call SonrakiBos(startT, startV)
           ucDurusBasT(i) = startT: ucDurusBasV(i) = startV
           Call Tuket(startT, startV, ucDurus(i), bitT, bitV)
           ucDurusBitT(i) = bitT: ucDurusBitV(i) = bitV
           c1SonT(c1H) = startT: c1SonV(c1H) = startV
       End If
 
       ' --- 2) COJI1 (en erken bos hat) ---
       enDusukKod = PozKod(c1SonT(1), c1SonV(1)): c1H = 1
       For h = 2 To COJI1_HAT
           kod = PozKod(c1SonT(h), c1SonV(h))
           If kod < enDusukKod Then enDusukKod = kod: c1H = h
       Next h
       startT = c1SonT(c1H): startV = c1SonV(c1H)
       Call SonrakiBos(startT, startV)
       ucC1BasT(i) = startT: ucC1BasV(i) = startV
       ucC1Hat(i) = c1H
       Call Tuket(startT, startV, ucCoji1Sure(i), bitT, bitV)
       ucC1BitT(i) = bitT: ucC1BitV(i) = bitV
       c1SonT(c1H) = startT: c1SonV(c1H) = startV
       Dim c1BitKod As Double: c1BitKod = PozKod(ucC1BitT(i), ucC1BitV(i))
 
       ' --- 3) WINDSHIELD (COJI2, en erken bos hat, COJI1 ile paralel baslar) ---
       ' COJI1 baslangicina gore COJI2'de yer bul
       Dim winReqT As Date: winReqT = ucC1BasT(i)
       enDusukKod = PozKod(c2SonT(1), c2SonV(1)): c2H_win = 1
       For h = 2 To COJI2_HAT
           kod = PozKod(c2SonT(h), c2SonV(h))
           If kod < enDusukKod Then enDusukKod = kod: c2H_win = h
       Next h
       ' Eger hat musait degil ise hat bos olana kadar bekle
       If PozKod(c2SonT(c2H_win), c2SonV(c2H_win)) > PozKod(winReqT, 0) Then
           startT = c2SonT(c2H_win): startV = c2SonV(c2H_win)
       Else
           startT = winReqT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       ucWinBasT(i) = startT: ucWinBasV(i) = startV
       ucWinHat(i) = c2H_win
       Call Tuket(startT, startV, ucWindSure(i), bitT, bitV)
       ucWinBitT(i) = bitT: ucWinBitV(i) = bitV
       c2SonT(c2H_win) = startT: c2SonV(c2H_win) = startV
       Dim winBitKod As Double: winBitKod = PozKod(ucWinBitT(i), ucWinBitV(i))
 
       ' --- 4) MATE (COJI2, en erken bos hat, COJI1 VE WINDSHIELD bittikten sonra) ---
       ' Hangi bitis daha gec?
       Dim mateReqT As Date, mateReqV As Integer
       If c1BitKod >= winBitKod Then
           mateReqT = ucC1BitT(i): mateReqV = ucC1BitV(i)
       Else
           mateReqT = ucWinBitT(i): mateReqV = ucWinBitV(i)
       End If
       mateReqT = SonrakiIsGunu(mateReqT + 1)
 
       ' En erken bos COJI2 hatti bul
       enDusukKod = PozKod(c2SonT(1), c2SonV(1)): c2H_mate = 1
       For h = 2 To COJI2_HAT
           kod = PozKod(c2SonT(h), c2SonV(h))
           If kod < enDusukKod Then enDusukKod = kod: c2H_mate = h
       Next h
       If PozKod(c2SonT(c2H_mate), c2SonV(c2H_mate)) > PozKod(mateReqT, 0) Then
           startT = c2SonT(c2H_mate): startV = c2SonV(c2H_mate)
       Else
           startT = mateReqT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       ucMateBasT(i) = startT: ucMateBasV(i) = startV
       ucMateHat(i) = c2H_mate
       Call Tuket(startT, startV, ucMateSure(i), bitT, bitV)
       ucMateBitT(i) = bitT: ucMateBitV(i) = bitV
       c2SonT(c2H_mate) = startT: c2SonV(c2H_mate) = startV
 
       ' Sonraki asamalar icin baslangic = bir sonraki is gunu
       Dim sonrakiT As Date: sonrakiT = SonrakiIsGunu(ucMateBitT(i) + 1)
 
       ' --- 5) OUT OF (tek hat) ---
       If PozKod(outSonT, outSonV) > PozKod(sonrakiT, 0) Then
           startT = outSonT: startV = outSonV
       Else
           startT = sonrakiT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       ucOutBasT(i) = startT: ucOutBasV(i) = startV
       Call Tuket(startT, startV, ucOutSure(i), bitT, bitV)
       ucOutBitT(i) = bitT: ucOutBitV(i) = bitV
       outSonT = startT: outSonV = startV
       sonrakiT = SonrakiIsGunu(ucOutBitT(i) + 1)
 
       ' --- 6) LAY OFF (tek hat) ---
       If PozKod(laySonT, laySonV) > PozKod(sonrakiT, 0) Then
           startT = laySonT: startV = laySonV
       Else
           startT = sonrakiT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       ucLayBasT(i) = startT: ucLayBasV(i) = startV
       Call Tuket(startT, startV, ucLaySure(i), bitT, bitV)
       ucLayBitT(i) = bitT: ucLayBitV(i) = bitV
       laySonT = startT: laySonV = startV
       sonrakiT = SonrakiIsGunu(ucLayBitT(i) + 1)
 
       ' --- 7) BOYA (tek hat) ---
       If PozKod(boyaSonT, boyaSonV) > PozKod(sonrakiT, 0) Then
           startT = boyaSonT: startV = boyaSonV
       Else
           startT = sonrakiT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       ucBoyaBasT(i) = startT: ucBoyaBasV(i) = startV
       Call Tuket(startT, startV, ucBoyaSure(i), bitT, bitV)
       ucBoyaBitT(i) = bitT: ucBoyaBitV(i) = bitV
       boyaSonT = startT: boyaSonV = startV
       sonrakiT = SonrakiIsGunu(ucBoyaBitT(i) + 1)
 
       ' --- 8) SEALANT (tek hat) ---
       If PozKod(sealSonT, sealSonV) > PozKod(sonrakiT, 0) Then
           startT = sealSonT: startV = sealSonV
       Else
           startT = sonrakiT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       ucSealBasT(i) = startT: ucSealBasV(i) = startV
       Call Tuket(startT, startV, ucSealSure(i), bitT, bitV)
       ucSealBitT(i) = bitT: ucSealBitV(i) = bitV
       sealSonT = startT: sealSonV = startV
       sonrakiT = SonrakiIsGunu(ucSealBitT(i) + 1)
 
       ' --- 9) FINAL (tek hat) ---
       If PozKod(finalSonT, finalSonV) > PozKod(sonrakiT, 0) Then
           startT = finalSonT: startV = finalSonV
       Else
           startT = sonrakiT: startV = 0
       End If
       Call SonrakiBos(startT, startV)
       ucFinalBasT(i) = startT: ucFinalBasV(i) = startV
       Call Tuket(startT, startV, ucFinalSure(i), bitT, bitV)
       ucFinalBitT(i) = bitT: ucFinalBitV(i) = bitV
       finalSonT = startT: finalSonV = startV
 
   Next i
End Sub
 
' ====================================================
' GORSEL OLUSTUR
' ====================================================
' Satir yapisi (her ay blogu, BLOK_YUK satir):
'  baseRow+0  : Gun adi (Pzt, Sal...)
'  baseRow+1  : Gun sayisi
'  baseRow+2  : Vardiya no (S1, S2...)
'  baseRow+3  : COJI1 Hat1
'  baseRow+4  : COJI1 Hat2
'  baseRow+5  : WINDSHIELD Hat1
'  baseRow+6  : WINDSHIELD Hat2
'  baseRow+7  : WINDSHIELD Hat3
'  baseRow+8  : WINDSHIELD Hat4
'  baseRow+9  : WINDSHIELD Hat5
'  (COJI2 = Windshield + Mate hatlari)
'  baseRow+10 : MATE Hat1
'  baseRow+11 : MATE Hat2
'  baseRow+12 : MATE Hat3
'  baseRow+13 : MATE Hat4
'  baseRow+14 : MATE Hat5
'  baseRow+15 : OUT OF
'  baseRow+16 : LAY OFF
'  baseRow+17 : BOYA
'  baseRow+18 : SEALANT
'  baseRow+19 : FINAL
 
Sub GorselOlustur( _
   ucNo() As Long, ucDurus() As Integer, _
   ucC1BasT() As Date, ucC1BasV() As Integer, ucC1BitT() As Date, ucC1BitV() As Integer, ucC1Hat() As Integer, _
   ucWinBasT() As Date, ucWinBasV() As Integer, ucWinBitT() As Date, ucWinBitV() As Integer, ucWinHat() As Integer, _
   ucMateBasT() As Date, ucMateBasV() As Integer, ucMateBitT() As Date, ucMateBitV() As Integer, ucMateHat() As Integer, _
   ucOutBasT() As Date, ucOutBasV() As Integer, ucOutBitT() As Date, ucOutBitV() As Integer, _
   ucLayBasT() As Date, ucLayBasV() As Integer, ucLayBitT() As Date, ucLayBitV() As Integer, _
   ucBoyaBasT() As Date, ucBoyaBasV() As Integer, ucBoyaBitT() As Date, ucBoyaBitV() As Integer, _
   ucSealBasT() As Date, ucSealBasV() As Integer, ucSealBitT() As Date, ucSealBitV() As Integer, _
   ucFinalBasT() As Date, ucFinalBasV() As Integer, ucFinalBitT() As Date, ucFinalBitV() As Integer, _
   ucDurusBasT() As Date, ucDurusBasV() As Integer, ucDurusBitT() As Date, ucDurusBitV() As Integer, _
   ucakSayisi As Long, aySayisi As Integer, enErken As Date)
 
   Dim ws As Worksheet
   On Error Resume Next: Application.DisplayAlerts = False
   ThisWorkbook.Sheets("OtomatikPlan").Delete
   Application.DisplayAlerts = True: On Error GoTo 0
   Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   ws.Name = "OtomatikPlan": ws.Cells.Font.Name = "Calibri"
 
   Const BLOK_YUK As Integer = 21  ' 3 baslik + 17 satir veri + 1 bosluk
   Const DATA_SATIR As Integer = 17 ' COJI1x2 + WINDx5 + MATEx5 + OUT+LAY+BOYA+SEAL+FINAL
 
   Dim mm As Integer, curAy As Integer, curYil As Integer
   Dim ayBas As Date, aySon As Date, gunSay As Long, baseRow As Long
   Dim col As Long, j As Long, dd As Date, lastCol As Long
   Dim ui As Long, renk As Long, aktV As Integer
   Dim vv As Integer, ll As Integer, gunV As Integer
   Dim colMap() As Long, rr As Integer
 
   ' Satir etiket tanimlari
   Dim satirEtiketler(1 To DATA_SATIR) As String
   Dim satirRenkler(1 To DATA_SATIR) As Long
   satirEtiketler(1) = "COJI 1 - Hat 1":    satirRenkler(1) = RGB(255, 255, 180)
   satirEtiketler(2) = "COJI 1 - Hat 2":    satirRenkler(2) = RGB(255, 255, 180)
   satirEtiketler(3) = "WINDSHIELD - Hat 1": satirRenkler(3) = RGB(180, 220, 255)
   satirEtiketler(4) = "WINDSHIELD - Hat 2": satirRenkler(4) = RGB(180, 220, 255)
   satirEtiketler(5) = "WINDSHIELD - Hat 3": satirRenkler(5) = RGB(180, 220, 255)
   satirEtiketler(6) = "WINDSHIELD - Hat 4": satirRenkler(6) = RGB(180, 220, 255)
   satirEtiketler(7) = "WINDSHIELD - Hat 5": satirRenkler(7) = RGB(180, 220, 255)
   satirEtiketler(8) = "MATE - Hat 1":       satirRenkler(8) = RGB(200, 255, 200)
   satirEtiketler(9) = "MATE - Hat 2":       satirRenkler(9) = RGB(200, 255, 200)
   satirEtiketler(10) = "MATE - Hat 3":      satirRenkler(10) = RGB(200, 255, 200)
   satirEtiketler(11) = "MATE - Hat 4":      satirRenkler(11) = RGB(200, 255, 200)
   satirEtiketler(12) = "MATE - Hat 5":      satirRenkler(12) = RGB(200, 255, 200)
   satirEtiketler(13) = "OUT OF":            satirRenkler(13) = RGB(255, 200, 160)
   satirEtiketler(14) = "LAY OFF":           satirRenkler(14) = RGB(220, 200, 255)
   satirEtiketler(15) = "BOYA":              satirRenkler(15) = RGB(255, 180, 180)
   satirEtiketler(16) = "SEALANT":           satirRenkler(16) = RGB(200, 240, 240)
   satirEtiketler(17) = "FINAL":             satirRenkler(17) = RGB(180, 255, 180)
 
   For mm = 0 To aySayisi - 1
       curAy = Month(enErken) + mm: curYil = Year(enErken)
       Do While curAy > 12: curAy = curAy - 12: curYil = curYil + 1: Loop
       ayBas = DateSerial(curYil, curAy, 1)
       aySon = DateSerial(curYil, curAy + 1, 0)
       gunSay = Day(aySon): baseRow = 1 + mm * BLOK_YUK
       Call AySutunHaritasi(ayBas, gunSay, colMap)
 
       ' Ay etiketi
       ws.Range(ws.Cells(baseRow + 3, C_AYADI), ws.Cells(baseRow + 3 + DATA_SATIR - 1, C_AYADI)).Merge
       With ws.Cells(baseRow + 3, C_AYADI)
           .Value = AyAdi(curAy): .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
           .Orientation = 90: .Font.Bold = True: .Font.Size = 11
           .Font.Color = RGB(255, 255, 255): .Interior.Color = RGB(0, 80, 160)
       End With
       ws.Columns(C_AYADI).ColumnWidth = 3.5
 
       ' Satir etiketleri
       For ll = 1 To DATA_SATIR
           With ws.Cells(baseRow + 2 + ll, C_LABEL)
               .Value = satirEtiketler(ll): .Font.Bold = True: .Font.Size = 8
               .VerticalAlignment = xlCenter: .Interior.Color = satirRenkler(ll)
           End With
       Next ll
       ws.Columns(C_LABEL).ColumnWidth = 18
 
       ' Gun baslik satirlari
       For j = 0 To gunSay - 1
           dd = ayBas + j: col = colMap(j): gunV = GunSutunSayisi(dd)
           ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow, col + gunV - 1)).Merge
           ws.Cells(baseRow, col).Value = GunKisa(dd)
           ws.Cells(baseRow, col).HorizontalAlignment = xlCenter
           ws.Cells(baseRow, col).Font.Size = 7: ws.Cells(baseRow, col).Font.Bold = True
           ws.Range(ws.Cells(baseRow + 1, col), ws.Cells(baseRow + 1, col + gunV - 1)).Merge
           ws.Cells(baseRow + 1, col).Value = Day(dd)
           ws.Cells(baseRow + 1, col).HorizontalAlignment = xlCenter
           ws.Cells(baseRow + 1, col).Font.Size = 8: ws.Cells(baseRow + 1, col).Font.Bold = True
           aktV = AktifVardiya(dd)
           For vv = 0 To gunV - 1
               If vv < aktV Then ws.Cells(baseRow + 2, col + vv).Value = "S" & (vv + 1)
               ws.Cells(baseRow + 2, col + vv).HorizontalAlignment = xlCenter
               ws.Cells(baseRow + 2, col + vv).Font.Size = 7
               ws.Columns(col + vv).ColumnWidth = 4
           Next vv
           If TatilMi(dd) Then
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + gunV - 1)).Interior.Color = RGB(215, 215, 215)
               If Weekday(dd, vbMonday) = 7 Then ws.Cells(baseRow, col).Font.Color = RGB(180, 0, 0)
           ElseIf ResmiTatilVardiya(dd) > 0 Then
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 1, col + gunV - 1)).Interior.Color = RGB(255, 230, 200)
           End If
       Next j
 
       lastCol = colMap(gunSay) - 1
       ws.Range(ws.Cells(baseRow, C_VERI), ws.Cells(baseRow + 2, lastCol)).Borders.LineStyle = xlContinuous
       ws.Range(ws.Cells(baseRow, C_VERI), ws.Cells(baseRow + 2, lastCol)).Borders.Weight = xlThin
       ws.Range(ws.Cells(baseRow, C_VERI), ws.Cells(baseRow + 2, lastCol)).Borders.Color = RGB(150, 150, 150)
       ws.Range(ws.Cells(baseRow + 3, C_VERI), ws.Cells(baseRow + 2 + DATA_SATIR, lastCol)).Borders.LineStyle = xlContinuous
       ws.Range(ws.Cells(baseRow + 3, C_VERI), ws.Cells(baseRow + 2 + DATA_SATIR, lastCol)).Borders.Weight = xlHairline
       ws.Range(ws.Cells(baseRow + 3, C_VERI), ws.Cells(baseRow + 2 + DATA_SATIR, lastCol)).Borders.Color = RGB(200, 200, 200)
       ws.Rows(baseRow).RowHeight = 14: ws.Rows(baseRow + 1).RowHeight = 16: ws.Rows(baseRow + 2).RowHeight = 12
       For rr = 3 To 2 + DATA_SATIR: ws.Rows(baseRow + rr).RowHeight = 16: Next rr
 
       ' Her ucak icin cizim
       For ui = 0 To ucakSayisi - 1
           renk = UcakRenk(ui)
           Dim c1Sat As Long, winSat As Long, mateSat As Long
 
           ' COJI1 hat satirlari: 3, 4
           c1Sat = baseRow + 2 + ucC1Hat(ui)  ' Hat1=satir3, Hat2=satir4
 
           ' WINDSHIELD hat satirlari: 3..7 (COJI2 hat 1..5)
           winSat = baseRow + 2 + 2 + ucWinHat(ui)  ' Hat1=satir5, ...Hat5=satir9
 
           ' MATE hat satirlari: 8..12 (COJI2 hat 1..5)
           mateSat = baseRow + 2 + 7 + ucMateHat(ui) ' Hat1=satir10, ...Hat5=satir14
 
           ' Durus (siyah) - COJI1 hattinda
           If ucDurus(ui) > 0 Then
               Call CizDurus(ws, c1Sat, ucDurusBasT(ui), ucDurusBasV(ui), ucDurusBitT(ui), ucDurusBitV(ui), ayBas, aySon, colMap)
           End If
 
           ' COJI1
           Call CizVardiyalar(ws, c1Sat, ucC1BasT(ui), ucC1BasV(ui), ucC1BitT(ui), ucC1BitV(ui), ucNo(ui), renk, ayBas, aySon, colMap)
 
           ' WINDSHIELD
           Call CizVardiyalar(ws, winSat, ucWinBasT(ui), ucWinBasV(ui), ucWinBitT(ui), ucWinBitV(ui), ucNo(ui), renk, ayBas, aySon, colMap)
 
           ' MATE
           Call CizVardiyalar(ws, mateSat, ucMateBasT(ui), ucMateBasV(ui), ucMateBitT(ui), ucMateBitV(ui), ucNo(ui), renk, ayBas, aySon, colMap)
 
           ' OUT OF (satir 15 = baseRow+2+13)
           Call CizVardiyalar(ws, baseRow + 15, ucOutBasT(ui), ucOutBasV(ui), ucOutBitT(ui), ucOutBitV(ui), ucNo(ui), renk, ayBas, aySon, colMap)
 
           ' LAY OFF (satir 16)
           Call CizVardiyalar(ws, baseRow + 16, ucLayBasT(ui), ucLayBasV(ui), ucLayBitT(ui), ucLayBitV(ui), ucNo(ui), renk, ayBas, aySon, colMap)
 
           ' BOYA (satir 17)
           Call CizVardiyalar(ws, baseRow + 17, ucBoyaBasT(ui), ucBoyaBasV(ui), ucBoyaBitT(ui), ucBoyaBitV(ui), ucNo(ui), renk, ayBas, aySon, colMap)
 
           ' SEALANT (satir 18)
           Call CizVardiyalar(ws, baseRow + 18, ucSealBasT(ui), ucSealBasV(ui), ucSealBitT(ui), ucSealBitV(ui), ucNo(ui), renk, ayBas, aySon, colMap)
 
           ' FINAL (satir 19)
           Call CizVardiyalar(ws, baseRow + 19, ucFinalBasT(ui), ucFinalBasV(ui), ucFinalBitT(ui), ucFinalBitV(ui), ucNo(ui), renk, ayBas, aySon, colMap)
       Next ui
   Next mm
 
   ws.Activate: ws.Cells(1, C_VERI).Select: ActiveWindow.FreezePanes = True: ws.Cells(1, 1).Select
End Sub
 
