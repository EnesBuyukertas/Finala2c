Sub GuncelleVeCiz( _
   ucNo() As Long, ucDurus() As Integer, _
   ucCoji1Sure() As Integer, ucWindSure() As Integer, ucMateSure() As Integer, _
   ucOutSure() As Integer, ucLaySure() As Integer, ucBoyaSure() As Integer, _
   ucSealSure() As Integer, ucFinalSure() As Integer, _
   ucakSayisi As Long, aySayisi As Integer)
 
   ' Pin tarihlerini PlanDetay'dan oku (varsa), yoksa sifir kullan
   Dim ucPinT() As Double
   ReDim ucPinT(0 To ucakSayisi - 1, 0 To 7)
   Dim wsP2 As Worksheet
   Dim jp As Long, admp As Integer
   On Error Resume Next
   Set wsP2 = ThisWorkbook.Sheets("PlanDetay")
   On Error GoTo 0
   If Not wsP2 Is Nothing Then
       For jp = 0 To ucakSayisi - 1
           For admp = 0 To 7
               Dim pv2 As Variant: pv2 = wsP2.Cells(jp + 2, 30 + admp).Value
               If IsNumeric(pv2) Then
                   If CDbl(pv2) > 0 Then ucPinT(jp, admp) = CDbl(pv2)
               End If
           Next admp
       Next jp
   End If
 
   Call GuncelleVeCizPin(ucNo, ucDurus, ucCoji1Sure, ucWindSure, ucMateSure, ucOutSure, ucLaySure, ucBoyaSure, ucSealSure, ucFinalSure, ucakSayisi, aySayisi, ucPinT)
End Sub
 
' ====================================================
' MAKRO 1: URETIM PLANI OLUSTUR
' ====================================================
Sub UretimPlaniOlustur()
   On Error GoTo Hata
   Application.ScreenUpdating = False
   Call TatilleriOlustur
 
   Dim ilkUcak As Long, ucakSayisi As Long, aySayisi As Integer
 
