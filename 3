Option Explicit
 
' ====================================================
' SABITLER
' ====================================================
Const COJI1_SURE     As Integer = 13
Const WINDSHIELD_SURE As Integer = 11
Const MATE_SURE      As Integer = 15
Const OUTOF_SURE     As Integer = 8
Const LAYOFF_SURE    As Integer = 2
Const BOYA_SURE      As Integer = 6
Const SEALANT_SURE   As Integer = 3
Const FINAL_SURE     As Integer = 4
 
Const COJI1_HAT      As Integer = 2
Const COJI2_HAT      As Integer = 5   ' Windshield + Mate icin ortak
 
Const C_AYADI  As Integer = 1
Const C_LABEL  As Integer = 2
Const C_VERI   As Integer = 3
 
' ====================================================
' GLOBAL DEGISKENLER
' ====================================================
Dim gNormalVardiya As Integer
Dim gTatilTarihBas() As Date
Dim gTatilTarihBit() As Date
Dim gTatilCalis()   As Boolean
Dim gTatilVardiya() As Integer
Dim gTatilSayisi    As Integer
 
' ====================================================
' TATIL TANIMLARI (2026 Turkiye)
' ====================================================
Sub TatilleriOlustur()
   gTatilSayisi = 8
   ReDim gTatilTarihBas(0 To gTatilSayisi - 1)
   ReDim gTatilTarihBit(0 To gTatilSayisi - 1)
   ReDim gTatilCalis(0 To gTatilSayisi - 1)
   ReDim gTatilVardiya(0 To gTatilSayisi - 1)
   gTatilTarihBas(0) = DateSerial(2026, 1, 1):  gTatilTarihBit(0) = DateSerial(2026, 1, 1)
   gTatilTarihBas(1) = DateSerial(2026, 3, 20): gTatilTarihBit(1) = DateSerial(2026, 3, 22)
   gTatilTarihBas(2) = DateSerial(2026, 4, 23): gTatilTarihBit(2) = DateSerial(2026, 4, 23)
   gTatilTarihBas(3) = DateSerial(2026, 5, 1):  gTatilTarihBit(3) = DateSerial(2026, 5, 1)
   gTatilTarihBas(4) = DateSerial(2026, 5, 19): gTatilTarihBit(4) = DateSerial(2026, 5, 19)
   gTatilTarihBas(5) = DateSerial(2026, 5, 26): gTatilTarihBit(5) = DateSerial(2026, 5, 30)
   gTatilTarihBas(6) = DateSerial(2026, 7, 15): gTatilTarihBit(6) = DateSerial(2026, 7, 15)
   gTatilTarihBas(7) = DateSerial(2026, 8, 30): gTatilTarihBit(7) = DateSerial(2026, 8, 30)
End Sub
 
