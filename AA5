   c2Str = InputBox("COJI 2 baslangic tarihi ve saati:" & vbCrLf & "(Ornek: 01.04.2026 07:00)", "Plan Olustur", "01.04.2026 07:00")
   Dim c2Tarih As Date: c2Tarih = CDate(Split(c2Str, " ")(0))
   Dim c2SaatPrc() As String: c2SaatPrc = Split(Split(c2Str, " ")(1), ":")
   c2BasSaat = CDbl(c2SaatPrc(0)) + CDbl(c2SaatPrc(1)) / 60#
 
   ' En erken tarih = plan baslangici
   If c1Tarih <= c2Tarih Then basTarih = c1Tarih Else basTarih = c2Tarih
   c1BasGun = CLng(c1Tarih - basTarih)
   c2BasGun = CLng(c2Tarih - basTarih)
 
   Dim ayCount As Integer
   ayCount = CInt(InputBox("Kac ay planlanacak:", "Plan Olustur", "3"))
   gunSayisi = ayCount * 31
End Sub
 
' ====================================================
' GORSEL OLUSTUR
' ====================================================
Sub GorselOlustur(plan() As Variant, ucakSayisi As Long, ilkUcak As Long, _
                 basTarih As Date, gunSayisi As Long)
 
   ' Renk paleti
   Dim renkler(0 To 19) As String
   renkler(0) = "FFD700": renkler(1) = "87CEEB": renkler(2) = "90EE90"
   renkler(3) = "FFB6C1": renkler(4) = "DDA0DD": renkler(5) = "F0E68C"
   renkler(6) = "98FB98": renkler(7) = "87CEFA": renkler(8) = "FFA07A"
   renkler(9) = "20B2AA": renkler(10) = "FF6347": renkler(11) = "4169E1"
   renkler(12) = "32CD32": renkler(13) = "FF69B4": renkler(14) = "9370DB"
   renkler(15) = "00CED1": renkler(16) = "FF8C00": renkler(17) = "8B4513"
   renkler(18) = "2E8B57": renkler(19) = "DC143C"
 
   ' Sayfayi olustur
   Dim ws As Worksheet
   Application.DisplayAlerts = False
   On Error Resume Next
   ThisWorkbook.Sheets("GanttPlan").Delete
   On Error GoTo 0
   Application.DisplayAlerts = True
   Dim yeniWs As Worksheet
   Set yeniWs = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   yeniWs.Name = "GanttPlan"
   Set ws = yeniWs
   ws.Cells.Font.Name = "Calibri"
 
   Const IST_COL As Integer = 1
   Const OP_COL As Integer = 2
   Const VERI_COL As Integer = 3
   Const BASLIK_SATIR As Integer = 3
 
   ' Saatler
   Dim saatler() As Integer
   Dim saat_sayisi As Integer
   If gNormalVardiya = 1 Then
       saat_sayisi = 8
       ReDim saatler(0 To saat_sayisi - 1)
       Dim ss As Integer
       For ss = 0 To saat_sayisi - 1: saatler(ss) = 7 + ss: Next ss
   ElseIf gNormalVardiya = 2 Then
       saat_sayisi = 16
       ReDim saatler(0 To saat_sayisi - 1)
       For ss = 0 To saat_sayisi - 1: saatler(ss) = 7 + ss: Next ss
   Else
       saat_sayisi = 24
       ReDim saatler(0 To saat_sayisi - 1)
       For ss = 0 To 15: saatler(ss) = 7 + ss: Next ss
       For ss = 0 To 7: saatler(16 + ss) = 23 + ss: Next ss  ' 23,24...
   End If
 
   Dim gunAdlari(0 To 6) As String
   gunAdlari(0) = "Pzt": gunAdlari(1) = "Sal": gunAdlari(2) = "Car"
   gunAdlari(3) = "Per": gunAdlari(4) = "Cum": gunAdlari(5) = "Cmt": gunAdlari(6) = "Paz"
 
   ' Baslik satirlari
   Dim gun_idx As Long, saat_val As Integer
   For gun_idx = 0 To gunSayisi - 1
       Dim dd As Date: dd = basTarih + gun_idx
       Dim gun_adi As String: gun_adi = gunAdlari(Weekday(dd, vbMonday) - 1)
       Dim is_tatil As Boolean: is_tatil = TatilMiGun(gun_idx, basTarih)
       Dim bas_col As Long: bas_col = VERI_COL + gun_idx * saat_sayisi
       Dim bit_col As Long: bit_col = bas_col + saat_sayisi - 1
 
       ' Gun baslik
       ws.Range(ws.Cells(1, bas_col), ws.Cells(1, bit_col)).Merge
       With ws.Cells(1, bas_col)
           .Value = gun_adi & " " & Format(dd, "DD.MM")
           .Font.Bold = True: .Font.Size = 8: .Font.Color = RGB(255, 255, 255)
           If is_tatil Then
               .Interior.Color = RGB(192, 0, 0)
           Else
               .Interior.Color = RGB(31, 78, 121)
           End If
           .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
       End With
 
       ' Vardiya baslikları
       Dim v As Integer
       For v = 1 To gNormalVardiya
           Dim vbas As Double: vbas = VardiyaBas(v)
           Dim vbit As Double: vbit = VardiyaBit(v)
           Dim v_bas_col As Long: v_bas_col = -1
           Dim v_bit_col As Long: v_bit_col = -1
           Dim si As Integer
           For si = 0 To saat_sayisi - 1
               If saatler(si) >= vbas And saatler(si) < vbit Then
                   If v_bas_col = -1 Then v_bas_col = bas_col + si
                   v_bit_col = bas_col + si
               End If
           Next si
           If v_bas_col > 0 Then
               ws.Range(ws.Cells(2, v_bas_col), ws.Cells(2, v_bit_col)).Merge
               With ws.Cells(2, v_bas_col)
                   Dim vrenk As String
                   Select Case v
                       Case 1: vrenk = "2E75B6"
                       Case 2: vrenk = "375623"
                       Case 3: vrenk = "7030A0"
                   End Select
                   .Value = "S" & v & " (" & Format(vbas, "00") & ":00-" & Format(IIf(vbit >= 24, vbit - 24, vbit), "00") & ":00)"
                   .Font.Bold = True: .Font.Size = 7: .Font.Color = RGB(255, 255, 255)
                   .Interior.Color = RGB(CLng("&H" & Mid(vrenk, 1, 2)), CLng("&H" & Mid(vrenk, 3, 2)), CLng("&H" & Mid(vrenk, 5, 2)))
                   .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
               End With
           End If
       Next v
 
       ' Saat baslikları
       For si = 0 To saat_sayisi - 1
           Dim scol As Long: scol = bas_col + si
           With ws.Cells(3, scol)
               Dim sh As Integer: sh = saatler(si)
               If sh >= 24 Then sh = sh - 24
               .Value = Format(sh, "00")
               .Font.Size = 6: .Font.Bold = True
               If is_tatil Then
                   .Interior.Color = RGB(255, 200, 200)
               Else
                   .Interior.Color = RGB(214, 228, 240)
               End If
               .HorizontalAlignment = xlCenter
               .Borders.LineStyle = xlContinuous
               .Borders.Weight = xlHairline
               .Borders.Color = RGB(180, 180, 180)
           End With
           ws.Columns(scol).ColumnWidth = 3.8
       Next si
   Next gun_idx
 
   ' Sol sutunlar
   ws.Columns(IST_COL).ColumnWidth = 24
   ws.Columns(OP_COL).ColumnWidth = 40
   ws.Cells(1, IST_COL).Value = "İSTASYON / HAT"
   ws.Cells(1, OP_COL).Value = "OPERASYON"
   Dim r As Integer, c As Integer
   For r = 1 To 3
       For c = 1 To 2
           With ws.Cells(r, c)
               .Font.Bold = True: .Font.Size = 9: .Font.Color = RGB(255, 255, 255)
               .Interior.Color = RGB(31, 78, 121)
               .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
           End With
       Next c
   Next r
   ws.Range(ws.Cells(1, IST_COL), ws.Cells(3, IST_COL)).Merge
   ws.Range(ws.Cells(1, OP_COL), ws.Cells(3, OP_COL)).Merge
 
   ' Istasyon ve operasyon satirlari
   Dim mevcut_satir As Long: mevcut_satir = BASLIK_SATIR + 1
   
   ' Istasyon bilgileri
   Dim ist_adlari(0 To 7) As String
   ist_adlari(0) = "COJI 1": ist_adlari(1) = "COJI 2 WINDSHIELD"
   ist_adlari(2) = "COJI 2 MATE": ist_adlari(3) = "OUT OF COJI"
   ist_adlari(4) = "LAY OFF": ist_adlari(5) = "BOYA"
   ist_adlari(6) = "SEALANT": ist_adlari(7) = "FINAL"
   
   Dim ist_hatlar(0 To 7) As Integer
