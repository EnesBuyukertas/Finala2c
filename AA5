       gTatilGunler(tt) = tatilTarihler(tt)
       Dim cvp As VbMsgBoxResult
       cvp = MsgBox(tatilAdlari(tt) & vbCrLf & vbCrLf & "Bu tatilde calisma yapilacak mi?", vbYesNo + vbQuestion, "Tatil Ayarlari")
       gTatilCalisiyorMu(tt) = (cvp = vbYes)
