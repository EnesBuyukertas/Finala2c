           ' Operasyon satirlari
           For op_idx = 0 To op_sayilari(ist_idx) - 1
               Dim key As String: key = CStr(ist_idx * 1000 + hat_no * 10 + op_idx)
               satir_harita(key) = mevcut_satir
               With ws.Cells(mevcut_satir, IST_COL)
                   .Interior.Color = RGB(242, 242, 242)
               End With
               With ws.Cells(mevcut_satir, OP_COL)
                   .Value = "  " & op_kodlar(ist_idx, op_idx)
                   .Font.Size = 7: .Interior.Color = RGB(242, 242, 242)
                   .VerticalAlignment = xlCenter
               End With
               ws.Rows(mevcut_satir).RowHeight = 15
               mevcut_satir = mevcut_satir + 1
           Next op_idx
       Next hat_no
   Next ist_idx
 
   ' Plan verilerini ciz
   Dim ui As Long
   For ui = 0 To UBound(plan, 1)
       Dim ucak_no As Long: ucak_no = ilkUcak + ui
       Dim renk As String: renk = renkler(ui Mod 20)
       Dim r_val As Long: r_val = CLng("&H" & Left(renk, 2))
       Dim g_val As Long: g_val = CLng("&H" & Mid(renk, 3, 2))
       Dim b_val As Long: b_val = CLng("&H" & Right(renk, 2))
 
       Dim kayit_idx As Long
       For kayit_idx = 0 To UBound(plan, 2)
           If plan(ui, kayit_idx, 0) = -1 Then GoTo sonraki_kayit
 
           Dim p_ist As Integer: p_ist = CInt(plan(ui, kayit_idx, 0))
           Dim p_hat As Integer: p_hat = CInt(plan(ui, kayit_idx, 1))
           Dim p_op As Integer: p_op = CInt(plan(ui, kayit_idx, 2))
           Dim p_bas_gun As Long: p_bas_gun = CLng(plan(ui, kayit_idx, 3))
           Dim p_bas_saat As Double: p_bas_saat = CDbl(plan(ui, kayit_idx, 4))
           Dim p_bit_gun As Long: p_bit_gun = CLng(plan(ui, kayit_idx, 5))
           Dim p_bit_saat As Double: p_bit_saat = CDbl(plan(ui, kayit_idx, 6))
 
           Dim s_key As String: s_key = CStr(p_ist * 1000 + p_hat * 10 + p_op)
           If Not satir_harita.Exists(s_key) Then GoTo sonraki_kayit
           Dim s_no As Long: s_no = CLng(satir_harita(s_key))
 
           ' Saatleri boya
           Dim cg As Long: cg = p_bas_gun
           Dim cs As Double: cs = Int(p_bas_saat)
           Dim ilk_hucre As Boolean: ilk_hucre = True
 
           Do While (cg < p_bit_gun) Or (cg = p_bit_gun And cs < Int(p_bit_saat))
               If cg >= gunSayisi Then Exit Do
 
               ' Bu saati saatler dizisinde bul
               Dim found_si As Integer: found_si = -1
               For si = 0 To saat_sayisi - 1
                   If saatler(si) = cs Then found_si = si: Exit For
               Next si
 
               If found_si >= 0 Then
                   Dim s_col As Long: s_col = VERI_COL + cg * saat_sayisi + found_si
                   With ws.Cells(s_no, s_col)
                       .Interior.Color = RGB(r_val, g_val, b_val)
                       .Borders.LineStyle = xlContinuous
                       .Borders.Weight = xlHairline
                       .Borders.Color = RGB(150, 150, 150)
                       If ilk_hucre Then
                           .Value = ucak_no
                           .Font.Size = 6: .Font.Bold = True
                           .HorizontalAlignment = xlLeft: .VerticalAlignment = xlCenter
                           ilk_hucre = False
                       End If
                   End With
               End If
 
               cs = cs + 1
               If cs >= 24 Then cs = 7: cg = cg + 1
               ' Vardiya disi kontrolu
               If gNormalVardiya < 3 And cs >= 23 Then cs = 7: cg = cg + 1
               If gNormalVardiya < 2 And cs >= 15 Then cs = 7: cg = cg + 1
           Loop
sonraki_kayit:
       Next kayit_idx
   Next ui
 
   ws.Activate
   ActiveWindow.FreezePanes = False
   ws.Cells(4, VERI_COL).Select
   ActiveWindow.FreezePanes = True
   ws.Cells(1, 1).Select
 
   ws.Rows(1).RowHeight = 20
   ws.Rows(2).RowHeight = 16
   ws.Rows(3).RowHeight = 14
End Sub
 
' ====================================================
' MAKRO 1: PLAN OLUSTUR
' ====================================================
Sub PlanOlustur()
   On Error GoTo Hata
   Application.ScreenUpdating = False
 
   Dim ilkUcak As Long, ucakSayisi As Long
   Dim c1BasGun As Long, c2BasGun As Long
   Dim c1BasSaat As Double, c2BasSaat As Double
   Dim basTarih As Date, gunSayisi As Long
 
   Call AyarlariOku(ilkUcak, ucakSayisi, c1BasGun, c1BasSaat, c2BasGun, c2BasSaat, basTarih, gunSayisi)
 
   ' Op sureleri - her istasyon icin dizi
   Dim c1Sureler(0 To 5) As Double
   c1Sureler(0) = C1_OP1_SURE: c1Sureler(1) = C1_OP2_SURE: c1Sureler(2) = C1_OP3_SURE
   c1Sureler(3) = C1_OP4_SURE: c1Sureler(4) = C1_OP5_SURE: c1Sureler(5) = C1_OP6_SURE
 
   Dim winSureler(0 To 1) As Double
   winSureler(0) = WIN_OP1_SURE: winSureler(1) = WIN_OP2_SURE
 
   Dim mateSureler(0 To 2) As Double
   mateSureler(0) = MATE_OP1_SURE: mateSureler(1) = MATE_OP2_SURE: mateSureler(2) = MATE_OP3_SURE
 
   Dim oocSureler(0 To 4) As Double
   oocSureler(0) = OOC_OP1_SURE: oocSureler(1) = OOC_OP2_SURE: oocSureler(2) = OOC_OP3_SURE
   oocSureler(3) = OOC_OP4_SURE: oocSureler(4) = OOC_OP5_SURE
 
   Dim laySureler(0 To 5) As Double
   laySureler(0) = LAY_OP1_SURE: laySureler(1) = LAY_OP2_SURE: laySureler(2) = LAY_OP3_SURE
   laySureler(3) = LAY_OP4_SURE: laySureler(4) = LAY_OP5_SURE: laySureler(5) = LAY_OP6_SURE
 
   Dim boyaSureler(0 To 1) As Double
   boyaSureler(0) = BOYA_OP1_SURE: boyaSureler(1) = BOYA_OP2_SURE
 
   ' Hat kuyruk pozisyonlari: (gun, saat)
   Dim c1HatGun(1 To COJI1_HAT) As Long, c1HatSaat(1 To COJI1_HAT) As Double
   Dim c2HatGun(1 To COJI2_HAT) As Long, c2HatSaat(1 To COJI2_HAT) As Double
   Dim tekHatGun(3 To 7) As Long, tekHatSaat(3 To 7) As Double
 
   Dim h As Integer
   For h = 1 To COJI1_HAT: c1HatGun(h) = c1BasGun: c1HatSaat(h) = c1BasSaat: Next h
   For h = 1 To COJI2_HAT: c2HatGun(h) = c2BasGun: c2HatSaat(h) = c2BasSaat: Next h
 
   Dim enErkenGun As Long, enErkenSaat As Double
   If c1BasGun < c2BasGun Or (c1BasGun = c2BasGun And c1BasSaat <= c2BasSaat) Then
       enErkenGun = c1BasGun: enErkenSaat = c1BasSaat
   Else
       enErkenGun = c2BasGun: enErkenSaat = c2BasSaat
   End If
   For h = 3 To 7: tekHatGun(h) = enErkenGun: tekHatSaat(h) = enErkenSaat: Next h
 
   ' Plan dizisi: (ucak_idx, kayit_idx, alan_idx)
   ' alan: 0=ist_idx, 1=hat_no, 2=op_idx, 3=bas_gun, 4=bas_saat, 5=bit_gun, 6=bit_saat
   Dim maks_kayit As Long: maks_kayit = 30  ' Ucak basina max kayit
   Dim plan() As Variant
   ReDim plan(0 To ucakSayisi - 1, 0 To maks_kayit - 1, 0 To 6)
   ' Baslangicta -1 ile doldur (bos kayit isaretcisi)
   Dim pi As Long, pj As Long, pk As Integer
   For pi = 0 To ucakSayisi - 1
       For pj = 0 To maks_kayit - 1
           plan(pi, pj, 0) = -1
       Next pj
   Next pi
 
   Dim ui As Long
   For ui = 0 To ucakSayisi - 1
       Dim kayit_idx As Long: kayit_idx = 0
 
       ' === COJI1 ===
       ' En erken bos hat
       Dim c1H As Integer: c1H = 1
       Dim c1EnDusukGun As Long: c1EnDusukGun = c1HatGun(1)
       Dim c1EnDusukSaat As Double: c1EnDusukSaat = c1HatSaat(1)
       For h = 2 To COJI1_HAT
           If c1HatGun(h) < c1EnDusukGun Or (c1HatGun(h) = c1EnDusukGun And c1HatSaat(h) < c1EnDusukSaat) Then
               c1EnDusukGun = c1HatGun(h): c1EnDusukSaat = c1HatSaat(h): c1H = h
           End If
       Next h
       Dim c1BasG As Long: c1BasG = c1EnDusukGun
       Dim c1BasS As Double: c1BasS = c1EnDusukSaat
       Call IlkUygunZaman(c1BasG, c1BasS, basTarih)
 
       Dim c1SonG As Long: c1SonG = c1BasG
       Dim c1SonS As Double: c1SonS = c1BasS
       Dim op As Integer
       For op = 0 To 5
           Dim og As Long: og = c1SonG: Dim os As Double: os = c1SonS
           Call IlkUygunZaman(og, os, basTarih)
           Dim bg As Long: bg = og: Dim bs As Double: bs = os
           Call SaatEkle(og, os, c1Sureler(op), basTarih)
           plan(ui, kayit_idx, 0) = 0: plan(ui, kayit_idx, 1) = c1H
           plan(ui, kayit_idx, 2) = op: plan(ui, kayit_idx, 3) = bg
           plan(ui, kayit_idx, 4) = bs: plan(ui, kayit_idx, 5) = og
           plan(ui, kayit_idx, 6) = os
           kayit_idx = kayit_idx + 1
           c1SonG = og: c1SonS = os
       Next op
       c1HatGun(c1H) = c1SonG: c1HatSaat(c1H) = c1SonS
       Dim c1BitG As Long: c1BitG = c1SonG
       Dim c1BitS As Double: c1BitS = c1SonS
 
       ' === WINDSHIELD ===
       Dim c2H_win As Integer: c2H_win = 1
       Dim c2EnDG As Long: c2EnDG = c2HatGun(1): Dim c2EnDS As Double: c2EnDS = c2HatSaat(1)
       For h = 2 To COJI2_HAT
           If c2HatGun(h) < c2EnDG Or (c2HatGun(h) = c2EnDG And c2HatSaat(h) < c2EnDS) Then
               c2EnDG = c2HatGun(h): c2EnDS = c2HatSaat(h): c2H_win = h
           End If
       Next h
       Dim winBasG As Long: Dim winBasS As Double
       If c2EnDG > c1BasG Or (c2EnDG = c1BasG And c2EnDS > c1BasS) Then
           winBasG = c2EnDG: winBasS = c2EnDS
       Else
           winBasG = c1BasG: winBasS = c1BasS
       End If
       Call IlkUygunZaman(winBasG, winBasS, basTarih)
       Dim winSonG As Long: winSonG = winBasG: Dim winSonS As Double: winSonS = winBasS
       For op = 0 To 1
           og = winSonG: os = winSonS
           Call IlkUygunZaman(og, os, basTarih)
           bg = og: bs = os
           Call SaatEkle(og, os, winSureler(op), basTarih)
           plan(ui, kayit_idx, 0) = 1: plan(ui, kayit_idx, 1) = c2H_win
           plan(ui, kayit_idx, 2) = op: plan(ui, kayit_idx, 3) = bg
           plan(ui, kayit_idx, 4) = bs: plan(ui, kayit_idx, 5) = og
           plan(ui, kayit_idx, 6) = os
           kayit_idx = kayit_idx + 1
           winSonG = og: winSonS = os
       Next op
       c2HatGun(c2H_win) = winSonG: c2HatSaat(c2H_win) = winSonS
       Dim winBitG As Long: winBitG = winSonG: Dim winBitS As Double: winBitS = winSonS
 
       ' === MATE ===
       Dim c2H_mate As Integer: c2H_mate = 1
       c2EnDG = c2HatGun(1): c2EnDS = c2HatSaat(1)
       For h = 2 To COJI2_HAT
           If c2HatGun(h) < c2EnDG Or (c2HatGun(h) = c2EnDG And c2HatSaat(h) < c2EnDS) Then
               c2EnDG = c2HatGun(h): c2EnDS = c2HatSaat(h): c2H_mate = h
           End If
       Next h
       ' MAX(c1bit, winbit)
       Dim mateReqG As Long: Dim mateReqS As Double
       If c1BitG > winBitG Or (c1BitG = winBitG And c1BitS >= winBitS) Then
           mateReqG = c1BitG: mateReqS = c1BitS
       Else
           mateReqG = winBitG: mateReqS = winBitS
       End If
       Dim mateBasG As Long: Dim mateBasS As Double
       If c2EnDG > mateReqG Or (c2EnDG = mateReqG And c2EnDS > mateReqS) Then
           mateBasG = c2EnDG: mateBasS = c2EnDS
       Else
           mateBasG = mateReqG: mateBasS = mateReqS
       End If
       Call IlkUygunZaman(mateBasG, mateBasS, basTarih)
       Dim mateSonG As Long: mateSonG = mateBasG: Dim mateSonS As Double: mateSonS = mateBasS
       For op = 0 To 2
           og = mateSonG: os = mateSonS
           Call IlkUygunZaman(og, os, basTarih)
           bg = og: bs = os
           Call SaatEkle(og, os, mateSureler(op), basTarih)
           plan(ui, kayit_idx, 0) = 2: plan(ui, kayit_idx, 1) = c2H_mate
           plan(ui, kayit_idx, 2) = op: plan(ui, kayit_idx, 3) = bg
           plan(ui, kayit_idx, 4) = bs: plan(ui, kayit_idx, 5) = og
           plan(ui, kayit_idx, 6) = os
           kayit_idx = kayit_idx + 1
           mateSonG = og: mateSonS = os
       Next op
       c2HatGun(c2H_mate) = mateSonG: c2HatSaat(c2H_mate) = mateSonS
 
       Dim oncekiG As Long: oncekiG = mateSonG
       Dim oncekiS As Double: oncekiS = mateSonS
 
       ' === TEK HATLI ISTASYONLAR ===
       ' 3=OOC, 4=LAY OFF, 5=BOYA, 6=SEALANT, 7=FINAL
       Dim ist_sur(3 To 7, 0 To 5) As Double
       ist_sur(3, 0) = OOC_OP1_SURE: ist_sur(3, 1) = OOC_OP2_SURE: ist_sur(3, 2) = OOC_OP3_SURE
       ist_sur(3, 3) = OOC_OP4_SURE: ist_sur(3, 4) = OOC_OP5_SURE
       ist_sur(4, 0) = LAY_OP1_SURE: ist_sur(4, 1) = LAY_OP2_SURE: ist_sur(4, 2) = LAY_OP3_SURE
       ist_sur(4, 3) = LAY_OP4_SURE: ist_sur(4, 4) = LAY_OP5_SURE: ist_sur(4, 5) = LAY_OP6_SURE
       ist_sur(5, 0) = BOYA_OP1_SURE: ist_sur(5, 1) = BOYA_OP2_SURE
       ist_sur(6, 0) = SEAL_OP1_SURE
       ist_sur(7, 0) = FINAL_OP1_SURE
 
       Dim ist_op_say(3 To 7) As Integer
       ist_op_say(3) = 5: ist_op_say(4) = 6: ist_op_say(5) = 2
       ist_op_say(6) = 1: ist_op_say(7) = 1
 
       Dim ist_idx As Integer
       For ist_idx = 3 To 7
           Dim hatG As Long: hatG = tekHatGun(ist_idx)
           Dim hatS As Double: hatS = tekHatSaat(ist_idx)
           Dim istBasG As Long: Dim istBasS As Double
           If hatG > oncekiG Or (hatG = oncekiG And hatS > oncekiS) Then
               istBasG = hatG: istBasS = hatS
           Else
               istBasG = oncekiG: istBasS = oncekiS
           End If
           Call IlkUygunZaman(istBasG, istBasS, basTarih)
           Dim istSonG As Long: istSonG = istBasG: Dim istSonS As Double: istSonS = istBasS
           For op = 0 To ist_op_say(ist_idx) - 1
               og = istSonG: os = istSonS
               Call IlkUygunZaman(og, os, basTarih)
               bg = og: bs = os
               Call SaatEkle(og, os, ist_sur(ist_idx, op), basTarih)
               plan(ui, kayit_idx, 0) = ist_idx: plan(ui, kayit_idx, 1) = 1
               plan(ui, kayit_idx, 2) = op: plan(ui, kayit_idx, 3) = bg
               plan(ui, kayit_idx, 4) = bs: plan(ui, kayit_idx, 5) = og
               plan(ui, kayit_idx, 6) = os
               kayit_idx = kayit_idx + 1
               istSonG = og: istSonS = os
           Next op
           tekHatGun(ist_idx) = istSonG: tekHatSaat(ist_idx) = istSonS
           oncekiG = istSonG: oncekiS = istSonS
       Next ist_idx
   Next ui
 
   ' Gorsel olustur
   Call GorselOlustur(plan, ucakSayisi, ilkUcak, basTarih, gunSayisi)
 
   Application.ScreenUpdating = True
   MsgBox ucakSayisi & " uçak planlandı!", vbInformation, "Tamam"
   Exit Sub
Hata:
   Application.ScreenUpdating = True
   MsgBox "Hata: " & Err.Description, vbCritical
End Sub
 
