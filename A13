   tatilAdlari(0) = "1 Ocak 2026 - Yilbasi"
   tatilAdlari(1) = "Ramazan Bayrami 2026 (20-22 Mart)"
   tatilAdlari(2) = "23 Nisan 2026 - Ulusal Egemenlik"
   tatilAdlari(3) = "1 Mayis 2026 - Isci Bayrami"
   tatilAdlari(4) = "19 Mayis 2026 - Genclik Bayrami"
   tatilAdlari(5) = "Kurban Bayrami 2026 (26-30 Mayis)"
   tatilAdlari(6) = "15 Temmuz 2026 - Demokrasi Gunu"
   tatilAdlari(7) = "30 Agustos 2026 - Zafer Bayrami"
 
   Dim tt As Integer
   For tt = 0 To 7
       Dim cvp As VbMsgBoxResult
       cvp = MsgBox(tatilAdlari(tt) & vbCrLf & vbCrLf & "Bu tatilde calisma yapilacak mi?", vbYesNo + vbQuestion, "Tatil Ayarlari")
       If cvp = vbYes Then
           ws.Cells(13 + tt, 2).Value = "EVET"
           ws.Cells(13 + tt, 2).Font.Color = RGB(0, 128, 0)
       Else
           ws.Cells(13 + tt, 2).Value = "HAYIR"
           ws.Cells(13 + tt, 2).Font.Color = RGB(192, 0, 0)
