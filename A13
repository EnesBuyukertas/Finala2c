' ====================================================
' MAKRO 3: HAFTALIK PLAN
' GanttPlan sayfasindan veri okuyarak haftalik ozet olusturur
' ====================================================
 
' Global plan verisi - PlanOlustur tarafindan doldurulur
Sub HaftalikPlan()
   On Error GoTo Hata
 
   ' Plan verisi hazir mi?
   If gPlanUcakSayisi = 0 Then
       MsgBox "Once PlanOlustur makrosunu calistirin!", vbExclamation
       Exit Sub
   End If
 
   ' Tarih araligini sor
   Dim basStr As String
   basStr = InputBox("Baslangic tarihi (GG.AA.YYYY):", "Haftalik Plan", Format(Date, "DD.MM.YYYY"))
   If basStr = "" Then Exit Sub
   Dim bitStr As String
   bitStr = InputBox("Bitis tarihi (GG.AA.YYYY):", "Haftalik Plan", Format(Date + 6, "DD.MM.YYYY"))
   If bitStr = "" Then Exit Sub
 
   Dim basTarihH As Date: basTarihH = CDate(basStr)
   Dim bitTarihH As Date: bitTarihH = CDate(bitStr)
   Dim gunSayisiH As Long: gunSayisiH = CLng(bitTarihH - basTarihH) + 1
 
   Application.ScreenUpdating = False
 
   ' Sheet olustur
   Dim wsH As Worksheet
   Application.DisplayAlerts = False
   On Error Resume Next: ThisWorkbook.Sheets("HaftalikPlan").Delete: On Error GoTo Hata
   Application.DisplayAlerts = True
   Set wsH = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   wsH.Name = "HaftalikPlan": wsH.Cells.Font.Name = "Calibri"
 
   ' Tanimlar
   Dim ist_adlari(0 To 7) As String
   ist_adlari(0) = "COJI 1": ist_adlari(1) = "COJI 2 WINDSHIELD"
   ist_adlari(2) = "COJI 2 MATE": ist_adlari(3) = "OUT OF COJI"
   ist_adlari(4) = "LAY OFF": ist_adlari(5) = "BOYA"
   ist_adlari(6) = "SEALANT": ist_adlari(7) = "FINAL"
 
   Dim ist_hatlar(0 To 7) As Integer
   ist_hatlar(0) = 2: ist_hatlar(1) = 5: ist_hatlar(2) = 5
   ist_hatlar(3) = 1: ist_hatlar(4) = 1: ist_hatlar(5) = 1
   ist_hatlar(6) = 1: ist_hatlar(7) = 1
 
   Dim op_kodlarH(0 To 7, 0 To 5) As String
   op_kodlarH(0, 0) = "TOPSKIN-0100": op_kodlarH(0, 1) = "TOPSKIN-0150": op_kodlarH(0, 2) = "TOPSKIN-0200"
   op_kodlarH(0, 3) = "TOPSKIN-0250": op_kodlarH(0, 4) = "TOPSKIN-0300": op_kodlarH(0, 5) = "TOPSKIN-0350"
   op_kodlarH(1, 0) = "CANOPY-0070": op_kodlarH(1, 1) = "CANOPY-0075"
   op_kodlarH(2, 0) = "CANOPY-0080": op_kodlarH(2, 1) = "CANOPY-0084": op_kodlarH(2, 2) = "CANOPY-0086"
   op_kodlarH(3, 0) = "CANOPY-0078": op_kodlarH(3, 1) = "CANOPY-0087": op_kodlarH(3, 2) = "CANOPY-0090"
   op_kodlarH(3, 3) = "CANOPY-0140": op_kodlarH(3, 4) = "CANOPY-0091"
   op_kodlarH(4, 0) = "CANOPY-0097": op_kodlarH(4, 1) = "CANOPY-0092": op_kodlarH(4, 2) = "CANOPY-0111"
   op_kodlarH(4, 3) = "CANOPY-0150": op_kodlarH(4, 4) = "CANOPY-1041": op_kodlarH(4, 5) = "CANOPY-1072"
   op_kodlarH(5, 0) = "CANOPY-0120": op_kodlarH(5, 1) = "CANOPY-0125"
   op_kodlarH(6, 0) = "CANOPY-0130"
   op_kodlarH(7, 0) = "FINAL"
 
   Dim op_sayilariH(0 To 7) As Integer
   op_sayilariH(0) = 6: op_sayilariH(1) = 2: op_sayilariH(2) = 3
   op_sayilariH(3) = 5: op_sayilariH(4) = 6: op_sayilariH(5) = 2
   op_sayilariH(6) = 1: op_sayilariH(7) = 1
 
   Dim renklerH(0 To 19) As String
   renklerH(0) = "FFD700": renklerH(1) = "87CEEB": renklerH(2) = "90EE90"
   renklerH(3) = "FFB6C1": renklerH(4) = "DDA0DD": renklerH(5) = "F0E68C"
   renklerH(6) = "98FB98": renklerH(7) = "87CEFA": renklerH(8) = "FFA07A"
   renklerH(9) = "20B2AA": renklerH(10) = "FF6347": renklerH(11) = "4169E1"
   renklerH(12) = "32CD32": renklerH(13) = "FF69B4": renklerH(14) = "9370DB"
   renklerH(15) = "00CED1": renklerH(16) = "FF8C00": renklerH(17) = "8B4513"
   renklerH(18) = "2E8B57": renklerH(19) = "DC143C"
 
   Dim gunAdlariH(0 To 6) As String
   gunAdlariH(0) = "Pzt": gunAdlariH(1) = "Sal": gunAdlariH(2) = "Car"
   gunAdlariH(3) = "Per": gunAdlariH(4) = "Cum": gunAdlariH(5) = "Cmt": gunAdlariH(6) = "Paz"
 
   ' Baslik
   wsH.Range("A1:Z1").Merge
   With wsH.Cells(1, 1)
       .Value = Format(basTarihH, "DD.MM.YYYY") & " - " & Format(bitTarihH, "DD.MM.YYYY") & " HAFTALIK PLAN"
       .Font.Bold = True: .Font.Size = 13: .Font.Color = RGB(255, 255, 255)
       .Interior.Color = RGB(31, 78, 121)
       .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
   End With
   wsH.Rows(1).RowHeight = 28
 
   ' Sutun yapisi: A=Istasyon, B+= Her gun x vardiya
   Const IST_COL_H As Integer = 1
   Const GUN_BAS_COL_H As Integer = 2
   wsH.Columns(IST_COL_H).ColumnWidth = 24
 
   ' Gun baslikları
   Dim hcol As Long: hcol = GUN_BAS_COL_H
   Dim gun_idx As Long
   For gun_idx = 0 To gunSayisiH - 1
       Dim dd As Date: dd = basTarihH + gun_idx
       Dim gun_adi As String: gun_adi = gunAdlariH(Weekday(dd, vbMonday) - 1)
       Dim is_tatil As Boolean: is_tatil = TatilMiGun(CLng(dd - gPlanBasTarih), gPlanBasTarih)
       Dim v As Integer
       For v = 1 To gNormalVardiya
           Dim vBasH As Double: vBasH = VardiyaBas(v)
           Dim vBitH As Double: vBitH = VardiyaBit(v)
           Dim vBitGH As Double: If vBitH >= 24 Then vBitGH = vBitH - 24 Else vBitGH = vBitH
           With wsH.Cells(2, hcol)
               .Value = gun_adi & " " & Format(dd, "DD.MM") & Chr(10) & "S" & v & " " & Format(vBasH, "00") & ":00-" & Format(vBitGH, "00") & ":00"
               .Font.Bold = True: .Font.Size = 8: .Font.Color = RGB(255, 255, 255)
               If is_tatil Then
                   .Interior.Color = RGB(192, 0, 0)
               Else
                   Select Case v
                       Case 1: .Interior.Color = RGB(31, 78, 121)
                       Case 2: .Interior.Color = RGB(55, 86, 35)
                       Case 3: .Interior.Color = RGB(112, 48, 160)
                   End Select
               End If
               .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter: .WrapText = True
           End With
           wsH.Columns(hcol).ColumnWidth = 22
           hcol = hcol + 1
       Next v
   Next gun_idx
   wsH.Rows(2).RowHeight = 36
 
   ' Istasyon satirlari
   Dim mevcut_satir As Long: mevcut_satir = 3
   Dim ist_idx As Integer, hat_no As Integer
 
   For ist_idx = 0 To 7
       For hat_no = 1 To ist_hatlar(ist_idx)
           Dim hat_label As String
           If ist_hatlar(ist_idx) > 1 Then
               hat_label = ist_adlari(ist_idx) & " - Hat " & hat_no
           Else
               hat_label = ist_adlari(ist_idx)
           End If
 
           With wsH.Cells(mevcut_satir, IST_COL_H)
               .Value = hat_label: .Font.Bold = True: .Font.Size = 9
               .Font.Color = RGB(255, 255, 255): .Interior.Color = RGB(46, 64, 87)
               .VerticalAlignment = xlCenter
               .Borders.LineStyle = xlContinuous: .Borders.Weight = xlThin
           End With
 
           ' Her gun ve vardiya icin plan verisini tara
           Dim col As Long: col = GUN_BAS_COL_H
           For gun_idx = 0 To gunSayisiH - 1
               dd = basTarihH + gun_idx
               Dim gunIdxPlan As Long: gunIdxPlan = CLng(dd - gPlanBasTarih)
               is_tatil = TatilMiGun(gunIdxPlan, gPlanBasTarih)
 
               For v = 1 To gNormalVardiya
                   vBasH = VardiyaBas(v)
                   vBitH = VardiyaBit(v)
 
                   Dim hucreMetin As String: hucreMetin = ""
                   Dim hucreRenk As String: hucreRenk = ""
 
                   If Not is_tatil Then
                       ' Plan verisini tara - bu gun/vardiya/istasyon/hat ile esleseni bul
                       Dim ui As Long
                       For ui = 0 To gPlanUcakSayisi - 1
                           Dim ucakNo As Long: ucakNo = gPlanIlkUcak + ui
                           Dim ki As Long
                           For ki = 0 To 29
                               ' Kayit gecerli mi?
                               If gPlanVerisi(ui, ki, 0) = -1 Then Exit For
 
                               Dim p_ist As Integer: p_ist = CInt(gPlanVerisi(ui, ki, 0))
                               Dim p_hat As Integer: p_hat = CInt(gPlanVerisi(ui, ki, 1))
                               Dim p_op As Integer: p_op = CInt(gPlanVerisi(ui, ki, 2))
                               Dim p_bas_gun As Long: p_bas_gun = CLng(gPlanVerisi(ui, ki, 3))
                               Dim p_bas_saat As Double: p_bas_saat = CDbl(gPlanVerisi(ui, ki, 4))
                               Dim p_bit_gun As Long: p_bit_gun = CLng(gPlanVerisi(ui, ki, 5))
                               Dim p_bit_saat As Double: p_bit_saat = CDbl(gPlanVerisi(ui, ki, 6))
 
                               ' Bu kayit bu istasyon/hat mi?
                               If p_ist <> ist_idx Or p_hat <> hat_no Then GoTo sonraki_kayit_h
 
                               ' Bu operasyon bu gun/vardiyadaki zaman araligiyla kesisiyor mu?
                               ' Vardiyanin baslangic ve bitis DateTime'ini hesapla
                               Dim vBasDtH As Double: vBasDtH = gunIdxPlan + vBasH / 24#
                               Dim vBitDtH As Double: vBitDtH = gunIdxPlan + vBitH / 24#
                               Dim opBasDtH As Double: opBasDtH = p_bas_gun + p_bas_saat / 24#
                               Dim opBitDtH As Double: opBitDtH = p_bit_gun + p_bit_saat / 24#
 
                               If opBasDtH < vBitDtH And opBitDtH > vBasDtH Then
                                   ' Kesisim var!
                                   ' Bu vardiyadaki baslangic ve bitis saatini hesapla
                                   Dim gosBas As Double: If opBasDtH > vBasDtH Then gosBas = opBasDtH Else gosBas = vBasDtH
                                   Dim gosBit As Double: If opBitDtH < vBitDtH Then gosBit = opBitDtH Else gosBit = vBitDtH
 
                                   Dim gosBasSaat As Double: gosBasSaat = (gosBas - Int(gosBas)) * 24#
                                   Dim gosBitSaat As Double: gosBitSaat = (gosBit - Int(gosBit)) * 24#
 
                                   ' Mola saatlerini exclude et - gostermek icin sadece bilgi yaz
                                   Dim basS As Integer: basS = CInt(gosBasSaat) Mod 24
                                   Dim basDk As Integer: basDk = CInt((gosBasSaat - Int(gosBasSaat)) * 60)
                                   Dim bitS As Integer: bitS = CInt(gosBitSaat) Mod 24
                                   Dim bitDk As Integer: bitDk = CInt((gosBitSaat - Int(gosBitSaat)) * 60)
 
                                   hucreMetin = ucakNo & " " & Format(basS, "00") & ":" & Format(basDk, "00") & "-" & Format(bitS, "00") & ":" & Format(bitDk, "00") & Chr(10) & op_kodlarH(p_ist, p_op)
                                   hucreRenk = renklerH(ui Mod 20)
                                   GoTo yazHucre
                               End If
sonraki_kayit_h:
                           Next ki
                       Next ui
                   End If
 
yazHucre:
                   With wsH.Cells(mevcut_satir, col)
                       If hucreMetin <> "" Then
                           .Value = hucreMetin
                           Dim rH As Long: rH = CLng("&H" & Left(hucreRenk, 2))
                           Dim gH As Long: gH = CLng("&H" & Mid(hucreRenk, 3, 2))
                           Dim bH As Long: bH = CLng("&H" & Right(hucreRenk, 2))
                           .Interior.Color = RGB(rH, gH, bH)
                           .Font.Bold = True: .Font.Size = 8
                           .WrapText = True
                       ElseIf is_tatil Then
                           .Interior.Color = RGB(215, 215, 215)
                       End If
                       .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
                       .Borders.LineStyle = xlContinuous
                       .Borders.Weight = xlHairline
                       .Borders.Color = RGB(180, 180, 180)
                   End With
                   col = col + 1
               Next v
           Next gun_idx
 
           wsH.Rows(mevcut_satir).RowHeight = 36
           mevcut_satir = mevcut_satir + 1
       Next hat_no
   Next ist_idx
 
   wsH.Cells(1, 1).Select
   Application.ScreenUpdating = True
   MsgBox "Haftalik plan olusturuldu!", vbInformation
   Exit Sub
Hata:
   Application.ScreenUpdating = True
   MsgBox "Hata: " & Err.Description, vbCritical
End Sub
