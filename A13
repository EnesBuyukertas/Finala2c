   op_kodlar(4, 0) = "CANOPY-0097": op_kodlar(4, 1) = "CANOPY-0092": op_kodlar(4, 2) = "CANOPY-0111"
   op_kodlar(4, 3) = "CANOPY-0150": op_kodlar(4, 4) = "CANOPY-1041": op_kodlar(4, 5) = "CANOPY-1072"
   op_kodlar(5, 0) = "CANOPY-0120": op_kodlar(5, 1) = "CANOPY-0125"
   op_kodlar(6, 0) = "CANOPY-0130"
   op_kodlar(7, 0) = "FINAL"
 
   ' Renk paleti
   Dim renkler(0 To 19) As String
   renkler(0) = "FFD700": renkler(1) = "87CEEB": renkler(2) = "90EE90"
   renkler(3) = "FFB6C1": renkler(4) = "DDA0DD": renkler(5) = "F0E68C"
   renkler(6) = "98FB98": renkler(7) = "87CEFA": renkler(8) = "FFA07A"
   renkler(9) = "20B2AA": renkler(10) = "FF6347": renkler(11) = "4169E1"
   renkler(12) = "32CD32": renkler(13) = "FF69B4": renkler(14) = "9370DB"
   renkler(15) = "00CED1": renkler(16) = "FF8C00": renkler(17) = "8B4513"
   renkler(18) = "2E8B57": renkler(19) = "DC143C"
 
   ' Sayfayi olustur
   Dim ws As Worksheet
   Application.DisplayAlerts = False
   On Error Resume Next: ThisWorkbook.Sheets("GanttPlan").Delete: On Error GoTo 0
   Application.DisplayAlerts = True
   Dim yeniWs As Worksheet
   Set yeniWs = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   yeniWs.Name = "GanttPlan"
   Set ws = yeniWs
   ws.Cells.Font.Name = "Calibri"
 
   Const IST_COL As Integer = 1
   Const OP_COL As Integer = 2
   Const VERI_COL As Integer = 3
   Const BASLIK_SATIR As Integer = 3
 
   ' 30 dakikalik dilimler (Double olarak: 7.0=07:00, 7.5=07:30, ...)
   Dim saat_sayisi As Integer
   If gNormalVardiya = 1 Then saat_sayisi = 16
   If gNormalVardiya = 2 Then saat_sayisi = 32
   If gNormalVardiya = 3 Then saat_sayisi = 48
   Dim saatlerD() As Double
   ReDim saatlerD(0 To saat_sayisi - 1)
   Dim ss As Integer
   If gNormalVardiya <= 2 Then
       For ss = 0 To saat_sayisi - 1
           saatlerD(ss) = 7# + ss * 0.5
       Next ss
   Else
       For ss = 0 To 31: saatlerD(ss) = 7# + ss * 0.5: Next ss
       For ss = 0 To 15: saatlerD(32 + ss) = 23# + ss * 0.5: Next ss
   End If
 
   Dim gunAdlari(0 To 6) As String
   gunAdlari(0) = "Pzt": gunAdlari(1) = "Sal": gunAdlari(2) = "Car"
   gunAdlari(3) = "Per": gunAdlari(4) = "Cum": gunAdlari(5) = "Cmt": gunAdlari(6) = "Paz"
 
   ' Baslik satirlari
   Dim gun_idx As Long
   For gun_idx = 0 To gunSayisi - 1
       Dim dd As Date: dd = basTarih + gun_idx
       Dim gun_adi As String: gun_adi = gunAdlari(Weekday(dd, vbMonday) - 1)
       Dim is_tatil As Boolean: is_tatil = TatilMiGun(gun_idx, basTarih)
       Dim bas_col As Long: bas_col = VERI_COL + gun_idx * saat_sayisi
       Dim bit_col As Long: bit_col = bas_col + saat_sayisi - 1
 
       ' Gun baslik
       ws.Range(ws.Cells(1, bas_col), ws.Cells(1, bit_col)).Merge
       With ws.Cells(1, bas_col)
           .Value = gun_adi & " " & Format(dd, "DD.MM.YYYY")
           .Font.Bold = True: .Font.Size = 8: .Font.Color = RGB(255, 255, 255)
           If is_tatil Then
               .Interior.Color = RGB(192, 0, 0)
           Else
               .Interior.Color = RGB(31, 78, 121)
           End If
           .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
       End With
 
       ' Vardiya baslikları
       Dim v As Integer
       For v = 1 To gNormalVardiya
           Dim vBas As Double: vBas = VardiyaBas(v)
           Dim vBit As Double: vBit = VardiyaBit(v)
           Dim vBitG As Double: If vBit >= 24 Then vBitG = vBit - 24 Else vBitG = vBit
           Dim v_bas_col As Long: v_bas_col = -1
           Dim v_bit_col As Long: v_bit_col = -1
           Dim si As Integer
           For si = 0 To saat_sayisi - 1
               Dim sd As Double: sd = saatlerD(si)
               If sd >= 24 Then sd = sd - 24
               Dim origSd As Double: origSd = saatlerD(si)
               If origSd >= vBas And origSd < vBit Then
                   If v_bas_col = -1 Then v_bas_col = bas_col + si
                   v_bit_col = bas_col + si
               End If
           Next si
           If v_bas_col > 0 Then
               ws.Range(ws.Cells(2, v_bas_col), ws.Cells(2, v_bit_col)).Merge
               With ws.Cells(2, v_bas_col)
                   Dim vrenk As String
                   Select Case v
                       Case 1: vrenk = "2E75B6"
                       Case 2: vrenk = "375623"
                       Case 3: vrenk = "7030A0"
                   End Select
                   Dim vb_s As Integer: vb_s = CInt(vBas): Dim vb_dk As Integer: vb_dk = CInt((vBas - Int(vBas)) * 60)
                   Dim vbt_s As Integer: vbt_s = CInt(vBitG): Dim vbt_dk As Integer: vbt_dk = CInt((vBitG - Int(vBitG)) * 60)
                   .Value = "S" & v & " (" & Format(vb_s, "00") & ":" & Format(vb_dk, "00") & "-" & Format(vbt_s, "00") & ":" & Format(vbt_dk, "00") & ")"
                   .Font.Bold = True: .Font.Size = 7: .Font.Color = RGB(255, 255, 255)
                   .Interior.Color = RGB(CLng("&H" & Left(vrenk, 2)), CLng("&H" & Mid(vrenk, 3, 2)), CLng("&H" & Right(vrenk, 2)))
                   .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
               End With
           End If
       Next v
 
       ' 30dk basliklar ve mola isareti
       For si = 0 To saat_sayisi - 1
           Dim scol As Long: scol = bas_col + si
           Dim sdVal As Double: sdVal = saatlerD(si)
 
           ' Mola mu?
           Dim is_mola As Boolean: is_mola = False
           Dim mv As Integer
           For mv = 1 To gNormalVardiya
               Dim mb As Double: mb = VardiyaMolaBas(mv)
               Dim mbt As Double: mbt = VardiyaMolaBit(mv)
               If mv = 3 Then mb = mb - 24#: mbt = mbt - 24#
               If sdVal >= mb And sdVal < mbt Then is_mola = True: Exit For
           Next mv
 
           Dim sdGoster As Double: sdGoster = sdVal
           If sdGoster >= 24 Then sdGoster = sdGoster - 24
           Dim s_h As Integer: s_h = CInt(Int(sdGoster))
           Dim s_m As Integer: s_m = CInt((sdGoster - Int(sdGoster)) * 60)
 
           With ws.Cells(3, scol)
               .Value = Format(s_h, "00") & ":" & Format(s_m, "00")
               .Font.Size = 6: .Font.Bold = True
               If is_mola Then
                   .Interior.Color = RGB(255, 200, 0)
                   .Font.Color = RGB(100, 60, 0)
               ElseIf is_tatil Then
                   .Interior.Color = RGB(255, 200, 200)
                   .Font.Color = RGB(0, 0, 0)
               Else
                   .Interior.Color = RGB(214, 228, 240)
                   .Font.Color = RGB(0, 0, 0)
               End If
               .HorizontalAlignment = xlCenter
               .Borders.LineStyle = xlContinuous
               .Borders.Weight = xlHairline
               .Borders.Color = RGB(180, 180, 180)
           End With
           ws.Columns(scol).ColumnWidth = 3.2
       Next si
   Next gun_idx
 
   ' Sol sutunlar
   ws.Columns(IST_COL).ColumnWidth = 22
   ws.Columns(OP_COL).ColumnWidth = 40
   Dim r As Integer, c As Integer
   For r = 1 To 3
       For c = 1 To 2
           With ws.Cells(r, c)
               .Font.Bold = True: .Font.Size = 9: .Font.Color = RGB(255, 255, 255)
               .Interior.Color = RGB(31, 78, 121)
               .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
           End With
       Next c
   Next r
   ws.Cells(1, IST_COL).Value = "ISTASYON / HAT"
   ws.Cells(1, OP_COL).Value = "OPERASYON"
   ws.Range(ws.Cells(1, IST_COL), ws.Cells(3, IST_COL)).Merge
   ws.Range(ws.Cells(1, OP_COL), ws.Cells(3, OP_COL)).Merge
 
   ' Istasyon ve operasyon satirlari
   Dim mevcut_satir As Long: mevcut_satir = BASLIK_SATIR + 1
 
   Dim ist_adlari(0 To 7) As String
   ist_adlari(0) = "COJI 1": ist_adlari(1) = "COJI 2 WINDSHIELD"
