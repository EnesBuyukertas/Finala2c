' ====================================================
' VARDIYA FONKSIYONLARI
' ====================================================
Function VardiyaBas(vNo As Integer) As Double
   Select Case vNo
       Case 1: VardiyaBas = 7#
       Case 2: VardiyaBas = 15#
       Case 3: VardiyaBas = 23#
   End Select
End Function
 
Function VardiyaBit(vNo As Integer) As Double
   Select Case vNo
       Case 1: VardiyaBit = 15#
       Case 2: VardiyaBit = 23#
       Case 3: VardiyaBit = 31#  ' Ertesi gun 07:00
   End Select
End Function
 
Function VardiyaMolaBas(vNo As Integer) As Double
   Select Case vNo
       Case 1: VardiyaMolaBas = 11.5   ' 11:30
       Case 2: VardiyaMolaBas = 18#    ' 18:00
       Case 3: VardiyaMolaBas = 26#    ' 02:00 (ertesi gun = 24+2)
   End Select
End Function
 
Function VardiyaMolaBit(vNo As Integer) As Double
   Select Case vNo
       Case 1: VardiyaMolaBit = 12.5   ' 12:30
       Case 2: VardiyaMolaBit = 19#    ' 19:00
       Case 3: VardiyaMolaBit = 27#    ' 03:00 (ertesi gun = 24+3)
   End Select
End Function
 
Function HangiVardiya(saatOfDay As Double) As Integer
   Dim s As Double: s = saatOfDay
   If s >= 23# Or s < 7# Then
       If gNormalVardiya >= 3 Then HangiVardiya = 3: Exit Function
   End If
   If s >= 7# And s < 15# Then HangiVardiya = 1: Exit Function
   If s >= 15# And s < 23# Then
       If gNormalVardiya >= 2 Then HangiVardiya = 2: Exit Function
   End If
   HangiVardiya = 0
End Function
 
Function TatilMiGun(gunIdx As Long, basTarih As Date) As Boolean
   Dim dd As Date: dd = basTarih + gunIdx
   TatilMiGun = False
   If Weekday(dd, vbMonday) = 7 Then TatilMiGun = True: Exit Function
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       If dd = gTatilGunler(tt) And Not gTatilCalisiyorMu(tt) Then
           TatilMiGun = True: Exit Function
       End If
   Next tt
End Function
 
' ====================================================
' ZAMAN HESAPLAMA
' Zaman = (gunIdx As Long, saatOfDay As Double) - Double tuple yerine
' ByRef ile geciyoruz
' ====================================================
Sub SaatEkle(ByRef gun As Long, ByRef saat As Double, netSaat As Double, basTarih As Date)
   Dim kalan As Double: kalan = netSaat
   Dim guvenlik As Long: guvenlik = 0
 
   Do While kalan > 0.0001
       guvenlik = guvenlik + 1
       If guvenlik > 500000 Then Exit Do
 
       ' Tatil atlama
       Do While TatilMiGun(gun, basTarih)
           gun = gun + 1
           saat = VardiyaBas(1)
       Loop
 
       Dim v As Integer: v = HangiVardiya(saat)
       If v = 0 Then
           ' Sonraki vardiyanin basina atla
           Dim sonV As Double: sonV = -1
           Dim vv As Integer
           For vv = 1 To gNormalVardiya
               If VardiyaBas(vv) > saat Then
                   sonV = VardiyaBas(vv): Exit For
               End If
           Next vv
           If sonV < 0 Then
               gun = gun + 1
               Do While TatilMiGun(gun, basTarih): gun = gun + 1: Loop
               saat = VardiyaBas(1)
           Else
               saat = sonV
           End If
       Else
           Dim vMolaBas As Double: vMolaBas = VardiyaMolaBas(v)
           Dim vMolaBit As Double: vMolaBit = VardiyaMolaBit(v)
           Dim vBit As Double: vBit = VardiyaBit(v)
 
           ' Molada mi?
           If saat >= vMolaBas And saat < vMolaBit Then
               saat = vMolaBit
           ElseIf saat < vMolaBas Then
               ' Moladan once
               Dim molayaKadar As Double: molayaKadar = vMolaBas - saat
               Dim molaSonrasi As Double: molaSonrasi = vBit - vMolaBit
               Dim topNetV As Double: topNetV = molayaKadar + molaSonrasi
 
               If kalan <= molayaKadar Then
                   saat = saat + kalan: kalan = 0
               ElseIf kalan <= topNetV Then
                   kalan = kalan - molayaKadar
                   saat = vMolaBit + kalan: kalan = 0
               Else
                   kalan = kalan - topNetV
                   If v < gNormalVardiya Then
                       saat = VardiyaBas(v + 1)
                   Else
                       gun = gun + 1
                       Do While TatilMiGun(gun, basTarih): gun = gun + 1: Loop
                       saat = VardiyaBas(1)
                   End If
               End If
           Else
               ' Moladan sonra
               Dim kalanV As Double: kalanV = vBit - saat
               If kalanV <= 0 Then
                   If v < gNormalVardiya Then
                       saat = VardiyaBas(v + 1)
                   Else
                       gun = gun + 1
                       Do While TatilMiGun(gun, basTarih): gun = gun + 1: Loop
                       saat = VardiyaBas(1)
                   End If
               ElseIf kalan <= kalanV Then
                   saat = saat + kalan: kalan = 0
               Else
                   kalan = kalan - kalanV
                   If v < gNormalVardiya Then
                       saat = VardiyaBas(v + 1)
                   Else
                       gun = gun + 1
                       Do While TatilMiGun(gun, basTarih): gun = gun + 1: Loop
                       saat = VardiyaBas(1)
                   End If
               End If
           End If
       End If
   Loop
End Sub
 
Sub IlkUygunZaman(ByRef gun As Long, ByRef saat As Double, basTarih As Date)
   Do While TatilMiGun(gun, basTarih)
       gun = gun + 1: saat = VardiyaBas(1)
   Loop
   Dim v As Integer: v = HangiVardiya(saat)
   If v = 0 Then
       Dim sonV As Double: sonV = -1
       Dim vv As Integer
       For vv = 1 To gNormalVardiya
           If VardiyaBas(vv) > saat Then sonV = VardiyaBas(vv): Exit For
       Next vv
       If sonV < 0 Then
           gun = gun + 1
           Do While TatilMiGun(gun, basTarih): gun = gun + 1: Loop
           saat = VardiyaBas(1)
       Else
           saat = sonV
       End If
   End If
   ' Molada mi?
   v = HangiVardiya(saat)
   If v > 0 Then
       If saat >= VardiyaMolaBas(v) And saat < VardiyaMolaBit(v) Then
           saat = VardiyaMolaBit(v)
       End If
   End If
End Sub
 
