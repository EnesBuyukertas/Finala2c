' ====================================================
' VARDIYA TANIMLARI
' Her vardiya: baslangic dakika (gun icinde), bitis dakika,
' mola baslangic, mola bitis (gun icinde dakika cinsinden)
' Gece vardiyasi (S3) gece yarisi gectiginden ozel muamele
' ====================================================
' S1: 07:00-15:00, mola 11:30-12:30  -> net 7 saat
' S2: 15:00-23:00, mola 18:00-19:00  -> net 7 saat
' S3: 23:00-07:00, mola 03:30-04:30  -> net 7 saat
 
' Vardiya bilgileri: dakika cinsinden (gunun baslangicindan itibaren)
' S3 icin bitis = 30*60+7*60 = ertesi gune tasiyor, onu ayri hesaplayacagiz
 
Function VardiyaBasDak(vNo As Integer) As Long
   Select Case vNo
       Case 1: VardiyaBasDak = 7 * 60        ' 07:00
       Case 2: VardiyaBasDak = 15 * 60       ' 15:00
       Case 3: VardiyaBasDak = 23 * 60       ' 23:00
   End Select
End Function
 
Function VardiyaBitDak(vNo As Integer) As Long
   Select Case vNo
       Case 1: VardiyaBitDak = 15 * 60       ' 15:00
       Case 2: VardiyaBitDak = 23 * 60       ' 23:00
       Case 3: VardiyaBitDak = 24 * 60 + 7 * 60  ' 31:00 (ertesi gun 07:00)
   End Select
End Function
 
Function MolaBasDak(vNo As Integer) As Long
   Select Case vNo
       Case 1: MolaBasDak = 11 * 60 + 30    ' 11:30
       Case 2: MolaBasDak = 18 * 60          ' 18:00
       Case 3: MolaBasDak = 24 * 60 + 3 * 60 + 30  ' 03:30 ertesi gun
   End Select
End Function
 
Function MolaBitDak(vNo As Integer) As Long
   Select Case vNo
       Case 1: MolaBitDak = 12 * 60 + 30    ' 12:30
       Case 2: MolaBitDak = 19 * 60          ' 19:00
       Case 3: MolaBitDak = 24 * 60 + 4 * 60 + 30  ' 04:30 ertesi gun
   End Select
End Function
 
' Bir vardiyanin net calisma suresi (saat)
Function VardiyaNetSaat(vNo As Integer) As Double
   VardiyaNetSaat = (VardiyaBitDak(vNo) - VardiyaBasDak(vNo) - 60) / 60#  ' 60 dk mola
End Function
 
' ====================================================
' ZAMAN YAPISI
' Zaman = tarihin Double degeri * 1440 + dakika (gun icinde)
' Biz DateTime'i Double olarak sakliyoruz:
'   tamKisim = gun (CDate serial)
'   ondalik = saatin gun icindeki orani
' ====================================================
 
' Bir DateTime'den dakikayi al (0..1439)
Function DtDakika(dt As Double) As Long
   DtDakika = CLng((dt - Int(dt)) * 1440) Mod 1440
End Function
 
' Datetime'i olustur (tarih + dakika)
Function DtOlustur(tarih As Date, dakika As Long) As Double
   Dim d As Long: d = dakika Mod (24 * 60)
   Dim gunEkle As Long: gunEkle = dakika \ (24 * 60)
   DtOlustur = CDbl(tarih) + gunEkle + d / 1440#
End Function
 
' Bir datetime'e saat ekle, molalari atlayarak
' Hangi vardiyadaysa o vardiyanin molasini atlar
' Vardiya sayisi (gNormalVardiya) global
Function SaatEkle(baslamaDt As Double, netSaat As Double) As Double
   Dim kalanSaat As Double: kalanSaat = netSaat
   Dim simdi As Double: simdi = baslamaDt
 
   Do While kalanSaat > 0.0000001
       ' Simdi hangi vardiyanin icindeyiz?
       Dim vNo As Integer: vNo = HangiVardiya(simdi)
       If vNo = 0 Then
           ' Vardiya disindayiz, bir sonraki vardiyanin basina atla
           simdi = SonrakiVardiyaBas(simdi)
       Else
           ' Bu vardiyanin kalan net saatini hesapla
           Dim vardiyaBitis As Double: vardiyaBitis = VardiyaBitisDateTime(simdi, vNo)
           Dim molaBasDt As Double: molaBasDt = MolaBasDateTime(simdi, vNo)
           Dim molaBitDt As Double: molaBitDt = MolaBitDateTime(simdi, vNo)
 
           ' Simdi molada miyiz?
           If simdi >= molaBasDt And simdi < molaBitDt Then
               simdi = molaBitDt  ' Moladan cik
           End If
 
           ' Molaya kadar kalan sure
           Dim suremolaya As Double
           If simdi < molaBasDt Then
               suremolaya = (molaBasDt - simdi) * 24#
           Else
               suremolaya = 0
           End If
 
           ' Vardiya bitisine kadar kalan net sure
           Dim sureBitis As Double
           If simdi < molaBasDt Then
               sureBitis = (vardiyaBitis - molaBasDt) * 24# - 1# + suremolaya  ' mola=1saat
           Else
               sureBitis = (vardiyaBitis - simdi) * 24#
           End If
 
           If sureBitis <= 0 Then
               ' Bu vardiyanin sonu geldi, sonraki vardiyanin basina atla
               simdi = SonrakiVardiyaBas(simdi)
           ElseIf kalanSaat <= sureBitis Then
               ' Bu vardiyanin icinde biter
               ' Moladan once mi sonra mi?
               If simdi < molaBasDt Then
                   If kalanSaat <= suremolaya Then
                       simdi = simdi + kalanSaat / 24#
                   Else
                       simdi = molaBitDt + (kalanSaat - suremolaya) / 24#
                   End If
               Else
                   simdi = simdi + kalanSaat / 24#
               End If
               kalanSaat = 0
           Else
               ' Bu vardiyanin tamami kullanildi
               kalanSaat = kalanSaat - sureBitis
               simdi = SonrakiVardiyaBas(vardiyaBitis)
           End If
       End If
   Loop
 
   SaatEkle = simdi
End Function
 
' Verilen datetime hangi vardiyanin icinde? (0=vardiya yok)
Function HangiVardiya(dt As Double) As Integer
   Dim gunDak As Long
   ' Dakikayi gun icinde hesapla
   gunDak = CLng((dt - Int(dt)) * 1440)
 
   Dim v As Integer
   For v = 1 To gNormalVardiya
       Dim vBas As Long: vBas = VardiyaBasDak(v)
       Dim vBit As Long: vBit = VardiyaBitDak(v)
 
       If v = 3 Then
           ' Gece vardiyas: 23:00 - 07:00 (ertesi gun)
           If gunDak >= vBas Or gunDak < (vBit - 24 * 60) Then
               HangiVardiya = v: Exit Function
           End If
       Else
           If gunDak >= vBas And gunDak < vBit Then
               HangiVardiya = v: Exit Function
           End If
       End If
   Next v
   HangiVardiya = 0
End Function
 
' Mevcut vardiyanin bitis DateTime'i
Function VardiyaBitisDateTime(dt As Double, vNo As Integer) As Double
   Dim gunTarih As Long: gunTarih = Int(dt)
   Dim gunDak As Long: gunDak = CLng((dt - Int(dt)) * 1440)
 
   If vNo = 3 And gunDak < 7 * 60 Then
       ' Gece vardiyas, ertesi gun 07:00
       VardiyaBitisDateTime = gunTarih + 7 * 60 / 1440#
   ElseIf vNo = 3 Then
       ' Gece vardiyas, bu gunun 23:00'inden basladi, ertesi gun 07:00
       VardiyaBitisDateTime = gunTarih + 1 + 7 * 60 / 1440#
   Else
       VardiyaBitisDateTime = gunTarih + VardiyaBitDak(vNo) / 1440#
   End If
End Function
 
' Mevcut vardiyanin mola baslangic DateTime'i
Function MolaBasDateTime(dt As Double, vNo As Integer) As Double
   Dim gunTarih As Long: gunTarih = Int(dt)
   Dim gunDak As Long: gunDak = CLng((dt - Int(dt)) * 1440)
 
   If vNo = 3 And gunDak < 7 * 60 Then
       MolaBasDateTime = gunTarih + (3 * 60 + 30) / 1440#
   ElseIf vNo = 3 Then
       MolaBasDateTime = gunTarih + 1 + (3 * 60 + 30) / 1440#
   Else
       MolaBasDateTime = gunTarih + MolaBasDak(vNo) / 1440#
   End If
End Function
 
Function MolaBitDateTime(dt As Double, vNo As Integer) As Double
   Dim gunTarih As Long: gunTarih = Int(dt)
   Dim gunDak As Long: gunDak = CLng((dt - Int(dt)) * 1440)
 
   If vNo = 3 And gunDak < 7 * 60 Then
       MolaBitDateTime = gunTarih + (4 * 60 + 30) / 1440#
   ElseIf vNo = 3 Then
       MolaBitDateTime = gunTarih + 1 + (4 * 60 + 30) / 1440#
   Else
       MolaBitDateTime = gunTarih + MolaBitDak(vNo) / 1440#
   End If
End Function
 
' Bir sonraki vardiyanin baslangic DateTime'i
Function SonrakiVardiyaBas(dt As Double) As Double
   Dim gunTarih As Long: gunTarih = Int(dt)
   Dim gunDak As Long: gunDak = CLng((dt - Int(dt)) * 1440)
 
   Dim v As Integer
   ' Mevcut gunun sonraki vardiyalarina bak
   For v = 1 To gNormalVardiya
       Dim vBas As Long: vBas = VardiyaBasDak(v)
       If vBas > gunDak And v <= gNormalVardiya Then
           SonrakiVardiyaBas = gunTarih + vBas / 1440#
           Exit Function
       End If
   Next v
 
   ' Bu gunde vardiya kalmadi, ertesi gun ilk vardiyaya gec
   SonrakiVardiyaBas = gunTarih + 1 + VardiyaBasDak(1) / 1440#
End Function
 
' DateTime'den saat string'i olustur (HH:MM)
Function DtSaat(dt As Double) As String
   Dim gunDak As Long: gunDak = CLng((dt - Int(dt)) * 1440)
   If gunDak < 0 Then gunDak = gunDak + 1440
   Dim saat As Integer: saat = gunDak \ 60
   Dim dakika As Integer: dakika = gunDak Mod 60
   DtSaat = Format(saat, "00") & ":" & Format(dakika, "00")
End Function
 
' DateTime'den tarih al
Function DtTarih(dt As Double) As Date
   DtTarih = CDate(Int(dt))
End Function
 
