                        ucOutBasDt, ucOutBitDt, ucLayBasDt, ucLayBitDt, ucBoyaBasDt, ucBoyaBitDt, ucSealBasDt, ucSealBitDt, _
                        ucFinalBasDt, ucFinalBitDt, ucakSayisi, ucPinDt)
