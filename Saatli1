       ucDurus(i) = CDbl(wsP.Cells(i + 2, 2).Value)
       ucC1Sure(i) = CDbl(wsP.Cells(i + 2, 3).Value)
       ucWinSure(i) = CDbl(wsP.Cells(i + 2, 4).Value)
       ucMateSure(i) = CDbl(wsP.Cells(i + 2, 5).Value)
       ucOutSure(i) = CDbl(wsP.Cells(i + 2, 6).Value)
       ucLaySure(i) = CDbl(wsP.Cells(i + 2, 7).Value)
       ucBoyaSure(i) = CDbl(wsP.Cells(i + 2, 8).Value)
       ucSealSure(i) = CDbl(wsP.Cells(i + 2, 9).Value)
       ucFinalSure(i) = CDbl(wsP.Cells(i + 2, 10).Value)
   Next i
