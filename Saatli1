Function TatilMi(tarih As Date) As Boolean
   TatilMi = False
   If Weekday(tarih, vbMonday) = 7 Then TatilMi = True: Exit Function
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       If tarih >= gTatilTarihBas(tt) And tarih <= gTatilTarihBit(tt) Then
           If Not gTatilCalis(tt) Then TatilMi = True
           Exit Function
       End If
   Next tt
End Function
 
' Bir DateTime tatil gununde mi?
Function DtTatilMi(dt As Double) As Boolean
   DtTatilMi = TatilMi(DtTarih(dt))
End Function
 
' Tatil/hafta sonu atlayarak ilk calisma gununun ilk vardiyas baslangicina git
Function SonrakiCalismaDt(dt As Double) As Double
   Dim d As Date: d = DtTarih(dt)
   Do While TatilMi(d)
       d = d + 1
   Loop
   SonrakiCalismaDt = CDbl(d) + VardiyaBasDak(1) / 1440#
End Function
 
' Eger dt tatil gunundeyse sonraki is gunune at
Function TatilAtla(dt As Double) As Double
   Dim d As Date: d = DtTarih(dt)
   If TatilMi(d) Then
       TatilAtla = SonrakiCalismaDt(dt)
   Else
       TatilAtla = dt
   End If
End Function
 
