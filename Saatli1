' ====================================================
' ANA HESAPLAMA
' Her ucak icin baslangic ve bitis DateTime'leri hesapla
' ====================================================
Sub TumHesapla( _
   ucNo() As Long, ucDurus() As Double, _
   ucC1Sure() As Double, ucWinSure() As Double, ucMateSure() As Double, _
   ucOutSure() As Double, ucLaySure() As Double, ucBoyaSure() As Double, _
   ucSealSure() As Double, ucFinalSure() As Double, _
   ucakSayisi As Long, _
   c1BasDt As Double, c2BasDt As Double, _
   ucPinDt() As Double, _
   ucDurusBasDt() As Double, ucDurusBitDt() As Double, _
   ucC1BasDt() As Double, ucC1BitDt() As Double, ucC1Hat() As Integer, _
   ucWinBasDt() As Double, ucWinBitDt() As Double, ucWinHat() As Integer, _
   ucMateBasDt() As Double, ucMateBitDt() As Double, ucMateHat() As Integer, _
   ucOutBasDt() As Double, ucOutBitDt() As Double, _
   ucLayBasDt() As Double, ucLayBitDt() As Double, _
   ucBoyaBasDt() As Double, ucBoyaBitDt() As Double, _
   ucSealBasDt() As Double, ucSealBitDt() As Double, _
   ucFinalBasDt() As Double, ucFinalBitDt() As Double)
 
   ReDim ucDurusBasDt(0 To ucakSayisi - 1): ReDim ucDurusBitDt(0 To ucakSayisi - 1)
   ReDim ucC1BasDt(0 To ucakSayisi - 1):    ReDim ucC1BitDt(0 To ucakSayisi - 1)
   ReDim ucC1Hat(0 To ucakSayisi - 1)
   ReDim ucWinBasDt(0 To ucakSayisi - 1):   ReDim ucWinBitDt(0 To ucakSayisi - 1)
   ReDim ucWinHat(0 To ucakSayisi - 1)
   ReDim ucMateBasDt(0 To ucakSayisi - 1):  ReDim ucMateBitDt(0 To ucakSayisi - 1)
   ReDim ucMateHat(0 To ucakSayisi - 1)
   ReDim ucOutBasDt(0 To ucakSayisi - 1):   ReDim ucOutBitDt(0 To ucakSayisi - 1)
   ReDim ucLayBasDt(0 To ucakSayisi - 1):   ReDim ucLayBitDt(0 To ucakSayisi - 1)
   ReDim ucBoyaBasDt(0 To ucakSayisi - 1):  ReDim ucBoyaBitDt(0 To ucakSayisi - 1)
   ReDim ucSealBasDt(0 To ucakSayisi - 1):  ReDim ucSealBitDt(0 To ucakSayisi - 1)
   ReDim ucFinalBasDt(0 To ucakSayisi - 1): ReDim ucFinalBitDt(0 To ucakSayisi - 1)
 
   ' Hat kuyruk pozisyonlari (DateTime olarak)
   Dim c1Son(1 To COJI1_HAT) As Double
   Dim h As Integer
   For h = 1 To COJI1_HAT: c1Son(h) = c1BasDt: Next h
 
   Dim c2Son(1 To COJI2_HAT) As Double
   For h = 1 To COJI2_HAT: c2Son(h) = c2BasDt: Next h
 
   Dim outSon As Double: outSon = IIf(c1BasDt < c2BasDt, c1BasDt, c2BasDt)
   Dim laySon As Double: laySon = outSon
   Dim boyaSon As Double: boyaSon = outSon
   Dim sealSon As Double: sealSon = outSon
   Dim finalSon As Double: finalSon = outSon
 
   Dim i As Long
   Dim startDt As Double, bitDt As Double
   Dim enDusuk As Double, kod As Double
   Dim c1H As Integer, c2H As Integer
   Dim pinDt As Double
 
   For i = 0 To ucakSayisi - 1
 
       ' --- DURUS ---
       If ucDurus(i) > 0 Then
           ' En erken bos COJI1 hatti bul
           enDusuk = c1Son(1): c1H = 1
           For h = 2 To COJI1_HAT
               If c1Son(h) < enDusuk Then enDusuk = c1Son(h): c1H = h
           Next h
           startDt = TatilAtla(c1Son(c1H))
           If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
           startDt = TatilAtla(startDt)
           ucDurusBasDt(i) = startDt
           bitDt = SaatEkle(startDt, ucDurus(i))
           ucDurusBitDt(i) = bitDt
           c1Son(c1H) = bitDt
       End If
 
       ' --- COJI1 ---
       enDusuk = c1Son(1): c1H = 1
       For h = 2 To COJI1_HAT
           If c1Son(h) < enDusuk Then enDusuk = c1Son(h): c1H = h
       Next h
       startDt = TatilAtla(c1Son(c1H))
       If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
       startDt = TatilAtla(startDt)
       ' Pin uygula
       If ucPinDt(i, 0) > 0 Then
           pinDt = ucPinDt(i, 0)
           If pinDt > startDt Then
               startDt = TatilAtla(pinDt)
               If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
           End If
       End If
       ucC1BasDt(i) = startDt: ucC1Hat(i) = c1H
       bitDt = SaatEkle(startDt, ucC1Sure(i))
       ucC1BitDt(i) = bitDt
       c1Son(c1H) = bitDt
 
       ' --- WINDSHIELD (COJI2, COJI1 ile paralel) ---
       ' En erken bos COJI2 hatti
       enDusuk = c2Son(1): c2H = 1
       For h = 2 To COJI2_HAT
           If c2Son(h) < enDusuk Then enDusuk = c2Son(h): c2H = h
       Next h
       ' COJI1 baslangici ile eslesir, ama hat bos olmali
       If c2Son(c2H) > ucC1BasDt(i) Then
           startDt = TatilAtla(c2Son(c2H))
       Else
           startDt = ucC1BasDt(i)
       End If
       If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
       startDt = TatilAtla(startDt)
       If ucPinDt(i, 1) > 0 Then
           pinDt = ucPinDt(i, 1)
           If pinDt > startDt Then
               startDt = TatilAtla(pinDt)
               If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
           End If
       End If
       ucWinBasDt(i) = startDt: ucWinHat(i) = c2H
       bitDt = SaatEkle(startDt, ucWinSure(i))
       ucWinBitDt(i) = bitDt
       c2Son(c2H) = bitDt
 
       ' --- MATE (COJI2, COJI1 VE WINDSHIELD bittikten sonra) ---
       Dim mateReqDt As Double
       If ucC1BitDt(i) >= ucWinBitDt(i) Then
           mateReqDt = ucC1BitDt(i)
       Else
           mateReqDt = ucWinBitDt(i)
       End If
       ' En erken bos COJI2 hatti
       enDusuk = c2Son(1): c2H = 1
       For h = 2 To COJI2_HAT
           If c2Son(h) < enDusuk Then enDusuk = c2Son(h): c2H = h
       Next h
       If c2Son(c2H) > mateReqDt Then
           startDt = TatilAtla(c2Son(c2H))
       Else
           startDt = mateReqDt
       End If
       If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
       startDt = TatilAtla(startDt)
       If ucPinDt(i, 2) > 0 Then
           pinDt = ucPinDt(i, 2)
           If pinDt > startDt Then
               startDt = TatilAtla(pinDt)
               If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
           End If
       End If
       ucMateBasDt(i) = startDt: ucMateHat(i) = c2H
       bitDt = SaatEkle(startDt, ucMateSure(i))
       ucMateBitDt(i) = bitDt
       c2Son(c2H) = bitDt
 
       ' Sonraki tek hatli istasyonlar icin baslangic
       Dim sonrakiDt As Double: sonrakiDt = ucMateBitDt(i)
 
       ' --- OUT OF ---
       If outSon > sonrakiDt Then startDt = outSon Else startDt = sonrakiDt
       If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
       startDt = TatilAtla(startDt)
       If ucPinDt(i, 3) > 0 Then
           pinDt = ucPinDt(i, 3)
           If pinDt > startDt Then
               startDt = TatilAtla(pinDt)
               If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
           End If
       End If
       ucOutBasDt(i) = startDt
       bitDt = SaatEkle(startDt, ucOutSure(i))
       ucOutBitDt(i) = bitDt: outSon = bitDt
       sonrakiDt = bitDt
 
       ' --- LAY OFF ---
       If laySon > sonrakiDt Then startDt = laySon Else startDt = sonrakiDt
       If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
       startDt = TatilAtla(startDt)
       If ucPinDt(i, 4) > 0 Then
           pinDt = ucPinDt(i, 4)
           If pinDt > startDt Then
               startDt = TatilAtla(pinDt)
               If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
           End If
       End If
       ucLayBasDt(i) = startDt
       bitDt = SaatEkle(startDt, ucLaySure(i))
       ucLayBitDt(i) = bitDt: laySon = bitDt
       sonrakiDt = bitDt
 
       ' --- BOYA ---
       If boyaSon > sonrakiDt Then startDt = boyaSon Else startDt = sonrakiDt
       If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
       startDt = TatilAtla(startDt)
       If ucPinDt(i, 5) > 0 Then
           pinDt = ucPinDt(i, 5)
           If pinDt > startDt Then
               startDt = TatilAtla(pinDt)
               If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
           End If
       End If
       ucBoyaBasDt(i) = startDt
       bitDt = SaatEkle(startDt, ucBoyaSure(i))
       ucBoyaBitDt(i) = bitDt: boyaSon = bitDt
       sonrakiDt = bitDt
 
       ' --- SEALANT ---
       If sealSon > sonrakiDt Then startDt = sealSon Else startDt = sonrakiDt
       If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
       startDt = TatilAtla(startDt)
       If ucPinDt(i, 6) > 0 Then
           pinDt = ucPinDt(i, 6)
           If pinDt > startDt Then
               startDt = TatilAtla(pinDt)
               If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
           End If
       End If
       ucSealBasDt(i) = startDt
       bitDt = SaatEkle(startDt, ucSealSure(i))
       ucSealBitDt(i) = bitDt: sealSon = bitDt
       sonrakiDt = bitDt
 
       ' --- FINAL ---
       If finalSon > sonrakiDt Then startDt = finalSon Else startDt = sonrakiDt
       If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
       startDt = TatilAtla(startDt)
       If ucPinDt(i, 7) > 0 Then
           pinDt = ucPinDt(i, 7)
           If pinDt > startDt Then
               startDt = TatilAtla(pinDt)
               If HangiVardiya(startDt) = 0 Then startDt = SonrakiVardiyaBas(startDt)
           End If
       End If
       ucFinalBasDt(i) = startDt
       bitDt = SaatEkle(startDt, ucFinalSure(i))
       ucFinalBitDt(i) = bitDt: finalSon = bitDt
 
   Next i
End Sub
 
' ====================================================
' GORSEL OLUSTUR
' Her gun icin vardiyalara gore sutunlar olusturur
' Her vardiyadaki istasyon satirina: ucak no + bas-bit saat
' ====================================================
Sub GorselOlustur( _
   ucNo() As Long, ucDurus() As Double, _
   ucC1BasDt() As Double, ucC1BitDt() As Double, ucC1Hat() As Integer, _
   ucWinBasDt() As Double, ucWinBitDt() As Double, ucWinHat() As Integer, _
   ucMateBasDt() As Double, ucMateBitDt() As Double, ucMateHat() As Integer, _
   ucOutBasDt() As Double, ucOutBitDt() As Double, _
   ucLayBasDt() As Double, ucLayBitDt() As Double, _
   ucBoyaBasDt() As Double, ucBoyaBitDt() As Double, _
   ucSealBasDt() As Double, ucSealBitDt() As Double, _
   ucFinalBasDt() As Double, ucFinalBitDt() As Double, _
   ucDurusBasDt() As Double, ucDurusBitDt() As Double, _
   ucakSayisi As Long, aySayisi As Integer, enErkenDt As Double)
 
   Dim ws As Worksheet
   On Error Resume Next: Application.DisplayAlerts = False
   ThisWorkbook.Sheets("OtomatikPlan").Delete
   Application.DisplayAlerts = True: On Error GoTo 0
   Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   ws.Name = "OtomatikPlan": ws.Cells.Font.Name = "Calibri"
 
   ' Satir etiketleri
   Const DATA_SATIR As Integer = 17
   Dim satirEtiketler(1 To DATA_SATIR) As String
   Dim satirRenkler(1 To DATA_SATIR) As Long
   satirEtiketler(1) = "COJI 1 - Hat 1":    satirRenkler(1) = RGB(255, 255, 180)
   satirEtiketler(2) = "COJI 1 - Hat 2":    satirRenkler(2) = RGB(255, 255, 180)
   satirEtiketler(3) = "WINDSHIELD - Hat 1": satirRenkler(3) = RGB(180, 220, 255)
   satirEtiketler(4) = "WINDSHIELD - Hat 2": satirRenkler(4) = RGB(180, 220, 255)
   satirEtiketler(5) = "WINDSHIELD - Hat 3": satirRenkler(5) = RGB(180, 220, 255)
   satirEtiketler(6) = "WINDSHIELD - Hat 4": satirRenkler(6) = RGB(180, 220, 255)
   satirEtiketler(7) = "WINDSHIELD - Hat 5": satirRenkler(7) = RGB(180, 220, 255)
   satirEtiketler(8) = "MATE - Hat 1":       satirRenkler(8) = RGB(200, 255, 200)
   satirEtiketler(9) = "MATE - Hat 2":       satirRenkler(9) = RGB(200, 255, 200)
   satirEtiketler(10) = "MATE - Hat 3":      satirRenkler(10) = RGB(200, 255, 200)
   satirEtiketler(11) = "MATE - Hat 4":      satirRenkler(11) = RGB(200, 255, 200)
   satirEtiketler(12) = "MATE - Hat 5":      satirRenkler(12) = RGB(200, 255, 200)
   satirEtiketler(13) = "OUT OF":            satirRenkler(13) = RGB(255, 200, 160)
   satirEtiketler(14) = "LAY OFF":           satirRenkler(14) = RGB(220, 200, 255)
   satirEtiketler(15) = "BOYA":              satirRenkler(15) = RGB(255, 180, 180)
   satirEtiketler(16) = "SEALANT":           satirRenkler(16) = RGB(200, 240, 240)
   satirEtiketler(17) = "FINAL":             satirRenkler(17) = RGB(180, 255, 180)
 
   Const BLOK_YUK As Integer = 22  ' baslik 3 + data 17 + bosluk 2
   Dim mm As Integer, curAy As Integer, curYil As Integer
   Dim ayBas As Date, aySon As Date, gunSay As Long, baseRow As Long
   Dim col As Long, j As Long, dd As Date, ll As Integer
   Dim ui As Long, renk As Long
 
   For mm = 0 To aySayisi - 1
       curAy = Month(DtTarih(enErkenDt)) + mm
       curYil = Year(DtTarih(enErkenDt))
       Do While curAy > 12: curAy = curAy - 12: curYil = curYil + 1: Loop
       ayBas = DateSerial(curYil, curAy, 1)
       aySon = DateSerial(curYil, curAy + 1, 0)
       gunSay = Day(aySon)
       baseRow = 1 + mm * BLOK_YUK
 
       ' Ay etiketi
       ws.Range(ws.Cells(baseRow + 3, C_AYADI), ws.Cells(baseRow + 3 + DATA_SATIR - 1, C_AYADI)).Merge
       With ws.Cells(baseRow + 3, C_AYADI)
           .Value = AyAdi(curAy): .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
           .Orientation = 90: .Font.Bold = True: .Font.Size = 11
           .Font.Color = RGB(255, 255, 255): .Interior.Color = RGB(0, 80, 160)
       End With
       ws.Columns(C_AYADI).ColumnWidth = 3.5
 
       ' Satir etiketleri
       For ll = 1 To DATA_SATIR
           With ws.Cells(baseRow + 2 + ll, C_LABEL)
               .Value = satirEtiketler(ll): .Font.Bold = True: .Font.Size = 8
               .VerticalAlignment = xlCenter: .Interior.Color = satirRenkler(ll)
               .WrapText = False
           End With
       Next ll
       ws.Columns(C_LABEL).ColumnWidth = 18
 
       ' Her gun icin vardiya sutunlari olustur
       ' col = baslangic sutunu bu gun icin
       col = C_VERI
       For j = 0 To gunSay - 1
           dd = ayBas + j
           Dim vSayisi As Integer
 
           ' Tatil gunu mu?
           If TatilMi(dd) Then
               ' Tatil: tek sutun, gri
               ws.Cells(baseRow, col).Value = GunKisa(dd) & " " & Day(dd)
               ws.Cells(baseRow, col).Font.Size = 7: ws.Cells(baseRow, col).Font.Bold = True
               ws.Cells(baseRow, col).HorizontalAlignment = xlCenter
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col)).Interior.Color = RGB(215, 215, 215)
               If Weekday(dd, vbMonday) = 7 Then ws.Cells(baseRow, col).Font.Color = RGB(180, 0, 0)
               ws.Columns(col).ColumnWidth = 8
               col = col + 1
           Else
               ' Calisma gunu: her vardiya bir sutun
               vSayisi = gNormalVardiya
               ' Gun etiketi, vardiya sutunlarini kapsar
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow, col + vSayisi - 1)).Merge
               ws.Cells(baseRow, col).Value = GunKisa(dd) & " " & Day(dd)
               ws.Cells(baseRow, col).HorizontalAlignment = xlCenter
               ws.Cells(baseRow, col).Font.Size = 8: ws.Cells(baseRow, col).Font.Bold = True
 
               Dim v As Integer
               For v = 1 To vSayisi
                   Dim vCol As Long: vCol = col + v - 1
                   ' Vardiya basligi
                   ws.Cells(baseRow + 1, vCol).Value = "S" & v
                   ws.Cells(baseRow + 1, vCol).HorizontalAlignment = xlCenter
                   ws.Cells(baseRow + 1, vCol).Font.Size = 7: ws.Cells(baseRow + 1, vCol).Font.Bold = True
 
                   ' Vardiya saat araliği
                   Dim vBasStr As String, vBitStr As String
                   Select Case v
                       Case 1: vBasStr = "07:00": vBitStr = "15:00"
                       Case 2: vBasStr = "15:00": vBitStr = "23:00"
                       Case 3: vBasStr = "23:00": vBitStr = "07:00"
                   End Select
                   ws.Cells(baseRow + 2, vCol).Value = vBasStr & "-" & vBitStr
                   ws.Cells(baseRow + 2, vCol).HorizontalAlignment = xlCenter
                   ws.Cells(baseRow + 2, vCol).Font.Size = 6
 
                   ' Satir etiket renkleri
                   For ll = 1 To DATA_SATIR
                       ws.Cells(baseRow + 2 + ll, vCol).Interior.Color = satirRenkler(ll)
                   Next ll
 
                   ws.Columns(vCol).ColumnWidth = 12
               Next v
 
               ' Sinir cizgileri
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + vSayisi - 1)).Borders.LineStyle = xlContinuous
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + vSayisi - 1)).Borders.Weight = xlHairline
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + vSayisi - 1)).Borders.Color = RGB(180, 180, 180)
 
               col = col + vSayisi
           End If
       Next j
 
       ' Satir yukseklikleri
       ws.Rows(baseRow).RowHeight = 14
       ws.Rows(baseRow + 1).RowHeight = 14
       ws.Rows(baseRow + 2).RowHeight = 12
       For ll = 3 To 2 + DATA_SATIR: ws.Rows(baseRow + ll).RowHeight = 30: Next ll
 
       ' Her ucak icin hucreleri doldur
       For ui = 0 To ucakSayisi - 1
           renk = UcakRenk(ui)
           Call CizUcakSaat(ws, ucNo(ui), renk, _
               ucC1BasDt(ui), ucC1BitDt(ui), ucC1Hat(ui), _
               baseRow + 2 + 1, baseRow + 2 + 2, _
               ayBas, aySon, C_VERI)
 
           Call CizUcakSaat(ws, ucNo(ui), renk, _
               ucWinBasDt(ui), ucWinBitDt(ui), ucWinHat(ui), _
               baseRow + 2 + 3, baseRow + 2 + 7, _
               ayBas, aySon, C_VERI)
 
           Call CizUcakSaat(ws, ucNo(ui), renk, _
               ucMateBasDt(ui), ucMateBitDt(ui), ucMateHat(ui), _
               baseRow + 2 + 8, baseRow + 2 + 12, _
               ayBas, aySon, C_VERI)
 
           Call CizUcakSaatTekHat(ws, ucNo(ui), renk, ucOutBasDt(ui), ucOutBitDt(ui), baseRow + 15, ayBas, aySon, C_VERI)
           Call CizUcakSaatTekHat(ws, ucNo(ui), renk, ucLayBasDt(ui), ucLayBitDt(ui), baseRow + 16, ayBas, aySon, C_VERI)
           Call CizUcakSaatTekHat(ws, ucNo(ui), renk, ucBoyaBasDt(ui), ucBoyaBitDt(ui), baseRow + 17, ayBas, aySon, C_VERI)
           Call CizUcakSaatTekHat(ws, ucNo(ui), renk, ucSealBasDt(ui), ucSealBitDt(ui), baseRow + 18, ayBas, aySon, C_VERI)
           Call CizUcakSaatTekHat(ws, ucNo(ui), renk, ucFinalBasDt(ui), ucFinalBitDt(ui), baseRow + 19, ayBas, aySon, C_VERI)
 
           ' Durus
           If ucDurus(ui) > 0 Then
               Call CizDurusSaat(ws, ucDurusBasDt(ui), ucDurusBitDt(ui), ucC1Hat(ui), baseRow + 2 + 1, baseRow + 2 + 2, ayBas, aySon, C_VERI)
           End If
       Next ui
   Next mm
 
   ws.Activate: ws.Cells(1, C_VERI).Select: ActiveWindow.FreezePanes = True: ws.Cells(1, 1).Select
End Sub
 
' Cok hatli istasyon icin (COJI1, WINDSHIELD, MATE)
Sub CizUcakSaat(ws As Worksheet, ucakNo As Long, renk As Long, _
   basDt As Double, bitDt As Double, hatNo As Integer, _
   ilkSatir As Long, sonSatir As Long, _
   ayBas As Date, aySon As Date, veriBasSutun As Long)
 
   Dim satirNo As Long: satirNo = ilkSatir + hatNo - 1
   Call CizUcakSaatTekHat(ws, ucakNo, renk, basDt, bitDt, satirNo, ayBas, aySon, veriBasSutun)
End Sub
 
' Tek satira ucak bilgisi yaz
Sub CizUcakSaatTekHat(ws As Worksheet, ucakNo As Long, renk As Long, _
   basDt As Double, bitDt As Double, satirNo As Long, _
   ayBas As Date, aySon As Date, veriBasSutun As Long)
 
   ' Bu ay icindeki her gun ve vardiya icin kontrol et
   Dim dd As Date
   Dim gunSay As Long: gunSay = Day(DateSerial(Year(aySon), Month(aySon) + 1, 0))
   Dim col As Long: col = veriBasSutun
 
   Dim j As Long
   For j = 0 To gunSay - 1
       dd = ayBas + j
       If TatilMi(dd) Then
           col = col + 1
       Else
           Dim v As Integer
           For v = 1 To gNormalVardiya
               Dim vCol As Long: vCol = col + v - 1
               ' Bu vardiyanin DateTime araligini hesapla
               Dim vBasDt As Double, vBitDt As Double
               If v = 3 Then
                   vBasDt = CDbl(dd) + 23 * 60 / 1440#
                   vBitDt = CDbl(dd) + 1 + 7 * 60 / 1440#
               Else
                   vBasDt = CDbl(dd) + VardiyaBasDak(v) / 1440#
                   vBitDt = CDbl(dd) + VardiyaBitDak(v) / 1440#
               End If
 
               ' Ucak bu vardiyadaymi?
               If basDt < vBitDt And bitDt > vBasDt Then
                   ' Bu vardiyadaki baslangic ve bitis
                   Dim gosBas As Double: gosBas = IIf(basDt > vBasDt, basDt, vBasDt)
                   Dim gosBit As Double: gosBit = IIf(bitDt < vBitDt, bitDt, vBitDt)
 
                   ' Hucreye yaz: mevcut icerige ekle
                   Dim mevcutIcerik As String: mevcutIcerik = ""
                   If ws.Cells(satirNo, vCol).Value <> "" Then
                       mevcutIcerik = ws.Cells(satirNo, vCol).Value & Chr(10)
                   End If
                   ws.Cells(satirNo, vCol).Value = mevcutIcerik & ucakNo & " " & DtSaat(gosBas) & "-" & DtSaat(gosBit)
                   ws.Cells(satirNo, vCol).Interior.Color = renk
                   ws.Cells(satirNo, vCol).Font.Size = 7
                   ws.Cells(satirNo, vCol).Font.Bold = True
                   ws.Cells(satirNo, vCol).HorizontalAlignment = xlCenter
                   ws.Cells(satirNo, vCol).VerticalAlignment = xlCenter
                   ws.Cells(satirNo, vCol).WrapText = True
               End If
           Next v
           col = col + gNormalVardiya
       End If
   Next j
End Sub
 
Sub CizDurusSaat(ws As Worksheet, basDt As Double, bitDt As Double, hatNo As Integer, _
   ilkSatir As Long, sonSatir As Long, ayBas As Date, aySon As Date, veriBasSutun As Long)
 
   Dim satirNo As Long: satirNo = ilkSatir + hatNo - 1
   Dim gunSay As Long: gunSay = Day(DateSerial(Year(aySon), Month(aySon) + 1, 0))
   Dim col As Long: col = veriBasSutun
   Dim j As Long, dd As Date, v As Integer
 
   For j = 0 To gunSay - 1
       dd = ayBas + j
       If TatilMi(dd) Then
           col = col + 1
       Else
           For v = 1 To gNormalVardiya
               Dim vCol As Long: vCol = col + v - 1
               Dim vBasDt As Double, vBitDt As Double
               If v = 3 Then
                   vBasDt = CDbl(dd) + 23 * 60 / 1440#
                   vBitDt = CDbl(dd) + 1 + 7 * 60 / 1440#
               Else
                   vBasDt = CDbl(dd) + VardiyaBasDak(v) / 1440#
                   vBitDt = CDbl(dd) + VardiyaBitDak(v) / 1440#
               End If
               If basDt < vBitDt And bitDt > vBasDt Then
                   ws.Cells(satirNo, vCol).Interior.Color = RGB(30, 30, 30)
                   ws.Cells(satirNo, vCol).Value = "DURUS"
                   ws.Cells(satirNo, vCol).Font.Color = RGB(255, 255, 255)
                   ws.Cells(satirNo, vCol).Font.Size = 7
                   ws.Cells(satirNo, vCol).HorizontalAlignment = xlCenter
               End If
           Next v
           col = col + gNormalVardiya
       End If
   Next j
End Sub
 
' ====================================================
' AYARLAR KAYDET / OKU
' ====================================================
Sub AyarlariKaydet(c1BasDt As Double, c2BasDt As Double, aySayisi As Integer)
   Dim wsA As Worksheet
   On Error Resume Next: Application.DisplayAlerts = False
   ThisWorkbook.Sheets("Ayarlar").Delete
   Application.DisplayAlerts = True: On Error GoTo 0
   Set wsA = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   wsA.Name = "Ayarlar": wsA.Visible = xlSheetHidden
   wsA.Cells(1, 1).Value = gNormalVardiya
   wsA.Cells(1, 2).Value = gTatilSayisi
   wsA.Cells(1, 3).Value = c1BasDt
   wsA.Cells(1, 4).Value = c2BasDt
   wsA.Cells(1, 5).Value = aySayisi
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       wsA.Cells(tt + 2, 1).Value = CDbl(gTatilTarihBas(tt))
       wsA.Cells(tt + 2, 2).Value = CDbl(gTatilTarihBit(tt))
       If gTatilCalis(tt) Then wsA.Cells(tt + 2, 3).Value = 1 Else wsA.Cells(tt + 2, 3).Value = 0
   Next tt
End Sub
 
Function AyarlariOku() As Boolean
   On Error GoTo AyarYok
   Dim wsA As Worksheet: Set wsA = ThisWorkbook.Sheets("Ayarlar")
   gNormalVardiya = CInt(wsA.Cells(1, 1).Value)
   gTatilSayisi = CInt(wsA.Cells(1, 2).Value)
   Call TatilleriOlustur
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       gTatilCalis(tt) = (wsA.Cells(tt + 2, 3).Value = 1)
   Next tt
   AyarlariOku = True: Exit Function
AyarYok:
   AyarlariOku = False
End Function
 
Sub BaslangicBilgisiOku(ByRef c1BasDt As Double, ByRef c2BasDt As Double, ByRef aySayisi As Integer)
   Dim wsA As Worksheet: Set wsA = ThisWorkbook.Sheets("Ayarlar")
   c1BasDt = CDbl(wsA.Cells(1, 3).Value)
   c2BasDt = CDbl(wsA.Cells(1, 4).Value)
   aySayisi = CInt(wsA.Cells(1, 5).Value)
End Sub
 
' ====================================================
' PLAN DETAY KAYDET / OKU
' ====================================================
Sub PlanDetayKaydet( _
   ucNo() As Long, ucDurus() As Double, _
   ucC1Sure() As Double, ucWinSure() As Double, ucMateSure() As Double, _
   ucOutSure() As Double, ucLaySure() As Double, ucBoyaSure() As Double, _
   ucSealSure() As Double, ucFinalSure() As Double, _
   ucC1Hat() As Integer, ucC1BasDt() As Double, ucC1BitDt() As Double, _
   ucWinHat() As Integer, ucWinBasDt() As Double, ucWinBitDt() As Double, _
   ucMateHat() As Integer, ucMateBasDt() As Double, ucMateBitDt() As Double, _
   ucOutBasDt() As Double, ucOutBitDt() As Double, _
   ucLayBasDt() As Double, ucLayBitDt() As Double, _
   ucBoyaBasDt() As Double, ucBoyaBitDt() As Double, _
   ucSealBasDt() As Double, ucSealBitDt() As Double, _
   ucFinalBasDt() As Double, ucFinalBitDt() As Double, _
   ucakSayisi As Long, ucPinDt() As Double)
 
   Dim wsL As Worksheet
   On Error Resume Next: Application.DisplayAlerts = False
   ThisWorkbook.Sheets("PlanDetay").Delete
   Application.DisplayAlerts = True: On Error GoTo 0
   Set wsL = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   wsL.Name = "PlanDetay": wsL.Cells.Font.Name = "Calibri"
 
   Dim basliklar As Variant
   basliklar = Array("Ucak", "Durus(s)", "C1(s)", "Win(s)", "Mate(s)", "Out(s)", "Lay(s)", "Boya(s)", "Seal(s)", "Final(s)", _
                     "C1Hat", "C1Bas", "C1Bit", "WinHat", "WinBas", "WinBit", "MateHat", "MateBas", "MateBit", _
                     "OutBas", "OutBit", "LayBas", "LayBit", "BoyaBas", "BoyaBit", "SealBas", "SealBit", "FinalBas", "FinalBit", _
                     "PinC1", "PinWin", "PinMate", "PinOut", "PinLay", "PinBoya", "PinSeal", "PinFinal")
   Dim k As Integer
   For k = 0 To UBound(basliklar)
       wsL.Cells(1, k + 1).Value = basliklar(k)
   Next k
   wsL.Range(wsL.Cells(1, 1), wsL.Cells(1, UBound(basliklar) + 1)).Font.Bold = True
   wsL.Range(wsL.Cells(1, 1), wsL.Cells(1, UBound(basliklar) + 1)).Interior.Color = RGB(0, 80, 160)
   wsL.Range(wsL.Cells(1, 1), wsL.Cells(1, UBound(basliklar) + 1)).Font.Color = RGB(255, 255, 255)
 
   Dim fmt As String: fmt = "DD.MM.YYYY HH:MM"
   Dim i As Long
   For i = 0 To ucakSayisi - 1
       Dim r As Long: r = i + 2
       wsL.Cells(r, 1).Value = ucNo(i)
       wsL.Cells(r, 2).Value = ucDurus(i)
       wsL.Cells(r, 3).Value = ucC1Sure(i)
       wsL.Cells(r, 4).Value = ucWinSure(i)
       wsL.Cells(r, 5).Value = ucMateSure(i)
       wsL.Cells(r, 6).Value = ucOutSure(i)
       wsL.Cells(r, 7).Value = ucLaySure(i)
       wsL.Cells(r, 8).Value = ucBoyaSure(i)
