' ====================================================
' DATETIME GIRISI YARDIMCISI
' ====================================================
Function TarihSaatGir(mesaj As String, varsayilan As String) As Double
   Dim girdi As String
   girdi = InputBox(mesaj & vbCrLf & "(Ornek: 01.04.2026 07:00)", "Tarih ve Saat", varsayilan)
   If girdi = "" Then TarihSaatGir = -1: Exit Function
   On Error GoTo HataTS
   ' Tarih ve saati ayir
   Dim parcalar() As String: parcalar = Split(Trim(girdi), " ")
   Dim tarihKismi As Date: tarihKismi = CDate(parcalar(0))
   Dim saatKismi As Double: saatKismi = 0
   If UBound(parcalar) >= 1 Then
       Dim saatParcalar() As String: saatParcalar = Split(parcalar(1), ":")
       saatKismi = (CDbl(saatParcalar(0)) * 60 + CDbl(saatParcalar(1))) / 1440#
   End If
   TarihSaatGir = CDbl(tarihKismi) + saatKismi
   Exit Function
HataTS:
   MsgBox "Gecersiz format! Ornek: 01.04.2026 07:00", vbExclamation
   TarihSaatGir = -1
End Function
 
