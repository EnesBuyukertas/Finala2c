Sub PinOku(ucPinDt() As Double, ucakSayisi As Long)
   ReDim ucPinDt(0 To ucakSayisi - 1, 0 To 7)
   Dim wsP As Worksheet
   On Error Resume Next: Set wsP = ThisWorkbook.Sheets("PlanDetay"): On Error GoTo 0
   If wsP Is Nothing Then Exit Sub
   Dim i As Long, adm As Integer
   For i = 0 To ucakSayisi - 1
       For adm = 0 To 7
           Dim pv As Variant: pv = wsP.Cells(i + 2, 30 + adm).Value
           If IsNumeric(pv) Then
               If CDbl(pv) > 0 Then ucPinDt(i, adm) = CDbl(pv)
           End If
       Next adm
   Next i
End Sub
 
