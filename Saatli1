' ====================================================
' MAKRO 4: STEP TARIH DEGISIMI
' ====================================================
Sub StepTarihDegisimi()
   On Error GoTo Hata4
   If Not AyarlariOku() Then MsgBox "Once UretimPlaniOlustur calistirin!", vbExclamation: Exit Sub
 
   Dim wsP As Worksheet: Set wsP = ThisWorkbook.Sheets("PlanDetay")
   Dim ucakSayisi As Long: ucakSayisi = wsP.Cells(wsP.Rows.Count, 1).End(xlUp).Row - 1
   If ucakSayisi < 1 Then MsgBox "PlanDetay bos!", vbExclamation: Exit Sub
 
   Dim hedefUcak As Long: hedefUcak = CLng(InputBox("Ucak numarasi:", "Step Tarih Degisimi"))
   Dim hedefIdx As Long: hedefIdx = -1
   Dim i As Long
   For i = 0 To ucakSayisi - 1
       If CLng(wsP.Cells(i + 2, 1).Value) = hedefUcak Then hedefIdx = i: Exit For
   Next i
   If hedefIdx = -1 Then MsgBox "Ucak bulunamadi!", vbExclamation: Exit Sub
 
   Dim adimAdlari(1 To 8) As String
   adimAdlari(1) = "COJI 1": adimAdlari(2) = "WINDSHIELD": adimAdlari(3) = "MATE"
   adimAdlari(4) = "OUT OF": adimAdlari(5) = "LAY OFF":    adimAdlari(6) = "BOYA"
   adimAdlari(7) = "SEALANT": adimAdlari(8) = "FINAL"
 
   Dim adimStr As String
   adimStr = InputBox("Hangi adim?" & vbCrLf & _
                      "1=COJI1  2=WINDSHIELD  3=MATE" & vbCrLf & _
                      "4=OUT OF  5=LAY OFF  6=BOYA  7=SEALANT  8=FINAL", "Step Tarih Degisimi", "1")
   Dim adimNo As Integer: adimNo = CInt(adimStr)
   If adimNo < 1 Or adimNo > 8 Then MsgBox "Gecersiz adim!", vbExclamation: Exit Sub
 
   ' Mevcut pin varsa goster
   Dim mevcutPin As String: mevcutPin = Format(Now, "DD.MM.YYYY HH:MM")
   Dim pvMevcut As Variant: pvMevcut = wsP.Cells(hedefIdx + 2, 29 + adimNo).Value
   If IsNumeric(pvMevcut) And CDbl(pvMevcut) > 0 Then
       mevcutPin = Format(CDate(pvMevcut), "DD.MM.YYYY HH:MM")
   End If
 
   Dim yeniDt As Double
   yeniDt = TarihSaatGir("Ucak " & hedefUcak & " - " & adimAdlari(adimNo) & vbCrLf & _
                          "Yeni baslangic (bos birak = sabitlemeyi kaldir):", mevcutPin)
 
   ' Tum verileri oku
   Dim ucNo() As Long, ucDurus() As Double
   Dim ucC1Sure() As Double, ucWinSure() As Double, ucMateSure() As Double
   Dim ucOutSure() As Double, ucLaySure() As Double, ucBoyaSure() As Double
   Dim ucSealSure() As Double, ucFinalSure() As Double
   ReDim ucNo(0 To ucakSayisi - 1):      ReDim ucDurus(0 To ucakSayisi - 1)
   ReDim ucC1Sure(0 To ucakSayisi - 1):  ReDim ucWinSure(0 To ucakSayisi - 1)
   ReDim ucMateSure(0 To ucakSayisi - 1):ReDim ucOutSure(0 To ucakSayisi - 1)
   ReDim ucLaySure(0 To ucakSayisi - 1): ReDim ucBoyaSure(0 To ucakSayisi - 1)
   ReDim ucSealSure(0 To ucakSayisi - 1):ReDim ucFinalSure(0 To ucakSayisi - 1)
   Call PlanDetayOku(ucNo, ucDurus, ucC1Sure, ucWinSure, ucMateSure, ucOutSure, ucLaySure, ucBoyaSure, ucSealSure, ucFinalSure, ucakSayisi)
 
   ' Mevcut pinleri oku (PlanDetay silinmeden once!)
   Dim ucPinDt() As Double
   Call PinOku(ucPinDt, ucakSayisi)
 
   ' Yeni pin degerini diziye yaz
   If yeniDt < 0 Then
       ucPinDt(hedefIdx, adimNo - 1) = 0  ' Sabitlemeyi kaldir
   Else
       ucPinDt(hedefIdx, adimNo - 1) = yeniDt
   End If
 
   Application.ScreenUpdating = False
   Call GuncelleVeCiz(ucNo, ucDurus, ucC1Sure, ucWinSure, ucMateSure, ucOutSure, ucLaySure, ucBoyaSure, ucSealSure, ucFinalSure, ucakSayisi)
 
   ' Pin bilgilerini PlanDetay'a tekrar yaz (GuncelleVeCiz PinOku'yu cagiriyor ama biz zaten ucPinDt'yi duzelttik)
   ' GuncelleVeCiz icindeki PinOku yeni PlanDetay'dan okuyacak, o yuzden
   ' PlanDetayKaydet'ten sonra pin'leri guncelle
   Dim wsP2 As Worksheet: Set wsP2 = ThisWorkbook.Sheets("PlanDetay")
   Dim adm As Integer
   For adm = 0 To 7
       If ucPinDt(hedefIdx, adm) > 0 Then
           wsP2.Cells(hedefIdx + 2, 30 + adm).Value = ucPinDt(hedefIdx, adm)
           wsP2.Cells(hedefIdx + 2, 30 + adm).NumberFormat = "DD.MM.YYYY HH:MM"
           wsP2.Cells(hedefIdx + 2, 30 + adm).Interior.Color = RGB(255, 220, 150)
       Else
           wsP2.Cells(hedefIdx + 2, 30 + adm).Value = 0
           wsP2.Cells(hedefIdx + 2, 30 + adm).Interior.ColorIndex = xlNone
       End If
   Next adm
 
   Application.ScreenUpdating = True
   If yeniDt < 0 Then
       MsgBox "Sabitleme kaldirildi!", vbInformation
   Else
       MsgBox "Ucak " & hedefUcak & " - " & adimAdlari(adimNo) & " baslangici " & Format(CDate(Int(yeniDt)), "DD.MM.YYYY") & " " & DtSaat(yeniDt) & " olarak sabitlendi!", vbInformation
   End If
   Exit Sub
Hata4:
   Application.ScreenUpdating = True
   MsgBox "Hata: " & Err.Description, vbCritical
End Sub
