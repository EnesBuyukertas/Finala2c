' ====================================================
Sub HaftalikPlan()
   On Error GoTo Hata
   If gPlanUcakSayisi = 0 Then MsgBox "Once PlanOlustur calistirin!", vbExclamation: Exit Sub
 
   Dim basStr As String: basStr = InputBox("Baslangic tarihi (GG.AA.YYYY):", "Haftalik Plan", Format(Date, "DD.MM.YYYY"))
   If basStr = "" Then Exit Sub
   Dim bitStr As String: bitStr = InputBox("Bitis tarihi (GG.AA.YYYY):", "Haftalik Plan", Format(Date + 6, "DD.MM.YYYY"))
   If bitStr = "" Then Exit Sub
   Dim basTarihH As Date: basTarihH = CDate(basStr)
   Dim bitTarihH As Date: bitTarihH = CDate(bitStr)
   Dim gunSayisiH As Long: gunSayisiH = CLng(bitTarihH - basTarihH) + 1
 
   Application.ScreenUpdating = False
   Dim ws As Worksheet
   Application.DisplayAlerts = False
   On Error Resume Next: ThisWorkbook.Sheets("HaftalikPlan").Delete: On Error GoTo Hata
   Application.DisplayAlerts = True
   Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   ws.Name = "HaftalikPlan": ws.Cells.Font.Name = "Calibri"
 
   ' Istasyon ve hat tanimlari
   Dim ist_adlari(0 To 7) As String
   ist_adlari(0) = "COJI 1": ist_adlari(1) = "COJI 2 WINDSHIELD"
   ist_adlari(2) = "COJI 2 MATE": ist_adlari(3) = "OUT OF COJI"
   ist_adlari(4) = "LAY OFF": ist_adlari(5) = "BOYA"
   ist_adlari(6) = "SEALANT": ist_adlari(7) = "FINAL"
   Dim ist_hatlar(0 To 7) As Integer
   ist_hatlar(0) = 2: ist_hatlar(1) = 5: ist_hatlar(2) = 5
   ist_hatlar(3) = 1: ist_hatlar(4) = 1: ist_hatlar(5) = 1
   ist_hatlar(6) = 1: ist_hatlar(7) = 1
 
   Dim renklerH(0 To 19) As String
   renklerH(0) = "FFD700": renklerH(1) = "87CEEB": renklerH(2) = "90EE90"
   renklerH(3) = "FFB6C1": renklerH(4) = "DDA0DD": renklerH(5) = "F0E68C"
   renklerH(6) = "98FB98": renklerH(7) = "87CEFA": renklerH(8) = "FFA07A"
   renklerH(9) = "20B2AA": renklerH(10) = "FF6347": renklerH(11) = "4169E1"
   renklerH(12) = "32CD32": renklerH(13) = "FF69B4": renklerH(14) = "9370DB"
   renklerH(15) = "00CED1": renklerH(16) = "FF8C00": renklerH(17) = "8B4513"
   renklerH(18) = "2E8B57": renklerH(19) = "DC143C"
 
   Dim gunAdlariH(0 To 6) As String
   gunAdlariH(0) = "Pzt": gunAdlariH(1) = "Sal": gunAdlariH(2) = "Car"
   gunAdlariH(3) = "Per": gunAdlariH(4) = "Cum": gunAdlariH(5) = "Cmt": gunAdlariH(6) = "Paz"
 
   ' Sutun yapisi: A=Istasyon/Hat, B+= Her gun x vardiya
   Const IST_COL_H As Integer = 1
   Const GUN_BAS_COL_H As Integer = 2
   ws.Columns(IST_COL_H).ColumnWidth = 24
 
   ' Baslik satiri 1
   Dim toplamSutun As Long: toplamSutun = GUN_BAS_COL_H + gunSayisiH * gNormalVardiya - 1
   ws.Range(ws.Cells(1, 1), ws.Cells(1, toplamSutun)).Merge
   With ws.Cells(1, 1)
       .Value = Format(basTarihH, "DD.MM.YYYY") & " - " & Format(bitTarihH, "DD.MM.YYYY") & " HAFTALIK PLAN"
       .Font.Bold = True: .Font.Size = 13: .Font.Color = RGB(255, 255, 255)
       .Interior.Color = RGB(31, 78, 121): .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
   End With
   ws.Rows(1).RowHeight = 28
 
   ' Gun ve vardiya baslikları
   Dim hcol As Long: hcol = GUN_BAS_COL_H
   Dim gun_idx As Long
   For gun_idx = 0 To gunSayisiH - 1
       Dim dd As Date: dd = basTarihH + gun_idx
       Dim gun_adi As String: gun_adi = gunAdlariH(Weekday(dd, vbMonday) - 1)
       Dim gunIdxPlan As Long: gunIdxPlan = CLng(dd - gPlanBasTarih)
       Dim is_tatil As Boolean: is_tatil = TatilMiGun(gunIdxPlan, gPlanBasTarih)
       Dim aktifV As Integer: aktifV = GunVardiyaSayisi(gunIdxPlan, gPlanBasTarih)
       Dim v As Integer
       For v = 1 To gNormalVardiya
           Dim vBas As Double: vBas = VardiyaBas(v)
           Dim vBitVal As Double: vBitVal = VardiyaBit(v)
           Dim vBitG As Double: If vBitVal >= 24 Then vBitG = vBitVal - 24 Else vBitG = vBitVal
           With ws.Cells(2, hcol)
               .Value = gun_adi & " " & Format(dd, "DD.MM") & Chr(10) & _
                        "S" & v & " " & SaatFormat(vBas) & "-" & SaatFormat(vBitG)
               .Font.Bold = True: .Font.Size = 8: .Font.Color = RGB(255, 255, 255)
               .WrapText = True: .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
               If is_tatil Or v > aktifV Then
                   .Interior.Color = RGB(160, 160, 160)
               Else
                   Select Case v
                       Case 1: .Interior.Color = RGB(31, 78, 121)
                       Case 2: .Interior.Color = RGB(55, 86, 35)
                       Case 3: .Interior.Color = RGB(112, 48, 160)
                   End Select
               End If
           End With
           ws.Columns(hcol).ColumnWidth = 22
           hcol = hcol + 1
       Next v
   Next gun_idx
   ws.Rows(2).RowHeight = 36
 
   ' Istasyon satirlari olustur ve plani doldur
   Dim mevcut_satir As Long: mevcut_satir = 3
   Dim ist_idx As Integer, hat_no As Integer
 
   For ist_idx = 0 To 7
       For hat_no = 1 To ist_hatlar(ist_idx)
           Dim hat_label As String
           If ist_hatlar(ist_idx) > 1 Then
               hat_label = ist_adlari(ist_idx) & " - Hat " & hat_no
           Else
               hat_label = ist_adlari(ist_idx)
           End If
           With ws.Cells(mevcut_satir, IST_COL_H)
               .Value = hat_label: .Font.Bold = True: .Font.Size = 9
               .Font.Color = RGB(255, 255, 255): .Interior.Color = RGB(46, 64, 87)
               .VerticalAlignment = xlCenter
               .Borders.LineStyle = xlContinuous: .Borders.Weight = xlThin
           End With
 
           ' Her gun ve vardiya icin veri doldur
           Dim col As Long: col = GUN_BAS_COL_H
           For gun_idx = 0 To gunSayisiH - 1
               dd = basTarihH + gun_idx
               gunIdxPlan = CLng(dd - gPlanBasTarih)
               is_tatil = TatilMiGun(gunIdxPlan, gPlanBasTarih)
               aktifV = GunVardiyaSayisi(gunIdxPlan, gPlanBasTarih)
 
               For v = 1 To gNormalVardiya
                   Dim vBasDtH As Double: vBasDtH = CDbl(gunIdxPlan) + VardiyaBas(v) / 24#
                   Dim vBitDtH As Double: vBitDtH = CDbl(gunIdxPlan) + VardiyaBit(v) / 24#
 
                   Dim hucreMetin As String: hucreMetin = ""
                   Dim hucreRenk As String: hucreRenk = ""
 
                   If Not is_tatil And v <= aktifV Then
                       Dim ui2 As Long, ki2 As Long
                       For ui2 = 0 To gPlanUcakSayisi - 1
                           For ki2 = 0 To A2C_MAX_KAYIT - 1
                               If gPlanVerisi(ui2, ki2, 0) = -1 Then Exit For
                               Dim p_ist As Integer: p_ist = CInt(gPlanVerisi(ui2, ki2, 0))
                               Dim p_hat As Integer: p_hat = CInt(gPlanVerisi(ui2, ki2, 1))
                               If p_ist <> ist_idx Or p_hat <> hat_no Then GoTo sonraki_kayit_h
                               Dim opBasDtH As Double: opBasDtH = CDbl(gPlanVerisi(ui2, ki2, 3)) + CDbl(gPlanVerisi(ui2, ki2, 4)) / 24#
                               Dim opBitDtH As Double: opBitDtH = CDbl(gPlanVerisi(ui2, ki2, 5)) + CDbl(gPlanVerisi(ui2, ki2, 6)) / 24#
                               If opBasDtH < vBitDtH And opBitDtH > vBasDtH Then
                                   Dim gosBas As Double: If opBasDtH > vBasDtH Then gosBas = opBasDtH Else gosBas = vBasDtH
                                   Dim gosBit As Double: If opBitDtH < vBitDtH Then gosBit = opBitDtH Else gosBit = vBitDtH
                                   Dim gosBasSaat As Double: gosBasSaat = (gosBas - Int(gosBas)) * 24#
                                   Dim gosBitSaat As Double: gosBitSaat = (gosBit - Int(gosBit)) * 24#
                                   Dim ucakNo As Long: ucakNo = gPlanIlkUcak + ui2
                                   If hucreMetin = "" Then
                                       hucreMetin = ucakNo & " " & SaatFormat(gosBasSaat) & "-" & SaatFormat(gosBitSaat)
                                   Else
                                       hucreMetin = hucreMetin & Chr(10) & ucakNo & " " & SaatFormat(gosBasSaat) & "-" & SaatFormat(gosBitSaat)
                                   End If
                                   hucreRenk = renklerH(ui2 Mod 20)
                                   GoTo yazHucre
                               End If
sonraki_kayit_h:
                           Next ki2
                       Next ui2
                   End If
 
yazHucre:
                   With ws.Cells(mevcut_satir, col)
                       If hucreMetin <> "" Then
                           .Value = hucreMetin
                           Dim rHH As Long: rHH = CLng("&H" & Left(hucreRenk, 2))
                           Dim gHH As Long: gHH = CLng("&H" & Mid(hucreRenk, 3, 2))
                           Dim bHH As Long: bHH = CLng("&H" & Right(hucreRenk, 2))
                           .Interior.Color = RGB(rHH, gHH, bHH)
                           .Font.Bold = True: .Font.Size = 8: .WrapText = True
                       ElseIf is_tatil Or v > aktifV Then
                           .Interior.Color = RGB(215, 215, 215)
                       End If
                       .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
                       .Borders.LineStyle = xlContinuous
                       .Borders.Weight = xlHairline
                       .Borders.Color = RGB(180, 180, 180)
                   End With
                   col = col + 1
               Next v
           Next gun_idx
 
           ws.Rows(mevcut_satir).RowHeight = 36
           mevcut_satir = mevcut_satir + 1
       Next hat_no
   Next ist_idx
 
   ws.Cells(1, 1).Select
   Application.ScreenUpdating = True
   MsgBox "Haftalik plan olusturuldu!", vbInformation
   Exit Sub
Hata:
   Application.ScreenUpdating = True
   MsgBox "Hata: " & Err.Description, vbCritical
End Sub
 
