' ====================================================
' SAAT FORMAT
' ====================================================
Function SaatFormat(s As Double) As String
   Dim toplamDakika As Long
   toplamDakika = CLng(s * 60 + 0.5)
   Dim saat As Integer: saat = CInt(toplamDakika \ 60) Mod 24
   Dim dakika As Integer: dakika = CInt(toplamDakika Mod 60)
   SaatFormat = Format(saat, "00") & ":" & Format(dakika, "00")
End Function
 
' ====================================================
' VARDIYA FONKSIYONLARI
' ====================================================
Function VardiyaBas(vNo As Integer) As Double
   Select Case vNo
       Case 1: VardiyaBas = 7#
       Case 2: VardiyaBas = 15#
       Case 3: VardiyaBas = 23#
       Case Else: VardiyaBas = 7#
   End Select
End Function
 
Function VardiyaBit(vNo As Integer) As Double
   Select Case vNo
       Case 1: VardiyaBit = 15#
       Case 2: VardiyaBit = 23#
       Case 3: VardiyaBit = 31#
       Case Else: VardiyaBit = 15#
   End Select
End Function
 
Function VardiyaMolaBas(vNo As Integer) As Double
   Select Case vNo
       Case 1: VardiyaMolaBas = 11.5
       Case 2: VardiyaMolaBas = 18#
       Case 3: VardiyaMolaBas = 26#
       Case Else: VardiyaMolaBas = 11.5
   End Select
End Function
 
Function VardiyaMolaBit(vNo As Integer) As Double
   Select Case vNo
       Case 1: VardiyaMolaBit = 12.5
       Case 2: VardiyaMolaBit = 19#
       Case 3: VardiyaMolaBit = 27#
       Case Else: VardiyaMolaBit = 12.5
   End Select
End Function
 
Function GunVardiyaSayisi(gunIdx As Long, basTarih As Date) As Integer
   Dim dd As Date: dd = basTarih + gunIdx
   Dim hw As Integer: hw = Weekday(dd, vbMonday)
   Select Case hw
       Case 6
           If gCumartesiCalisiyorMu Then
               GunVardiyaSayisi = gCumartesiVardiya
           Else
               GunVardiyaSayisi = 0
           End If
       Case 7
           If gPazarCalisiyorMu Then
               GunVardiyaSayisi = gPazarVardiya
           Else
               GunVardiyaSayisi = 0
           End If
       Case Else
           GunVardiyaSayisi = gNormalVardiya
   End Select
End Function
 
Function HangiVardiyaGun(saatOfDay As Double, gunIdx As Long, basTarih As Date) As Integer
   Dim gv As Integer: gv = GunVardiyaSayisi(gunIdx, basTarih)
   If gv <= 0 Then HangiVardiyaGun = 0: Exit Function
   Dim s As Double: s = saatOfDay
   If s >= 23# Or s < 7# Then
       If gv >= 3 Then HangiVardiyaGun = 3: Exit Function
   End If
   If s >= 7# And s < 15# Then
       If gv >= 1 Then HangiVardiyaGun = 1: Exit Function
   End If
   If s >= 15# And s < 23# Then
       If gv >= 2 Then HangiVardiyaGun = 2: Exit Function
   End If
   HangiVardiyaGun = 0
End Function
 
Function TatilMiGun(gunIdx As Long, basTarih As Date) As Boolean
   Dim dd As Date: dd = basTarih + gunIdx
   Dim hw As Integer: hw = Weekday(dd, vbMonday)
   TatilMiGun = False
   If hw = 6 Then
       If Not gCumartesiCalisiyorMu Then TatilMiGun = True: Exit Function
   End If
   If hw = 7 Then
       If Not gPazarCalisiyorMu Then TatilMiGun = True: Exit Function
   End If
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       If dd = gTatilGunler(tt) And Not gTatilCalisiyorMu(tt) Then
           TatilMiGun = True: Exit Function
       End If
   Next tt
End Function
 
Sub IlkUygunZaman(ByRef gun As Long, ByRef saat As Double, basTarih As Date)
   Do While TatilMiGun(gun, basTarih)
       gun = gun + 1: saat = VardiyaBas(1)
   Loop
   Dim gv As Integer: gv = GunVardiyaSayisi(gun, basTarih)
   Dim v As Integer: v = HangiVardiyaGun(saat, gun, basTarih)
   If v = 0 Then
       Dim sonV As Double: sonV = -1
       Dim vv As Integer
       For vv = 1 To gv
           If VardiyaBas(vv) > saat Then sonV = VardiyaBas(vv): Exit For
       Next vv
       If sonV < 0 Then
           gun = gun + 1
           Do While TatilMiGun(gun, basTarih): gun = gun + 1: Loop
           saat = VardiyaBas(1)
       Else
           saat = sonV
       End If
   End If
   v = HangiVardiyaGun(saat, gun, basTarih)
   If v > 0 Then
       If saat >= VardiyaMolaBas(v) And saat < VardiyaMolaBit(v) Then
           saat = VardiyaMolaBit(v)
       End If
   End If
End Sub
 
Sub SaatEkle(ByRef gun As Long, ByRef saat As Double, netSaat As Double, basTarih As Date)
   Dim kalan As Double: kalan = netSaat
   Dim guvenlik As Long: guvenlik = 0
   Do While kalan > 0.0001
       guvenlik = guvenlik + 1
       If guvenlik > 500000 Then Exit Do
       Do While TatilMiGun(gun, basTarih)
           gun = gun + 1: saat = VardiyaBas(1)
       Loop
       Dim gv As Integer: gv = GunVardiyaSayisi(gun, basTarih)
       Dim v As Integer: v = HangiVardiyaGun(saat, gun, basTarih)
       If v = 0 Then
           Dim sonV As Double: sonV = -1
           Dim vv As Integer
           For vv = 1 To gv
               If VardiyaBas(vv) > saat Then sonV = VardiyaBas(vv): Exit For
           Next vv
           If sonV < 0 Then
               gun = gun + 1
               Do While TatilMiGun(gun, basTarih): gun = gun + 1: Loop
               saat = VardiyaBas(1)
           Else
               saat = sonV
           End If
       Else
           Dim vMolaBas As Double: vMolaBas = VardiyaMolaBas(v)
           Dim vMolaBit As Double: vMolaBit = VardiyaMolaBit(v)
           Dim vBit As Double: vBit = VardiyaBit(v)
           If saat >= vMolaBas And saat < vMolaBit Then
               saat = vMolaBit
           ElseIf saat < vMolaBas Then
               Dim molayaKadar As Double: molayaKadar = vMolaBas - saat
               Dim molaSonrasi As Double: molaSonrasi = vBit - vMolaBit
               Dim topNetV As Double: topNetV = molayaKadar + molaSonrasi
               If kalan <= molayaKadar Then
                   saat = saat + kalan: kalan = 0
               ElseIf kalan <= topNetV Then
                   kalan = kalan - molayaKadar
                   saat = vMolaBit + kalan: kalan = 0
               Else
                   kalan = kalan - topNetV
                   If v < gv Then
                       saat = VardiyaBas(v + 1)
                   Else
                       gun = gun + 1
                       Do While TatilMiGun(gun, basTarih): gun = gun + 1: Loop
                       saat = VardiyaBas(1)
                   End If
               End If
           Else
               Dim kalanV As Double: kalanV = vBit - saat
               If kalanV <= 0 Then
                   If v < gv Then
                       saat = VardiyaBas(v + 1)
                   Else
                       gun = gun + 1
                       Do While TatilMiGun(gun, basTarih): gun = gun + 1: Loop
                       saat = VardiyaBas(1)
                   End If
               ElseIf kalan <= kalanV Then
                   saat = saat + kalan: kalan = 0
               Else
                   kalan = kalan - kalanV
                   If v < gv Then
                       saat = VardiyaBas(v + 1)
                   Else
                       gun = gun + 1
                       Do While TatilMiGun(gun, basTarih): gun = gun + 1: Loop
                       saat = VardiyaBas(1)
                   End If
               End If
           End If
       End If
   Loop
End Sub
 
