Sub A2C_PlanDetayOlusturVeyaGuncelle(ilkUcak As Long, ucakSayisi As Long)
   Dim ws As Worksheet
   If Not A2C_SheetVarMi("PlanDetay") Then
       Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
       ws.Name = "PlanDetay": ws.Cells.Font.Name = "Calibri"
   Else
       Set ws = ThisWorkbook.Sheets("PlanDetay")
       ws.Cells.Clear
   End If
   ' Baslik yaz
   Call A2C_PlanDetayBaslikYaz(ws)
   ' Yeni ucaklar icin satir ekle
   Dim i As Long, ucakNo As Long, c As Long
   For i = 0 To ucakSayisi - 1
       ucakNo = ilkUcak + i
       Dim yeniSatir As Long: yeniSatir = i + 2
       ws.Cells(yeniSatir, 1).Value = ucakNo
       ws.Cells(yeniSatir, 2).Value = 0
       For c = 3 To 18: ws.Cells(yeniSatir, c).Value = 0: Next c
   Next i
   ws.Columns("A:AK").AutoFit
End Sub
 
Sub A2C_DetayOku(ilkUcak As Long, ucakSayisi As Long, _
   durusSaat() As Double, ekSaat() As Double, pinTarih() As Double)
   Dim ws As Worksheet: Set ws = ThisWorkbook.Sheets("PlanDetay")
   ReDim durusSaat(0 To ucakSayisi - 1)
   ReDim ekSaat(0 To ucakSayisi - 1, 0 To A2C_STAGE_COUNT - 1)
   ReDim pinTarih(0 To ucakSayisi - 1, 0 To A2C_STAGE_COUNT - 1)
   Dim i As Long, s As Integer, ucakNo As Long, r As Long
   Dim v As Variant
   For i = 0 To ucakSayisi - 1
       ucakNo = ilkUcak + i
       r = A2C_UcakSatiriBul(ws, ucakNo)
       If r > 0 Then
           If IsNumeric(ws.Cells(r, 2).Value) Then durusSaat(i) = CDbl(ws.Cells(r, 2).Value)
           For s = 0 To A2C_STAGE_COUNT - 1
               If IsNumeric(ws.Cells(r, 3 + s).Value) Then ekSaat(i, s) = CDbl(ws.Cells(r, 3 + s).Value)
               v = ws.Cells(r, 11 + s).Value
               If IsDate(v) Then
                   pinTarih(i, s) = CDbl(CDate(v))
               ElseIf IsNumeric(v) Then
                   If CDbl(v) > 0 Then pinTarih(i, s) = CDbl(v)
               End If
           Next s
       End If
   Next i
End Sub
 
Sub A2C_PlanDetaySonuclariYaz(plan() As Variant, ilkUcak As Long, ucakSayisi As Long, basTarih As Date)
   If Not A2C_SheetVarMi("PlanDetay") Then Exit Sub
   Dim ws As Worksheet: Set ws = ThisWorkbook.Sheets("PlanDetay")
   Dim ui As Long, ki As Long, ucakNo As Long, r As Long
   Dim pIst As Integer, pHat As Integer, pBasG As Long, pBitG As Long
   Dim pBasS As Double, pBitS As Double
   For ui = 0 To ucakSayisi - 1
       ucakNo = ilkUcak + ui
       r = A2C_UcakSatiriBul(ws, ucakNo)
       If r = 0 Then GoTo sonrakiUcak
       ws.Range(ws.Cells(r, 19), ws.Cells(r, 37)).ClearContents
       For ki = 0 To A2C_MAX_KAYIT - 1
           If plan(ui, ki, 0) = -1 Then Exit For
           pIst = CInt(plan(ui, ki, 0)): pHat = CInt(plan(ui, ki, 1))
           pBasG = CLng(plan(ui, ki, 3)): pBasS = CDbl(plan(ui, ki, 4))
           pBitG = CLng(plan(ui, ki, 5)): pBitS = CDbl(plan(ui, ki, 6))
           Dim basDt As Date: basDt = A2C_DateTimeYaz(basTarih, pBasG, pBasS)
           Dim bitDt As Date: bitDt = A2C_DateTimeYaz(basTarih, pBitG, pBitS)
           Select Case pIst
               Case 0
                   If ws.Cells(r, 20).Value = "" Then
                       ws.Cells(r, 19).Value = pHat
                       ws.Cells(r, 20).Value = basDt: ws.Cells(r, 20).NumberFormat = "DD.MM.YYYY HH:MM"
                   End If
                   ws.Cells(r, 21).Value = bitDt: ws.Cells(r, 21).NumberFormat = "DD.MM.YYYY HH:MM"
               Case 1
                   If ws.Cells(r, 23).Value = "" Then
                       ws.Cells(r, 22).Value = pHat
                       ws.Cells(r, 23).Value = basDt: ws.Cells(r, 23).NumberFormat = "DD.MM.YYYY HH:MM"
                   End If
                   ws.Cells(r, 24).Value = bitDt: ws.Cells(r, 24).NumberFormat = "DD.MM.YYYY HH:MM"
               Case 2
                   If ws.Cells(r, 26).Value = "" Then
                       ws.Cells(r, 25).Value = pHat
                       ws.Cells(r, 26).Value = basDt: ws.Cells(r, 26).NumberFormat = "DD.MM.YYYY HH:MM"
                   End If
                   ws.Cells(r, 27).Value = bitDt: ws.Cells(r, 27).NumberFormat = "DD.MM.YYYY HH:MM"
               Case 3
                   If ws.Cells(r, 28).Value = "" Then
                       ws.Cells(r, 28).Value = basDt: ws.Cells(r, 28).NumberFormat = "DD.MM.YYYY HH:MM"
                   End If
                   ws.Cells(r, 29).Value = bitDt: ws.Cells(r, 29).NumberFormat = "DD.MM.YYYY HH:MM"
               Case 4
                   If ws.Cells(r, 30).Value = "" Then
                       ws.Cells(r, 30).Value = basDt: ws.Cells(r, 30).NumberFormat = "DD.MM.YYYY HH:MM"
                   End If
                   ws.Cells(r, 31).Value = bitDt: ws.Cells(r, 31).NumberFormat = "DD.MM.YYYY HH:MM"
               Case 5
                   If ws.Cells(r, 32).Value = "" Then
                       ws.Cells(r, 32).Value = basDt: ws.Cells(r, 32).NumberFormat = "DD.MM.YYYY HH:MM"
                   End If
                   ws.Cells(r, 33).Value = bitDt: ws.Cells(r, 33).NumberFormat = "DD.MM.YYYY HH:MM"
               Case 6
                   If ws.Cells(r, 34).Value = "" Then
                       ws.Cells(r, 34).Value = basDt: ws.Cells(r, 34).NumberFormat = "DD.MM.YYYY HH:MM"
                   End If
                   ws.Cells(r, 35).Value = bitDt: ws.Cells(r, 35).NumberFormat = "DD.MM.YYYY HH:MM"
               Case 7
                   If ws.Cells(r, 36).Value = "" Then
                       ws.Cells(r, 36).Value = basDt: ws.Cells(r, 36).NumberFormat = "DD.MM.YYYY HH:MM"
                   End If
                   ws.Cells(r, 37).Value = bitDt: ws.Cells(r, 37).NumberFormat = "DD.MM.YYYY HH:MM"
           End Select
       Next ki
sonrakiUcak:
   Next ui
   ws.Columns("A:AK").AutoFit
End Sub
 
' ====================================================
' PLAN HESAPLA VE CIZ (Soru sormadan, mevcut ayarlarla)
' DurusEkleme gibi makrolar tarafindan cagirilir
' ====================================================
Sub PlanHesaplaVeCiz()
   On Error GoTo Hata
   If gPlanUcakSayisi = 0 Then MsgBox "Once PlanOlustur calistirin!", vbExclamation: Exit Sub
 
   Dim ilkUcak As Long: ilkUcak = gPlanIlkUcak
   Dim ucakSayisi As Long: ucakSayisi = gPlanUcakSayisi
   Dim basTarih As Date: basTarih = gPlanBasTarih
   Dim gunSayisi As Long: gunSayisi = gPlanGunSayisi
   Dim c1BasGun As Long: c1BasGun = gC1BasGun
   Dim c1BasSaat As Double: c1BasSaat = gC1BasSaat
   Dim c2BasGun As Long: c2BasGun = gC2BasGun
   Dim c2BasSaat As Double: c2BasSaat = gC2BasSaat
 
   ' PlanDetay'dan mevcut verileri oku
   Dim a2cDurusSaat() As Double
   Dim a2cEkSaat() As Double
   Dim a2cPinTarih() As Double
   Call A2C_DetayOku(ilkUcak, ucakSayisi, a2cDurusSaat, a2cEkSaat, a2cPinTarih)
 
   ' Sureler
   Dim c1Sur(0 To 5) As Double
   c1Sur(0) = C1_OP1_SURE: c1Sur(1) = C1_OP2_SURE: c1Sur(2) = C1_OP3_SURE
   c1Sur(3) = C1_OP4_SURE: c1Sur(4) = C1_OP5_SURE: c1Sur(5) = C1_OP6_SURE
   Dim winSur(0 To 1) As Double
   winSur(0) = WIN_OP1_SURE: winSur(1) = WIN_OP2_SURE
   Dim mateSur(0 To 2) As Double
   mateSur(0) = MATE_OP1_SURE: mateSur(1) = MATE_OP2_SURE: mateSur(2) = MATE_OP3_SURE
   Dim istSur(3 To 7, 0 To 5) As Double
   istSur(3, 0) = OOC_OP1_SURE: istSur(3, 1) = OOC_OP2_SURE: istSur(3, 2) = OOC_OP3_SURE
   istSur(3, 3) = OOC_OP4_SURE: istSur(3, 4) = OOC_OP5_SURE
   istSur(4, 0) = LAY_OP1_SURE: istSur(4, 1) = LAY_OP2_SURE: istSur(4, 2) = LAY_OP3_SURE
   istSur(4, 3) = LAY_OP4_SURE: istSur(4, 4) = LAY_OP5_SURE: istSur(4, 5) = LAY_OP6_SURE
   istSur(5, 0) = BOYA_OP1_SURE: istSur(5, 1) = BOYA_OP2_SURE
   istSur(6, 0) = SEAL_OP1_SURE
   istSur(7, 0) = FINAL_OP1_SURE
   Dim istOpSay(3 To 7) As Integer
   istOpSay(3) = 5: istOpSay(4) = 6: istOpSay(5) = 2: istOpSay(6) = 1: istOpSay(7) = 1
 
   ' Hat kuyruk pozisyonlari
   Dim c1HatGun(1 To COJI1_HAT) As Long
   Dim c1HatSaat(1 To COJI1_HAT) As Double
   Dim c2HatGun(1 To COJI2_HAT) As Long
   Dim c2HatSaat(1 To COJI2_HAT) As Double
   Dim tekHatGun(3 To 7) As Long
   Dim tekHatSaat(3 To 7) As Double
   Dim h As Integer
   For h = 1 To COJI1_HAT: c1HatGun(h) = c1BasGun: c1HatSaat(h) = c1BasSaat: Next h
   For h = 1 To COJI2_HAT: c2HatGun(h) = c2BasGun: c2HatSaat(h) = c2BasSaat: Next h
   Dim enErkenGun As Long, enErkenSaat As Double
   If c1BasGun < c2BasGun Or (c1BasGun = c2BasGun And c1BasSaat <= c2BasSaat) Then
       enErkenGun = c1BasGun: enErkenSaat = c1BasSaat
   Else
       enErkenGun = c2BasGun: enErkenSaat = c2BasSaat
   End If
   For h = 3 To 7: tekHatGun(h) = enErkenGun: tekHatSaat(h) = enErkenSaat: Next h
 
   ' Plan dizisi
   Dim plan() As Variant
   ReDim plan(0 To ucakSayisi - 1, 0 To A2C_MAX_KAYIT - 1, 0 To 6)
   Dim pi As Long, pj As Long
   For pi = 0 To ucakSayisi - 1
       For pj = 0 To A2C_MAX_KAYIT - 1: plan(pi, pj, 0) = -1: Next pj
   Next pi
 
   Dim ui As Long
   For ui = 0 To ucakSayisi - 1
       Dim kayitIdx As Long: kayitIdx = 0
       Dim lc1Sur(0 To 5) As Double, lwinSur(0 To 1) As Double, lmateSur(0 To 2) As Double
       Dim listSur(3 To 7, 0 To 5) As Double
       Dim op As Integer, istIdx As Integer
       For op = 0 To 5: lc1Sur(op) = c1Sur(op): Next op
       For op = 0 To 1: lwinSur(op) = winSur(op): Next op
       For op = 0 To 2: lmateSur(op) = mateSur(op): Next op
       For istIdx = 3 To 7: For op = 0 To 5: listSur(istIdx, op) = istSur(istIdx, op): Next op: Next istIdx
       lc1Sur(5) = A2C_SurePozitif(lc1Sur(5) + a2cEkSaat(ui, A2C_STAGE_C1))
       lwinSur(1) = A2C_SurePozitif(lwinSur(1) + a2cEkSaat(ui, A2C_STAGE_WIN))
       lmateSur(2) = A2C_SurePozitif(lmateSur(2) + a2cEkSaat(ui, A2C_STAGE_MATE))
       listSur(3, 4) = A2C_SurePozitif(listSur(3, 4) + a2cEkSaat(ui, A2C_STAGE_OUT))
       listSur(4, 5) = A2C_SurePozitif(listSur(4, 5) + a2cEkSaat(ui, A2C_STAGE_LAY))
       listSur(5, 1) = A2C_SurePozitif(listSur(5, 1) + a2cEkSaat(ui, A2C_STAGE_BOYA))
       listSur(6, 0) = A2C_SurePozitif(listSur(6, 0) + a2cEkSaat(ui, A2C_STAGE_SEAL))
       listSur(7, 0) = A2C_SurePozitif(listSur(7, 0) + a2cEkSaat(ui, A2C_STAGE_FINAL))
 
       ' COJI1
       Dim c1H As Integer: c1H = 1
       Dim c1EnG As Long: c1EnG = c1HatGun(1): Dim c1EnS As Double: c1EnS = c1HatSaat(1)
       For h = 2 To COJI1_HAT
           If c1HatGun(h) < c1EnG Or (c1HatGun(h) = c1EnG And c1HatSaat(h) < c1EnS) Then
               c1EnG = c1HatGun(h): c1EnS = c1HatSaat(h): c1H = h
           End If
       Next h
       Dim c1BasG As Long: c1BasG = c1EnG: Dim c1BasS As Double: c1BasS = c1EnS
       Call IlkUygunZaman(c1BasG, c1BasS, basTarih)
       If a2cDurusSaat(ui) > 0 Then Call SaatEkle(c1BasG, c1BasS, a2cDurusSaat(ui), basTarih)
       Call A2C_PinUygula(c1BasG, c1BasS, a2cPinTarih(ui, A2C_STAGE_C1), basTarih)
       Dim c1SonG As Long: c1SonG = c1BasG: Dim c1SonS As Double: c1SonS = c1BasS
       Dim og As Long, os As Double, bg As Long, bs As Double
       For op = 0 To 5
           og = c1SonG: os = c1SonS: Call IlkUygunZaman(og, os, basTarih)
           bg = og: bs = os: Call SaatEkle(og, os, lc1Sur(op), basTarih)
           Call A2C_KayitEkle(plan, ui, kayitIdx, 0, c1H, op, bg, bs, og, os)
           c1SonG = og: c1SonS = os
       Next op
       c1HatGun(c1H) = c1SonG: c1HatSaat(c1H) = c1SonS
       Dim c1BitG As Long: c1BitG = c1SonG: Dim c1BitS As Double: c1BitS = c1SonS
 
       ' WINDSHIELD
       Dim c2HWin As Integer: c2HWin = 1
       Dim c2EnG As Long: c2EnG = c2HatGun(1): Dim c2EnS As Double: c2EnS = c2HatSaat(1)
       For h = 2 To COJI2_HAT
           If c2HatGun(h) < c2EnG Or (c2HatGun(h) = c2EnG And c2HatSaat(h) < c2EnS) Then
               c2EnG = c2HatGun(h): c2EnS = c2HatSaat(h): c2HWin = h
           End If
       Next h
       Dim winBasG As Long, winBasS As Double
       If c2EnG > c1BasG Or (c2EnG = c1BasG And c2EnS > c1BasS) Then
           winBasG = c2EnG: winBasS = c2EnS
       Else
           winBasG = c1BasG: winBasS = c1BasS
       End If
       Call IlkUygunZaman(winBasG, winBasS, basTarih)
       Call A2C_PinUygula(winBasG, winBasS, a2cPinTarih(ui, A2C_STAGE_WIN), basTarih)
       Dim winSonG As Long: winSonG = winBasG: Dim winSonS As Double: winSonS = winBasS
       For op = 0 To 1
           og = winSonG: os = winSonS: Call IlkUygunZaman(og, os, basTarih)
           bg = og: bs = os: Call SaatEkle(og, os, lwinSur(op), basTarih)
           Call A2C_KayitEkle(plan, ui, kayitIdx, 1, c2HWin, op, bg, bs, og, os)
           winSonG = og: winSonS = os
       Next op
       c2HatGun(c2HWin) = winSonG: c2HatSaat(c2HWin) = winSonS
       Dim winBitG As Long: winBitG = winSonG: Dim winBitS As Double: winBitS = winSonS
 
       ' MATE
       Dim c2HMate As Integer: c2HMate = 1
       c2EnG = c2HatGun(1): c2EnS = c2HatSaat(1)
       For h = 2 To COJI2_HAT
           If c2HatGun(h) < c2EnG Or (c2HatGun(h) = c2EnG And c2HatSaat(h) < c2EnS) Then
               c2EnG = c2HatGun(h): c2EnS = c2HatSaat(h): c2HMate = h
           End If
       Next h
       Dim mateReqG As Long, mateReqS As Double
       If c1BitG > winBitG Or (c1BitG = winBitG And c1BitS >= winBitS) Then
           mateReqG = c1BitG: mateReqS = c1BitS
       Else
           mateReqG = winBitG: mateReqS = winBitS
       End If
       Dim mateBasG As Long, mateBasS As Double
       If c2EnG > mateReqG Or (c2EnG = mateReqG And c2EnS > mateReqS) Then
           mateBasG = c2EnG: mateBasS = c2EnS
       Else
           mateBasG = mateReqG: mateBasS = mateReqS
       End If
       Call IlkUygunZaman(mateBasG, mateBasS, basTarih)
       Call A2C_PinUygula(mateBasG, mateBasS, a2cPinTarih(ui, A2C_STAGE_MATE), basTarih)
       Dim mateSonG As Long: mateSonG = mateBasG: Dim mateSonS As Double: mateSonS = mateBasS
       For op = 0 To 2
           og = mateSonG: os = mateSonS: Call IlkUygunZaman(og, os, basTarih)
           bg = og: bs = os: Call SaatEkle(og, os, lmateSur(op), basTarih)
           Call A2C_KayitEkle(plan, ui, kayitIdx, 2, c2HMate, op, bg, bs, og, os)
           mateSonG = og: mateSonS = os
       Next op
       c2HatGun(c2HMate) = mateSonG: c2HatSaat(c2HMate) = mateSonS
       Dim oncekiG As Long: oncekiG = mateSonG: Dim oncekiS As Double: oncekiS = mateSonS
 
       ' Tek hatli istasyonlar
       For istIdx = 3 To 7
           Dim hatG As Long: hatG = tekHatGun(istIdx): Dim hatS As Double: hatS = tekHatSaat(istIdx)
           Dim istBasG As Long, istBasS As Double
           If hatG > oncekiG Or (hatG = oncekiG And hatS > oncekiS) Then
               istBasG = hatG: istBasS = hatS
           Else
               istBasG = oncekiG: istBasS = oncekiS
           End If
           Call IlkUygunZaman(istBasG, istBasS, basTarih)
           Select Case istIdx
               Case 3: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_OUT), basTarih)
               Case 4: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_LAY), basTarih)
               Case 5: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_BOYA), basTarih)
               Case 6: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_SEAL), basTarih)
               Case 7: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_FINAL), basTarih)
           End Select
           Dim istSonG As Long: istSonG = istBasG: Dim istSonS As Double: istSonS = istBasS
           For op = 0 To istOpSay(istIdx) - 1
               og = istSonG: os = istSonS: Call IlkUygunZaman(og, os, basTarih)
               bg = og: bs = os: Call SaatEkle(og, os, listSur(istIdx, op), basTarih)
               Call A2C_KayitEkle(plan, ui, kayitIdx, istIdx, 1, op, bg, bs, og, os)
               istSonG = og: istSonS = os
           Next op
           tekHatGun(istIdx) = istSonG: tekHatSaat(istIdx) = istSonS
           oncekiG = istSonG: oncekiS = istSonS
       Next istIdx
   Next ui
 
   gPlanVerisi = plan
   Call GorselOlustur(plan, ucakSayisi, ilkUcak, basTarih, gunSayisi)
   Call A2C_AylikPlanOlustur(plan, ucakSayisi, ilkUcak, basTarih, gunSayisi)
   Call A2C_PlanDetaySonuclariYaz(plan, ilkUcak, ucakSayisi, basTarih)
   Exit Sub
Hata: MsgBox "Hata: " & Err.Description, vbCritical
End Sub
 
' ====================================================
' MAKRO 1: PLAN OLUSTUR
' ====================================================
Sub PlanOlustur()
   On Error GoTo Hata
   Application.ScreenUpdating = False
 
   Dim ilkUcak As Long, ucakSayisi As Long
   Dim c1BasGun As Long, c2BasGun As Long
   Dim c1BasSaat As Double, c2BasSaat As Double
   Dim basTarih As Date, gunSayisi As Long
 
   ilkUcak = CLng(InputBox("Ilk ucak numarasi:", "Plan Olustur", "501"))
   ucakSayisi = CLng(InputBox("Kac ucak planlanacak:", "Plan Olustur", "5"))
   gNormalVardiya = CInt(InputBox("Hafta ici vardiya sayisi (1, 2 veya 3):", "Plan Olustur", "2"))
   If gNormalVardiya < 1 Or gNormalVardiya > 3 Then gNormalVardiya = 2
 
   Application.ScreenUpdating = True
 
   Dim cvpHS As VbMsgBoxResult
   cvpHS = MsgBox("Cumartesi calisilacak mi?", vbYesNo + vbQuestion, "Hafta Sonu Ayari")
   If cvpHS = vbYes Then
       gCumartesiCalisiyorMu = True
       gCumartesiVardiya = CInt(InputBox("Cumartesi kac vardiya?", "Cumartesi", CStr(gNormalVardiya)))
       If gCumartesiVardiya < 1 Or gCumartesiVardiya > 3 Then gCumartesiVardiya = gNormalVardiya
   Else
       gCumartesiCalisiyorMu = False: gCumartesiVardiya = 0
   End If
 
   cvpHS = MsgBox("Pazar calisilacak mi?", vbYesNo + vbQuestion, "Hafta Sonu Ayari")
   If cvpHS = vbYes Then
       gPazarCalisiyorMu = True
       gPazarVardiya = CInt(InputBox("Pazar kac vardiya?", "Pazar", CStr(gNormalVardiya)))
       If gPazarVardiya < 1 Or gPazarVardiya > 3 Then gPazarVardiya = gNormalVardiya
   Else
       gPazarCalisiyorMu = False: gPazarVardiya = 0
   End If
 
   ' Tatiller
   gTatilSayisi = 8
   ReDim gTatilGunler(0 To gTatilSayisi - 1)
   ReDim gTatilCalisiyorMu(0 To gTatilSayisi - 1)
   Dim tatilTarihler(0 To 7) As Date
   tatilTarihler(0) = DateSerial(2026, 1, 1): tatilTarihler(1) = DateSerial(2026, 3, 20)
   tatilTarihler(2) = DateSerial(2026, 4, 23): tatilTarihler(3) = DateSerial(2026, 5, 1)
   tatilTarihler(4) = DateSerial(2026, 5, 19): tatilTarihler(5) = DateSerial(2026, 5, 26)
   tatilTarihler(6) = DateSerial(2026, 7, 15): tatilTarihler(7) = DateSerial(2026, 8, 30)
   Dim tatilAdlari(0 To 7) As String
   tatilAdlari(0) = "1 Ocak 2026 - Yilbasi"
   tatilAdlari(1) = "Ramazan Bayrami 2026 (20-22 Mart)"
   tatilAdlari(2) = "23 Nisan 2026 - Ulusal Egemenlik"
   tatilAdlari(3) = "1 Mayis 2026 - Isci Bayrami"
   tatilAdlari(4) = "19 Mayis 2026 - Genclik Bayrami"
   tatilAdlari(5) = "Kurban Bayrami 2026 (26-30 Mayis)"
   tatilAdlari(6) = "15 Temmuz 2026 - Demokrasi Gunu"
   tatilAdlari(7) = "30 Agustos 2026 - Zafer Bayrami"
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       gTatilGunler(tt) = tatilTarihler(tt)
       Dim cvp As VbMsgBoxResult
       cvp = MsgBox(tatilAdlari(tt) & vbCrLf & vbCrLf & "Bu tatilde calisma yapilacak mi?", vbYesNo + vbQuestion, "Tatil Ayarlari")
       gTatilCalisiyorMu(tt) = (cvp = vbYes)
   Next tt
 
   Application.ScreenUpdating = False
 
   ' COJI1 baslangic
   Dim c1Str As String
   c1Str = InputBox("COJI 1 baslangic tarihi ve saati (Ornek: 01.04.2026 07:00):", "Plan Olustur", "01.04.2026 07:00")
   If Trim(c1Str) = "" Then Application.ScreenUpdating = True: Exit Sub
   Dim c1Tarih As Date: c1Tarih = CDate(Split(Trim(c1Str), " ")(0))
   Dim c1SP() As String: c1SP = Split(Split(Trim(c1Str), " ")(1), ":")
   c1BasSaat = CDbl(c1SP(0)) + CDbl(c1SP(1)) / 60#
 
   ' COJI2 baslangic
   Dim c2Str As String
   c2Str = InputBox("COJI 2 baslangic tarihi ve saati (Ornek: 01.04.2026 07:00):", "Plan Olustur", "01.04.2026 07:00")
   If Trim(c2Str) = "" Then Application.ScreenUpdating = True: Exit Sub
   Dim c2Tarih As Date: c2Tarih = CDate(Split(Trim(c2Str), " ")(0))
   Dim c2SP() As String: c2SP = Split(Split(Trim(c2Str), " ")(1), ":")
   c2BasSaat = CDbl(c2SP(0)) + CDbl(c2SP(1)) / 60#
 
   If c1Tarih <= c2Tarih Then basTarih = c1Tarih Else basTarih = c2Tarih
   c1BasGun = CLng(c1Tarih - basTarih)
   c2BasGun = CLng(c2Tarih - basTarih)
 
   Dim ayCount As Integer
   ayCount = CInt(InputBox("Kac ay planlanacak:", "Plan Olustur", "3"))
   gunSayisi = ayCount * 31
   gPlanGunSayisi = gunSayisi
 
   ' PlanDetay olustur
   Call A2C_PlanDetayOlusturVeyaGuncelle(ilkUcak, ucakSayisi)
 
   Dim a2cDurusSaat() As Double
   Dim a2cEkSaat() As Double
   Dim a2cPinTarih() As Double
   Call A2C_DetayOku(ilkUcak, ucakSayisi, a2cDurusSaat, a2cEkSaat, a2cPinTarih)
 
   ' Sureler
   Dim c1Sur(0 To 5) As Double
   c1Sur(0) = C1_OP1_SURE: c1Sur(1) = C1_OP2_SURE: c1Sur(2) = C1_OP3_SURE
   c1Sur(3) = C1_OP4_SURE: c1Sur(4) = C1_OP5_SURE: c1Sur(5) = C1_OP6_SURE
   Dim winSur(0 To 1) As Double
   winSur(0) = WIN_OP1_SURE: winSur(1) = WIN_OP2_SURE
   Dim mateSur(0 To 2) As Double
   mateSur(0) = MATE_OP1_SURE: mateSur(1) = MATE_OP2_SURE: mateSur(2) = MATE_OP3_SURE
   Dim istSur(3 To 7, 0 To 5) As Double
   istSur(3, 0) = OOC_OP1_SURE: istSur(3, 1) = OOC_OP2_SURE: istSur(3, 2) = OOC_OP3_SURE
   istSur(3, 3) = OOC_OP4_SURE: istSur(3, 4) = OOC_OP5_SURE
   istSur(4, 0) = LAY_OP1_SURE: istSur(4, 1) = LAY_OP2_SURE: istSur(4, 2) = LAY_OP3_SURE
   istSur(4, 3) = LAY_OP4_SURE: istSur(4, 4) = LAY_OP5_SURE: istSur(4, 5) = LAY_OP6_SURE
   istSur(5, 0) = BOYA_OP1_SURE: istSur(5, 1) = BOYA_OP2_SURE
   istSur(6, 0) = SEAL_OP1_SURE
   istSur(7, 0) = FINAL_OP1_SURE
   Dim istOpSay(3 To 7) As Integer
   istOpSay(3) = 5: istOpSay(4) = 6: istOpSay(5) = 2: istOpSay(6) = 1: istOpSay(7) = 1
 
   ' Hat kuyruk pozisyonlari
   Dim c1HatGun(1 To COJI1_HAT) As Long
   Dim c1HatSaat(1 To COJI1_HAT) As Double
   Dim c2HatGun(1 To COJI2_HAT) As Long
   Dim c2HatSaat(1 To COJI2_HAT) As Double
   Dim tekHatGun(3 To 7) As Long
   Dim tekHatSaat(3 To 7) As Double
   Dim h As Integer
   For h = 1 To COJI1_HAT: c1HatGun(h) = c1BasGun: c1HatSaat(h) = c1BasSaat: Next h
   For h = 1 To COJI2_HAT: c2HatGun(h) = c2BasGun: c2HatSaat(h) = c2BasSaat: Next h
   Dim enErkenGun As Long, enErkenSaat As Double
   If c1BasGun < c2BasGun Or (c1BasGun = c2BasGun And c1BasSaat <= c2BasSaat) Then
       enErkenGun = c1BasGun: enErkenSaat = c1BasSaat
   Else
       enErkenGun = c2BasGun: enErkenSaat = c2BasSaat
   End If
   For h = 3 To 7: tekHatGun(h) = enErkenGun: tekHatSaat(h) = enErkenSaat: Next h
 
   ' Plan dizisi
   Dim plan() As Variant
   ReDim plan(0 To ucakSayisi - 1, 0 To A2C_MAX_KAYIT - 1, 0 To 6)
   Dim pi As Long, pj As Long
   For pi = 0 To ucakSayisi - 1
       For pj = 0 To A2C_MAX_KAYIT - 1
           plan(pi, pj, 0) = -1
       Next pj
   Next pi
 
   Dim ui As Long
   For ui = 0 To ucakSayisi - 1
       Dim kayitIdx As Long: kayitIdx = 0
 
       ' Her ucak icin lokal sure kopyalari
       Dim lc1Sur(0 To 5) As Double
       Dim lwinSur(0 To 1) As Double
       Dim lmateSur(0 To 2) As Double
       Dim listSur(3 To 7, 0 To 5) As Double
       Dim op As Integer, istIdx As Integer
 
       For op = 0 To 5: lc1Sur(op) = c1Sur(op): Next op
       For op = 0 To 1: lwinSur(op) = winSur(op): Next op
       For op = 0 To 2: lmateSur(op) = mateSur(op): Next op
       For istIdx = 3 To 7
           For op = 0 To 5: listSur(istIdx, op) = istSur(istIdx, op): Next op
       Next istIdx
 
       ' Ek sureler uygula
       lc1Sur(5) = A2C_SurePozitif(lc1Sur(5) + a2cEkSaat(ui, A2C_STAGE_C1))
       lwinSur(1) = A2C_SurePozitif(lwinSur(1) + a2cEkSaat(ui, A2C_STAGE_WIN))
       lmateSur(2) = A2C_SurePozitif(lmateSur(2) + a2cEkSaat(ui, A2C_STAGE_MATE))
       listSur(3, 4) = A2C_SurePozitif(listSur(3, 4) + a2cEkSaat(ui, A2C_STAGE_OUT))
       listSur(4, 5) = A2C_SurePozitif(listSur(4, 5) + a2cEkSaat(ui, A2C_STAGE_LAY))
       listSur(5, 1) = A2C_SurePozitif(listSur(5, 1) + a2cEkSaat(ui, A2C_STAGE_BOYA))
       listSur(6, 0) = A2C_SurePozitif(listSur(6, 0) + a2cEkSaat(ui, A2C_STAGE_SEAL))
       listSur(7, 0) = A2C_SurePozitif(listSur(7, 0) + a2cEkSaat(ui, A2C_STAGE_FINAL))
 
       ' COJI1
       Dim c1H As Integer: c1H = 1
       Dim c1EnG As Long: c1EnG = c1HatGun(1)
       Dim c1EnS As Double: c1EnS = c1HatSaat(1)
       For h = 2 To COJI1_HAT
           If c1HatGun(h) < c1EnG Or (c1HatGun(h) = c1EnG And c1HatSaat(h) < c1EnS) Then
               c1EnG = c1HatGun(h): c1EnS = c1HatSaat(h): c1H = h
           End If
       Next h
       Dim c1BasG As Long: c1BasG = c1EnG
       Dim c1BasS As Double: c1BasS = c1EnS
       Call IlkUygunZaman(c1BasG, c1BasS, basTarih)
       If a2cDurusSaat(ui) > 0 Then Call SaatEkle(c1BasG, c1BasS, a2cDurusSaat(ui), basTarih)
       Call A2C_PinUygula(c1BasG, c1BasS, a2cPinTarih(ui, A2C_STAGE_C1), basTarih)
       Dim c1SonG As Long: c1SonG = c1BasG
       Dim c1SonS As Double: c1SonS = c1BasS
       Dim og As Long, os As Double, bg As Long, bs As Double
       For op = 0 To 5
           og = c1SonG: os = c1SonS
           Call IlkUygunZaman(og, os, basTarih)
           bg = og: bs = os
           Call SaatEkle(og, os, lc1Sur(op), basTarih)
           Call A2C_KayitEkle(plan, ui, kayitIdx, 0, c1H, op, bg, bs, og, os)
           c1SonG = og: c1SonS = os
       Next op
       c1HatGun(c1H) = c1SonG: c1HatSaat(c1H) = c1SonS
       Dim c1BitG As Long: c1BitG = c1SonG
       Dim c1BitS As Double: c1BitS = c1SonS
 
       ' WINDSHIELD
       Dim c2HWin As Integer: c2HWin = 1
       Dim c2EnG As Long: c2EnG = c2HatGun(1)
       Dim c2EnS As Double: c2EnS = c2HatSaat(1)
       For h = 2 To COJI2_HAT
           If c2HatGun(h) < c2EnG Or (c2HatGun(h) = c2EnG And c2HatSaat(h) < c2EnS) Then
               c2EnG = c2HatGun(h): c2EnS = c2HatSaat(h): c2HWin = h
           End If
       Next h
       Dim winBasG As Long, winBasS As Double
       If c2EnG > c1BasG Or (c2EnG = c1BasG And c2EnS > c1BasS) Then
           winBasG = c2EnG: winBasS = c2EnS
       Else
           winBasG = c1BasG: winBasS = c1BasS
       End If
       Call IlkUygunZaman(winBasG, winBasS, basTarih)
       Call A2C_PinUygula(winBasG, winBasS, a2cPinTarih(ui, A2C_STAGE_WIN), basTarih)
       Dim winSonG As Long: winSonG = winBasG
       Dim winSonS As Double: winSonS = winBasS
       For op = 0 To 1
           og = winSonG: os = winSonS
           Call IlkUygunZaman(og, os, basTarih)
           bg = og: bs = os
           Call SaatEkle(og, os, lwinSur(op), basTarih)
           Call A2C_KayitEkle(plan, ui, kayitIdx, 1, c2HWin, op, bg, bs, og, os)
           winSonG = og: winSonS = os
       Next op
       c2HatGun(c2HWin) = winSonG: c2HatSaat(c2HWin) = winSonS
       Dim winBitG As Long: winBitG = winSonG
       Dim winBitS As Double: winBitS = winSonS
 
       ' MATE
       Dim c2HMate As Integer: c2HMate = 1
       c2EnG = c2HatGun(1): c2EnS = c2HatSaat(1)
       For h = 2 To COJI2_HAT
           If c2HatGun(h) < c2EnG Or (c2HatGun(h) = c2EnG And c2HatSaat(h) < c2EnS) Then
               c2EnG = c2HatGun(h): c2EnS = c2HatSaat(h): c2HMate = h
           End If
       Next h
       Dim mateReqG As Long, mateReqS As Double
       If c1BitG > winBitG Or (c1BitG = winBitG And c1BitS >= winBitS) Then
           mateReqG = c1BitG: mateReqS = c1BitS
       Else
           mateReqG = winBitG: mateReqS = winBitS
       End If
       Dim mateBasG As Long, mateBasS As Double
       If c2EnG > mateReqG Or (c2EnG = mateReqG And c2EnS > mateReqS) Then
           mateBasG = c2EnG: mateBasS = c2EnS
       Else
           mateBasG = mateReqG: mateBasS = mateReqS
       End If
       Call IlkUygunZaman(mateBasG, mateBasS, basTarih)
       Call A2C_PinUygula(mateBasG, mateBasS, a2cPinTarih(ui, A2C_STAGE_MATE), basTarih)
       Dim mateSonG As Long: mateSonG = mateBasG
       Dim mateSonS As Double: mateSonS = mateBasS
       For op = 0 To 2
           og = mateSonG: os = mateSonS
           Call IlkUygunZaman(og, os, basTarih)
           bg = og: bs = os
           Call SaatEkle(og, os, lmateSur(op), basTarih)
           Call A2C_KayitEkle(plan, ui, kayitIdx, 2, c2HMate, op, bg, bs, og, os)
           mateSonG = og: mateSonS = os
       Next op
       c2HatGun(c2HMate) = mateSonG: c2HatSaat(c2HMate) = mateSonS
       Dim oncekiG As Long: oncekiG = mateSonG
       Dim oncekiS As Double: oncekiS = mateSonS
 
       ' Tek hatli istasyonlar
       For istIdx = 3 To 7
           Dim hatG As Long: hatG = tekHatGun(istIdx)
           Dim hatS As Double: hatS = tekHatSaat(istIdx)
           Dim istBasG As Long, istBasS As Double
           If hatG > oncekiG Or (hatG = oncekiG And hatS > oncekiS) Then
               istBasG = hatG: istBasS = hatS
           Else
               istBasG = oncekiG: istBasS = oncekiS
           End If
           Call IlkUygunZaman(istBasG, istBasS, basTarih)
           Select Case istIdx
               Case 3: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_OUT), basTarih)
               Case 4: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_LAY), basTarih)
               Case 5: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_BOYA), basTarih)
               Case 6: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_SEAL), basTarih)
               Case 7: Call A2C_PinUygula(istBasG, istBasS, a2cPinTarih(ui, A2C_STAGE_FINAL), basTarih)
           End Select
           Dim istSonG As Long: istSonG = istBasG
           Dim istSonS As Double: istSonS = istBasS
           For op = 0 To istOpSay(istIdx) - 1
               og = istSonG: os = istSonS
               Call IlkUygunZaman(og, os, basTarih)
               bg = og: bs = os
               Call SaatEkle(og, os, listSur(istIdx, op), basTarih)
               Call A2C_KayitEkle(plan, ui, kayitIdx, istIdx, 1, op, bg, bs, og, os)
               istSonG = og: istSonS = os
           Next op
           tekHatGun(istIdx) = istSonG: tekHatSaat(istIdx) = istSonS
           oncekiG = istSonG: oncekiS = istSonS
       Next istIdx
   Next ui
 
   ' Global degiskenlere kaydet
   gPlanVerisi = plan
   gC1BasGun = c1BasGun
   gC1BasSaat = c1BasSaat
   gC2BasGun = c2BasGun
   gC2BasSaat = c2BasSaat
   gPlanUcakSayisi = ucakSayisi
   gPlanIlkUcak = ilkUcak
   gPlanBasTarih = basTarih
   gPlanGunSayisi = gunSayisi
 
   Call GorselOlustur(plan, ucakSayisi, ilkUcak, basTarih, gunSayisi)
   Call A2C_AylikPlanOlustur(plan, ucakSayisi, ilkUcak, basTarih, gunSayisi)
   Call A2C_PlanDetaySonuclariYaz(plan, ilkUcak, ucakSayisi, basTarih)
 
   Application.ScreenUpdating = True
   MsgBox ucakSayisi & " ucak planlandi!", vbInformation, "Tamam"
   Exit Sub
Hata:
   Application.ScreenUpdating = True
   MsgBox "Hata: " & Err.Description, vbCritical
End Sub
 
' ====================================================
' GORSEL OLUSTUR - GANTTPLAN (30dk dilimler)
' ====================================================
Sub GorselOlustur(plan() As Variant, ucakSayisi As Long, ilkUcak As Long, _
                 basTarih As Date, gunSayisi As Long)
 
   Dim op_kodlar(0 To 7, 0 To 5) As String
   op_kodlar(0, 0) = "TOPSKIN-0100": op_kodlar(0, 1) = "TOPSKIN-0150"
   op_kodlar(0, 2) = "TOPSKIN-0200": op_kodlar(0, 3) = "TOPSKIN-0250"
   op_kodlar(0, 4) = "TOPSKIN-0300": op_kodlar(0, 5) = "TOPSKIN-0350"
   op_kodlar(1, 0) = "CANOPY-0070": op_kodlar(1, 1) = "CANOPY-0075"
   op_kodlar(2, 0) = "CANOPY-0080": op_kodlar(2, 1) = "CANOPY-0084": op_kodlar(2, 2) = "CANOPY-0086"
   op_kodlar(3, 0) = "CANOPY-0078": op_kodlar(3, 1) = "CANOPY-0087"
   op_kodlar(3, 2) = "CANOPY-0090": op_kodlar(3, 3) = "CANOPY-0140": op_kodlar(3, 4) = "CANOPY-0091"
   op_kodlar(4, 0) = "CANOPY-0097": op_kodlar(4, 1) = "CANOPY-0092"
   op_kodlar(4, 2) = "CANOPY-0111": op_kodlar(4, 3) = "CANOPY-0150"
   op_kodlar(4, 4) = "CANOPY-1041": op_kodlar(4, 5) = "CANOPY-1072"
   op_kodlar(5, 0) = "CANOPY-0120": op_kodlar(5, 1) = "CANOPY-0125"
   op_kodlar(6, 0) = "CANOPY-0130"
   op_kodlar(7, 0) = "FINAL"
 
   Dim renkler(0 To 19) As String
   renkler(0) = "FFD700": renkler(1) = "87CEEB": renkler(2) = "90EE90"
   renkler(3) = "FFB6C1": renkler(4) = "DDA0DD": renkler(5) = "F0E68C"
   renkler(6) = "98FB98": renkler(7) = "87CEFA": renkler(8) = "FFA07A"
   renkler(9) = "20B2AA": renkler(10) = "FF6347": renkler(11) = "4169E1"
   renkler(12) = "32CD32": renkler(13) = "FF69B4": renkler(14) = "9370DB"
   renkler(15) = "00CED1": renkler(16) = "FF8C00": renkler(17) = "8B4513"
   renkler(18) = "2E8B57": renkler(19) = "DC143C"
 
   Dim ws As Worksheet
   Application.DisplayAlerts = False
   On Error Resume Next: ThisWorkbook.Sheets("GanttPlan").Delete: On Error GoTo 0
   Application.DisplayAlerts = True
   Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   ws.Name = "GanttPlan": ws.Cells.Font.Name = "Calibri"
 
   Const IST_COL As Integer = 1
   Const OP_COL As Integer = 2
   Const VERI_COL As Integer = 3
 
   ' Max vardiya hesapla
   Dim maxV As Integer: maxV = gNormalVardiya
   If gCumartesiCalisiyorMu Then If gCumartesiVardiya > maxV Then maxV = gCumartesiVardiya
   If gPazarCalisiyorMu Then If gPazarVardiya > maxV Then maxV = gPazarVardiya
   If maxV < 1 Then maxV = 1
   If maxV > 3 Then maxV = 3
 
   Dim saat_sayisi As Integer
   If maxV = 1 Then saat_sayisi = 16
   If maxV = 2 Then saat_sayisi = 32
   If maxV = 3 Then saat_sayisi = 48
 
   Dim saatlerD() As Double
   ReDim saatlerD(0 To saat_sayisi - 1)
   Dim ss As Integer
   If maxV <= 2 Then
       For ss = 0 To saat_sayisi - 1: saatlerD(ss) = 7# + ss * 0.5: Next ss
   Else
       For ss = 0 To 31: saatlerD(ss) = 7# + ss * 0.5: Next ss
       For ss = 0 To 15: saatlerD(32 + ss) = 23# + ss * 0.5: Next ss
   End If
 
   Dim gunAdlari(0 To 6) As String
   gunAdlari(0) = "Pzt": gunAdlari(1) = "Sal": gunAdlari(2) = "Car"
   gunAdlari(3) = "Per": gunAdlari(4) = "Cum": gunAdlari(5) = "Cmt": gunAdlari(6) = "Paz"
 
   Dim gun_idx As Long, si As Integer
 
   For gun_idx = 0 To gunSayisi - 1
       Dim dd As Date: dd = basTarih + gun_idx
       Dim gun_adi As String: gun_adi = gunAdlari(Weekday(dd, vbMonday) - 1)
       Dim is_tatil As Boolean: is_tatil = TatilMiGun(gun_idx, basTarih)
       Dim gunV As Integer: gunV = GunVardiyaSayisi(gun_idx, basTarih)
       Dim bas_col As Long: bas_col = VERI_COL + gun_idx * saat_sayisi
       Dim bit_col As Long: bit_col = bas_col + saat_sayisi - 1
 
       ws.Range(ws.Cells(1, bas_col), ws.Cells(1, bit_col)).Merge
       With ws.Cells(1, bas_col)
           .Value = gun_adi & " " & Format(dd, "DD.MM.YYYY")
           .Font.Bold = True: .Font.Size = 8: .Font.Color = RGB(255, 255, 255)
           If is_tatil Or gunV = 0 Then .Interior.Color = RGB(160, 160, 160) _
           Else .Interior.Color = RGB(31, 78, 121)
           .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
       End With
 
       Dim v As Integer
       For v = 1 To maxV
           Dim vBas As Double: vBas = VardiyaBas(v)
           Dim vBitVal As Double: vBitVal = VardiyaBit(v)
           Dim vBitG As Double: If vBitVal >= 24 Then vBitG = vBitVal - 24 Else vBitG = vBitVal
           Dim vbc As Long: vbc = -1
           Dim vbtc As Long: vbtc = -1
           For si = 0 To saat_sayisi - 1
               If saatlerD(si) >= vBas And saatlerD(si) < vBitVal Then
                   If vbc = -1 Then vbc = bas_col + si
                   vbtc = bas_col + si
               End If
           Next si
           If vbc > 0 Then
               ws.Range(ws.Cells(2, vbc), ws.Cells(2, vbtc)).Merge
               With ws.Cells(2, vbc)
                   If v <= gunV And Not is_tatil Then
                       Dim vrenk As String
                       Select Case v
                           Case 1: vrenk = "2E75B6"
                           Case 2: vrenk = "375623"
                           Case 3: vrenk = "7030A0"
                       End Select
                       .Value = "S" & v & " (" & SaatFormat(vBas) & "-" & SaatFormat(vBitG) & ")"
                       .Interior.Color = RGB(CLng("&H" & Left(vrenk, 2)), CLng("&H" & Mid(vrenk, 3, 2)), CLng("&H" & Right(vrenk, 2)))
                   Else
                       .Value = "": .Interior.Color = RGB(217, 217, 217)
                   End If
                   .Font.Bold = True: .Font.Size = 7: .Font.Color = RGB(255, 255, 255)
                   .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
               End With
           End If
       Next v
 
       For si = 0 To saat_sayisi - 1
           Dim scol As Long: scol = bas_col + si
           Dim sdVal As Double: sdVal = saatlerD(si)
           Dim sdGoster As Double: sdGoster = sdVal
           If sdGoster >= 24 Then sdGoster = sdGoster - 24
           Dim is_mola As Boolean: is_mola = False
           If Not is_tatil Then
               Dim mv As Integer
               For mv = 1 To gunV
                   If sdVal >= VardiyaMolaBas(mv) And sdVal < VardiyaMolaBit(mv) Then
                       is_mola = True: Exit For
                   End If
               Next mv
           End If
           With ws.Cells(3, scol)
               .Value = SaatFormat(sdGoster)
               .Font.Size = 6: .Font.Bold = True
               If is_mola Then
                   .Interior.Color = RGB(255, 200, 0): .Font.Color = RGB(100, 60, 0)
               ElseIf is_tatil Or HangiVardiyaGun(sdVal, gun_idx, basTarih) = 0 Then
                   .Interior.Color = RGB(230, 230, 230): .Font.Color = RGB(120, 120, 120)
               Else
                   .Interior.Color = RGB(214, 228, 240): .Font.Color = RGB(0, 0, 0)
               End If
               .HorizontalAlignment = xlCenter
               .Borders.LineStyle = xlContinuous: .Borders.Weight = xlHairline
               .Borders.Color = RGB(180, 180, 180)
           End With
           ws.Columns(scol).ColumnWidth = 3.2
       Next si
   Next gun_idx
 
   ws.Columns(IST_COL).ColumnWidth = 22
   ws.Columns(OP_COL).ColumnWidth = 42
   Dim rr As Integer, cc As Integer
   For rr = 1 To 3
       For cc = 1 To 2
           With ws.Cells(rr, cc)
               .Font.Bold = True: .Font.Size = 9: .Font.Color = RGB(255, 255, 255)
               .Interior.Color = RGB(31, 78, 121): .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
           End With
       Next cc
   Next rr
   ws.Cells(1, IST_COL).Value = "ISTASYON / HAT"
   ws.Cells(1, OP_COL).Value = "OPERASYON"
   ws.Range(ws.Cells(1, IST_COL), ws.Cells(3, IST_COL)).Merge
   ws.Range(ws.Cells(1, OP_COL), ws.Cells(3, OP_COL)).Merge
 
   Dim ist_adlari(0 To 7) As String
   ist_adlari(0) = "COJI 1": ist_adlari(1) = "COJI 2 WINDSHIELD"
   ist_adlari(2) = "COJI 2 MATE": ist_adlari(3) = "OUT OF COJI"
   ist_adlari(4) = "LAY OFF": ist_adlari(5) = "BOYA"
   ist_adlari(6) = "SEALANT": ist_adlari(7) = "FINAL"
   Dim ist_hatlar(0 To 7) As Integer
   ist_hatlar(0) = 2: ist_hatlar(1) = 5: ist_hatlar(2) = 5
   ist_hatlar(3) = 1: ist_hatlar(4) = 1: ist_hatlar(5) = 1
   ist_hatlar(6) = 1: ist_hatlar(7) = 1
   Dim op_sayilari(0 To 7) As Integer
   op_sayilari(0) = 6: op_sayilari(1) = 2: op_sayilari(2) = 3
   op_sayilari(3) = 5: op_sayilari(4) = 6: op_sayilari(5) = 2
   op_sayilari(6) = 1: op_sayilari(7) = 1
   Dim op_adlar(0 To 7, 0 To 5) As String
   op_adlar(0, 0) = " CANOPY-TOPSKIN-0100 | LOCATION OF PARTS"
   op_adlar(0, 1) = " CANOPY-TOPSKIN-0150 | PRE-ARM INSTALL&ARM OPERATION"
   op_adlar(0, 2) = " CANOPY-TOPSKIN-0200 | ARM OPERATION"
   op_adlar(0, 3) = " CANOPY-TOPSKIN-0250 | FRAME INSTALLATION AFTER ARM"
   op_adlar(0, 4) = " CANOPY-TOPSKIN-0300 | OTHERS"
   op_adlar(0, 5) = " CANOPY-TOPSKIN-0350 | OUT OF COJI PROCESS"
   op_adlar(1, 0) = " CANOPY-0070 | COLD WORKING OF HOLES"
   op_adlar(1, 1) = " CANOPY-0075 | WINDSHIELD INSTALLATION"
   op_adlar(2, 0) = " CANOPY-0080 | INTEGRATION"
   op_adlar(2, 1) = " CANOPY-0084 | SILL EXT INTERCOSTAL AND STRAP INSTALLATION"
   op_adlar(2, 2) = " CANOPY-0086 | COJI 2 WINDSHIELD OPERATIONS"
   op_adlar(3, 0) = " CANOPY-0078 | OUT OF COJI-4 - OOC"
   op_adlar(3, 1) = " CANOPY-0087 | FR10 SECTOR CENTER EXT AND GUSSET INST - OOC"
   op_adlar(3, 2) = " CANOPY-0090 | WINDSHIELD OPERATIONS - OOC"
   op_adlar(3, 3) = " CANOPY-0140 | GTI MEASUREMENT - LAZER"
   op_adlar(3, 4) = " CANOPY-0091 | RETAINER INSTALLATION - OOC"
   op_adlar(4, 0) = " CANOPY-0097 | OVERHEAD AND HUD BRACKETS"
   op_adlar(4, 1) = " CANOPY-0092 | RETAINER NUT INSTALLATION"
   op_adlar(4, 2) = " CANOPY-0111 | OUT OF COJI-2"
   op_adlar(4, 3) = " CANOPY-0150 | ID PLATE&GROUND STUD OPS & ELECTRICAL BONDING"
   op_adlar(4, 4) = " CANOPY-1041 | OUT OF COJI"
   op_adlar(4, 5) = " CANOPY-1072 | OUT OF COJI-3"
   op_adlar(5, 0) = " CANOPY-0120 | TOUCH UP OPERATIONS"
   op_adlar(5, 1) = " CANOPY-0125 | TOUCH UP OPERATIONS"
   op_adlar(6, 0) = " CANOPY-0130 | SEALANT OPERATIONS"
   op_adlar(7, 0) = " FINAL | FINAL OPERATIONS"
 
   Dim satir_harita As Object: Set satir_harita = CreateObject("Scripting.Dictionary")
   Dim mevcut_satir As Long: mevcut_satir = 4
   Dim ist_idx As Integer, hat_no As Integer, op_idx As Integer
 
   For ist_idx = 0 To 7
       For hat_no = 1 To ist_hatlar(ist_idx)
           Dim hat_label As String
           If ist_hatlar(ist_idx) > 1 Then
               hat_label = ist_adlari(ist_idx) & " - Hat " & hat_no
           Else
               hat_label = ist_adlari(ist_idx)
           End If
           With ws.Cells(mevcut_satir, IST_COL)
               .Value = hat_label: .Font.Bold = True: .Font.Size = 9
               .Font.Color = RGB(255, 255, 255): .Interior.Color = RGB(46, 64, 87)
               .VerticalAlignment = xlCenter: .WrapText = True
           End With
           ws.Cells(mevcut_satir, OP_COL).Interior.Color = RGB(46, 64, 87)
           For gun_idx = 0 To gunSayisi - 1
               Dim bc2 As Long: bc2 = VERI_COL + gun_idx * saat_sayisi
               ws.Range(ws.Cells(mevcut_satir, bc2), ws.Cells(mevcut_satir, bc2 + saat_sayisi - 1)).Interior.Color = RGB(46, 64, 87)
           Next gun_idx
           ws.Rows(mevcut_satir).RowHeight = 18
           mevcut_satir = mevcut_satir + 1
           For op_idx = 0 To op_sayilari(ist_idx) - 1
               Dim key As String: key = CStr(ist_idx * 1000 + hat_no * 10 + op_idx)
               satir_harita(key) = mevcut_satir
               ws.Cells(mevcut_satir, IST_COL).Interior.Color = RGB(242, 242, 242)
               With ws.Cells(mevcut_satir, OP_COL)
                   .Value = op_adlar(ist_idx, op_idx)
                   .Font.Size = 7: .Interior.Color = RGB(242, 242, 242): .VerticalAlignment = xlCenter
               End With
               ws.Rows(mevcut_satir).RowHeight = 15
               mevcut_satir = mevcut_satir + 1
           Next op_idx
       Next hat_no
   Next ist_idx
 
   ' Plani ciz
   Dim ui2 As Long
   For ui2 = 0 To ucakSayisi - 1
       Dim ucak_no As Long: ucak_no = ilkUcak + ui2
       Dim renk As String: renk = renkler(ui2 Mod 20)
       Dim r_val As Long: r_val = CLng("&H" & Left(renk, 2))
       Dim g_val As Long: g_val = CLng("&H" & Mid(renk, 3, 2))
       Dim b_val As Long: b_val = CLng("&H" & Right(renk, 2))
       Dim kayit_idx As Long
       For kayit_idx = 0 To A2C_MAX_KAYIT - 1
           If plan(ui2, kayit_idx, 0) = -1 Then Exit For
           Dim p_ist As Integer: p_ist = CInt(plan(ui2, kayit_idx, 0))
           Dim p_hat As Integer: p_hat = CInt(plan(ui2, kayit_idx, 1))
           Dim p_op As Integer: p_op = CInt(plan(ui2, kayit_idx, 2))
           Dim p_bas_gun As Long: p_bas_gun = CLng(plan(ui2, kayit_idx, 3))
           Dim p_bas_saat As Double: p_bas_saat = CDbl(plan(ui2, kayit_idx, 4))
           Dim p_bit_gun As Long: p_bit_gun = CLng(plan(ui2, kayit_idx, 5))
           Dim p_bit_saat As Double: p_bit_saat = CDbl(plan(ui2, kayit_idx, 6))
           Dim s_key As String: s_key = CStr(p_ist * 1000 + p_hat * 10 + p_op)
           If Not satir_harita.Exists(s_key) Then GoTo sonraki_kayit
           Dim s_no As Long: s_no = CLng(satir_harita(s_key))
           Dim cg As Long: cg = p_bas_gun
           Dim cs As Double: cs = Int(p_bas_saat * 2) / 2
           Dim ilk_hucre As Boolean: ilk_hucre = True
           Do While (cg < p_bit_gun) Or (cg = p_bit_gun And cs < p_bit_saat)
               If cg >= gunSayisi Then Exit Do
               Dim found_si As Integer: found_si = -1
               For si = 0 To saat_sayisi - 1
                   If Abs(saatlerD(si) - cs) < 0.001 Then found_si = si: Exit For
               Next si
               If found_si >= 0 Then
                   If Not TatilMiGun(cg, basTarih) Then
                       If HangiVardiyaGun(cs, cg, basTarih) > 0 Then
                           Dim s_col As Long: s_col = VERI_COL + cg * saat_sayisi + found_si
                           Dim is_mola_saat As Boolean: is_mola_saat = False
                           Dim mv2 As Integer
                           For mv2 = 1 To GunVardiyaSayisi(cg, basTarih)
                               If cs >= VardiyaMolaBas(mv2) And cs < VardiyaMolaBit(mv2) Then
                                   is_mola_saat = True: Exit For
                               End If
                           Next mv2
                           Dim sncs As Double: sncs = cs + 0.5
                           Dim sncg As Long: sncg = cg
                           If maxV = 1 Then
                               If sncs >= 15# Then sncs = 7#: sncg = cg + 1
                           ElseIf maxV = 2 Then
                               If sncs >= 23# Then sncs = 7#: sncg = cg + 1
                           Else
                               If sncs >= 31# Then sncs = 7#: sncg = cg + 1
                           End If
                           Dim son_hucre As Boolean
                           son_hucre = (sncg > p_bit_gun) Or (sncg = p_bit_gun And sncs >= p_bit_saat)
                           If is_mola_saat Then
                               With ws.Cells(s_no, s_col)
                                   .Interior.Color = RGB(CLng(r_val + (255 - r_val) * 0.5), CLng(g_val + (255 - g_val) * 0.5), CLng(b_val + (255 - b_val) * 0.5))
                                   .Value = "M": .Font.Size = 6: .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
                                   .Borders.LineStyle = xlContinuous: .Borders.Weight = xlHairline: .Borders.Color = RGB(150, 150, 150)
                               End With
                           Else
                               With ws.Cells(s_no, s_col)
                                   .Interior.Color = RGB(r_val, g_val, b_val)
                                   .Borders.LineStyle = xlContinuous: .Borders.Weight = xlHairline: .Borders.Color = RGB(150, 150, 150)
                                   If ilk_hucre And son_hucre Then
                                       .Value = ucak_no & " " & SaatFormat(p_bas_saat) & "-" & SaatFormat(p_bit_saat) & " " & op_kodlar(p_ist, p_op)
                                       .Font.Size = 6: .Font.Bold = True: .HorizontalAlignment = xlLeft: .VerticalAlignment = xlCenter
                                       ilk_hucre = False
                                   ElseIf ilk_hucre Then
                                       .Value = ucak_no & " " & SaatFormat(p_bas_saat) & " " & op_kodlar(p_ist, p_op)
                                       .Font.Size = 6: .Font.Bold = True: .HorizontalAlignment = xlLeft: .VerticalAlignment = xlCenter
                                       ilk_hucre = False
                                   ElseIf son_hucre Then
                                       .Value = SaatFormat(p_bit_saat)
                                       .Font.Size = 6: .Font.Bold = True: .HorizontalAlignment = xlRight: .VerticalAlignment = xlCenter
                                   End If
                               End With
                           End If
                       End If
                   End If
               End If
               cs = cs + 0.5
               If maxV = 1 Then
                   If cs >= 15# Then cs = 7#: cg = cg + 1
               ElseIf maxV = 2 Then
                   If cs >= 23# Then cs = 7#: cg = cg + 1
               Else
                   If cs >= 31# Then cs = 7#: cg = cg + 1
               End If
           Loop
sonraki_kayit:
       Next kayit_idx
   Next ui2
 
   ws.Activate: ws.Cells(1, VERI_COL).Select: ActiveWindow.FreezePanes = True: ws.Cells(1, 1).Select
   ws.Rows(1).RowHeight = 20: ws.Rows(2).RowHeight = 16: ws.Rows(3).RowHeight = 14
End Sub
 
