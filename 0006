Function A2C_AyAdi(ayNo As Integer) As String
   Select Case ayNo
       Case 1: A2C_AyAdi = "OCAK": Case 2: A2C_AyAdi = "SUBAT": Case 3: A2C_AyAdi = "MART"
       Case 4: A2C_AyAdi = "NISAN": Case 5: A2C_AyAdi = "MAYIS": Case 6: A2C_AyAdi = "HAZIRAN"
       Case 7: A2C_AyAdi = "TEMMUZ": Case 8: A2C_AyAdi = "AGUSTOS": Case 9: A2C_AyAdi = "EYLUL"
       Case 10: A2C_AyAdi = "EKIM": Case 11: A2C_AyAdi = "KASIM": Case 12: A2C_AyAdi = "ARALIK"
       Case Else: A2C_AyAdi = ""
   End Select
End Function
 
Function A2C_GunKisa(dd As Date) As String
   Select Case Weekday(dd, vbMonday)
       Case 1: A2C_GunKisa = "Pzt": Case 2: A2C_GunKisa = "Sal": Case 3: A2C_GunKisa = "Car"
       Case 4: A2C_GunKisa = "Per": Case 5: A2C_GunKisa = "Cum": Case 6: A2C_GunKisa = "Cmt": Case 7: A2C_GunKisa = "Paz"
   End Select
End Function
 
Function A2C_UcakRenk(idx As Long) As Long
   Dim rr(0 To 17) As Long
   rr(0) = RGB(255, 255, 0): rr(1) = RGB(255, 100, 100): rr(2) = RGB(0, 176, 240)
   rr(3) = RGB(255, 192, 0): rr(4) = RGB(146, 208, 80): rr(5) = RGB(255, 102, 255)
   rr(6) = RGB(0, 204, 153): rr(7) = RGB(255, 153, 204): rr(8) = RGB(153, 204, 255)
   rr(9) = RGB(255, 204, 0): rr(10) = RGB(204, 153, 255): rr(11) = RGB(0, 204, 204)
   rr(12) = RGB(255, 204, 153): rr(13) = RGB(146, 208, 80): rr(14) = RGB(255, 153, 0)
   rr(15) = RGB(153, 255, 204): rr(16) = RGB(255, 204, 255): rr(17) = RGB(204, 255, 153)
   A2C_UcakRenk = rr(idx Mod 18)
End Function
 
Function A2C_MaxVardiya() As Integer
   Dim mx As Integer: mx = gNormalVardiya
   If gCumartesiCalisiyorMu Then If gCumartesiVardiya > mx Then mx = gCumartesiVardiya
   If gPazarCalisiyorMu Then If gPazarVardiya > mx Then mx = gPazarVardiya
   If mx < 1 Then mx = 1
   If mx > 3 Then mx = 3
   A2C_MaxVardiya = mx
End Function
 
Function A2C_GunSutunSayisi(gunIdx As Long, basTarih As Date) As Integer
   Dim gv As Integer: gv = GunVardiyaSayisi(gunIdx, basTarih)
   If gv <= 0 Or TatilMiGun(gunIdx, basTarih) Then
       A2C_GunSutunSayisi = A2C_MaxVardiya()
   Else
       A2C_GunSutunSayisi = gv
   End If
End Function
 
Sub A2C_AySutunHaritasi(ayBas As Date, aySon As Date, planBasTarih As Date, colMap() As Long)
   Dim gunSay As Long: gunSay = CLng(aySon - ayBas) + 1
   ReDim colMap(0 To gunSay)
   colMap(0) = 3
   Dim j As Long, gunIdx As Long
   For j = 0 To gunSay - 1
       gunIdx = CLng((ayBas + j) - planBasTarih)
       colMap(j + 1) = colMap(j) + A2C_GunSutunSayisi(gunIdx, planBasTarih)
   Next j
End Sub
 
Function A2C_VardiyaBasDate(dd As Date, vNoZero As Integer) As Date
   Select Case vNoZero
       Case 0: A2C_VardiyaBasDate = dd + TimeSerial(7, 0, 0)
       Case 1: A2C_VardiyaBasDate = dd + TimeSerial(15, 0, 0)
       Case 2: A2C_VardiyaBasDate = dd + TimeSerial(23, 0, 0)
   End Select
End Function
 
Function A2C_VardiyaBitDate(dd As Date, vNoZero As Integer) As Date
   Select Case vNoZero
       Case 0: A2C_VardiyaBitDate = dd + TimeSerial(15, 0, 0)
       Case 1: A2C_VardiyaBitDate = dd + TimeSerial(23, 0, 0)
       Case 2: A2C_VardiyaBitDate = dd + 1 + TimeSerial(7, 0, 0)
   End Select
End Function
 
Function A2C_PlanDateTime(planBasTarih As Date, gunIdx As Long, saatVal As Double) As Date
   A2C_PlanDateTime = planBasTarih + gunIdx + saatVal / 24#
End Function
 
Function A2C_SatirBul(istIdx As Integer, hatNo As Integer, baseRow As Long) As Long
   Select Case istIdx
       Case 0: A2C_SatirBul = baseRow + 2 + hatNo
       Case 1: A2C_SatirBul = baseRow + 4 + hatNo
       Case 2: A2C_SatirBul = baseRow + 9 + hatNo
       Case 3: A2C_SatirBul = baseRow + 15
       Case 4: A2C_SatirBul = baseRow + 16
       Case 5: A2C_SatirBul = baseRow + 17
       Case 6: A2C_SatirBul = baseRow + 18
       Case 7: A2C_SatirBul = baseRow + 19
       Case Else: A2C_SatirBul = 0
   End Select
End Function
 
Sub A2C_YazTekHucre(ws As Worksheet, satir As Long, sutun As Long, deger As Long, renk As Long)
   With ws.Cells(satir, sutun)
       If .Value = "" Then
           .Value = deger
       Else
           If InStr(1, CStr(.Value), CStr(deger), vbTextCompare) = 0 Then
               .Value = .Value & Chr(10) & deger
           End If
       End If
       .Interior.Color = renk: .Font.Size = 7: .Font.Bold = True
       .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter: .WrapText = True
       .Borders.LineStyle = xlContinuous: .Borders.Weight = xlThin
   End With
End Sub
 
Sub A2C_BasliklariCiz(ws As Worksheet, baseRow As Long, ayBas As Date, aySon As Date, planBasTarih As Date, colMap() As Long)
   Const C_AYADI As Integer = 1
   Const C_LABEL As Integer = 2
   Const C_VERI As Integer = 3
   Const DATA_SATIR As Integer = 17
 
   Dim satirEtiketler(1 To DATA_SATIR) As String
   Dim satirRenkler(1 To DATA_SATIR) As Long
   satirEtiketler(1) = "COJI 1 - Hat 1": satirRenkler(1) = RGB(255, 255, 180)
   satirEtiketler(2) = "COJI 1 - Hat 2": satirRenkler(2) = RGB(255, 255, 180)
   satirEtiketler(3) = "WINDSHIELD - Hat 1": satirRenkler(3) = RGB(180, 220, 255)
   satirEtiketler(4) = "WINDSHIELD - Hat 2": satirRenkler(4) = RGB(180, 220, 255)
   satirEtiketler(5) = "WINDSHIELD - Hat 3": satirRenkler(5) = RGB(180, 220, 255)
   satirEtiketler(6) = "WINDSHIELD - Hat 4": satirRenkler(6) = RGB(180, 220, 255)
   satirEtiketler(7) = "WINDSHIELD - Hat 5": satirRenkler(7) = RGB(180, 220, 255)
   satirEtiketler(8) = "MATE - Hat 1": satirRenkler(8) = RGB(200, 255, 200)
   satirEtiketler(9) = "MATE - Hat 2": satirRenkler(9) = RGB(200, 255, 200)
   satirEtiketler(10) = "MATE - Hat 3": satirRenkler(10) = RGB(200, 255, 200)
   satirEtiketler(11) = "MATE - Hat 4": satirRenkler(11) = RGB(200, 255, 200)
   satirEtiketler(12) = "MATE - Hat 5": satirRenkler(12) = RGB(200, 255, 200)
   satirEtiketler(13) = "OUT OF": satirRenkler(13) = RGB(255, 200, 160)
   satirEtiketler(14) = "LAY OFF": satirRenkler(14) = RGB(220, 200, 255)
   satirEtiketler(15) = "BOYA": satirRenkler(15) = RGB(255, 180, 180)
   satirEtiketler(16) = "SEALANT": satirRenkler(16) = RGB(200, 240, 240)
   satirEtiketler(17) = "FINAL": satirRenkler(17) = RGB(180, 255, 180)
 
   ws.Range(ws.Cells(baseRow + 3, C_AYADI), ws.Cells(baseRow + 3 + DATA_SATIR - 1, C_AYADI)).Merge
   With ws.Cells(baseRow + 3, C_AYADI)
       .Value = A2C_AyAdi(Month(ayBas)): .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
       .Orientation = 90: .Font.Bold = True: .Font.Size = 11
       .Font.Color = RGB(255, 255, 255): .Interior.Color = RGB(0, 80, 160)
   End With
   ws.Columns(C_AYADI).ColumnWidth = 3.5
 
   Dim ll As Integer
   For ll = 1 To DATA_SATIR
       With ws.Cells(baseRow + 2 + ll, C_LABEL)
           .Value = satirEtiketler(ll): .Font.Bold = True: .Font.Size = 8
           .VerticalAlignment = xlCenter: .Interior.Color = satirRenkler(ll)
           .Borders.LineStyle = xlContinuous: .Borders.Weight = xlThin
       End With
   Next ll
   ws.Columns(C_LABEL).ColumnWidth = 18
 
   Dim j As Long, dd As Date, col As Long, gunIdx As Long, gunV As Integer, aktifV As Integer, vv As Integer
   For j = 0 To CLng(aySon - ayBas)
       dd = ayBas + j
       gunIdx = CLng(dd - planBasTarih)
       col = colMap(j)
       gunV = A2C_GunSutunSayisi(gunIdx, planBasTarih)
       aktifV = GunVardiyaSayisi(gunIdx, planBasTarih)
 
       ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow, col + gunV - 1)).Merge
       With ws.Cells(baseRow, col)
           .Value = A2C_GunKisa(dd): .HorizontalAlignment = xlCenter: .Font.Size = 7: .Font.Bold = True
       End With
       ws.Range(ws.Cells(baseRow + 1, col), ws.Cells(baseRow + 1, col + gunV - 1)).Merge
       With ws.Cells(baseRow + 1, col)
           .Value = Day(dd): .HorizontalAlignment = xlCenter: .Font.Size = 8: .Font.Bold = True
       End With
       For vv = 0 To gunV - 1
           With ws.Cells(baseRow + 2, col + vv)
               If vv < aktifV And Not TatilMiGun(gunIdx, planBasTarih) Then
                   .Value = "S" & (vv + 1)
               Else
                   .Value = ""
               End If
               .HorizontalAlignment = xlCenter: .Font.Size = 7: .Font.Bold = True
               .Borders.LineStyle = xlContinuous: .Borders.Weight = xlThin
           End With
           ws.Columns(col + vv).ColumnWidth = 4
       Next vv
       If TatilMiGun(gunIdx, planBasTarih) Or aktifV = 0 Then
           ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + gunV - 1)).Interior.Color = RGB(215, 215, 215)
           If Weekday(dd, vbMonday) = 6 Or Weekday(dd, vbMonday) = 7 Then ws.Cells(baseRow, col).Font.Color = RGB(180, 0, 0)
       End If
   Next j
 
   Dim lastCol As Long: lastCol = colMap(CLng(aySon - ayBas) + 1) - 1
   ws.Range(ws.Cells(baseRow, C_VERI), ws.Cells(baseRow + 2, lastCol)).Borders.LineStyle = xlContinuous
   ws.Range(ws.Cells(baseRow + 3, C_VERI), ws.Cells(baseRow + 2 + DATA_SATIR, lastCol)).Borders.LineStyle = xlContinuous
   ws.Range(ws.Cells(baseRow + 3, C_VERI), ws.Cells(baseRow + 2 + DATA_SATIR, lastCol)).Borders.Weight = xlHairline
   ws.Rows(baseRow).RowHeight = 14: ws.Rows(baseRow + 1).RowHeight = 16: ws.Rows(baseRow + 2).RowHeight = 12
   Dim rr2 As Integer
   For rr2 = 3 To 2 + DATA_SATIR: ws.Rows(baseRow + rr2).RowHeight = 16: Next rr2
End Sub
 
Sub A2C_PlaniAyaCiz(ws As Worksheet, plan() As Variant, ucakSayisi As Long, ilkUcak As Long, _
   planBasTarih As Date, ayBas As Date, aySon As Date, baseRow As Long, colMap() As Long)
   Dim ui As Long, kayitIdx As Long, ucakNo As Long, renk As Long
   Dim pIst As Integer, pHat As Integer, pBasGun As Long, pBitGun As Long
   Dim pBasSaat As Double, pBitSaat As Double
   Dim opBasDt As Date, opBitDt As Date, satir As Long
   Dim j As Long, dd As Date, gunIdx As Long, aktifV As Integer, vv As Integer
   Dim vBasDt As Date, vBitDt As Date, col As Long
 
   For ui = 0 To ucakSayisi - 1
       ucakNo = ilkUcak + ui
       renk = A2C_UcakRenk(ui)
       For kayitIdx = 0 To A2C_MAX_KAYIT - 1
           If plan(ui, kayitIdx, 0) = -1 Then Exit For
           pIst = CInt(plan(ui, kayitIdx, 0)): pHat = CInt(plan(ui, kayitIdx, 1))
           pBasGun = CLng(plan(ui, kayitIdx, 3)): pBasSaat = CDbl(plan(ui, kayitIdx, 4))
           pBitGun = CLng(plan(ui, kayitIdx, 5)): pBitSaat = CDbl(plan(ui, kayitIdx, 6))
           opBasDt = A2C_PlanDateTime(planBasTarih, pBasGun, pBasSaat)
           opBitDt = A2C_PlanDateTime(planBasTarih, pBitGun, pBitSaat)
           If opBitDt < ayBas Or opBasDt > aySon + 1 Then GoTo sonrakiKayit
           satir = A2C_SatirBul(pIst, pHat, baseRow)
           If satir <= 0 Then GoTo sonrakiKayit
           For j = 0 To CLng(aySon - ayBas)
               dd = ayBas + j
               gunIdx = CLng(dd - planBasTarih)
               If gunIdx < 0 Then GoTo sonrakiGun
               aktifV = GunVardiyaSayisi(gunIdx, planBasTarih)
               If aktifV <= 0 Or TatilMiGun(gunIdx, planBasTarih) Then GoTo sonrakiGun
               For vv = 0 To aktifV - 1
                   vBasDt = A2C_VardiyaBasDate(dd, vv)
                   vBitDt = A2C_VardiyaBitDate(dd, vv)
                   If opBasDt < vBitDt And opBitDt > vBasDt Then
                       col = colMap(CLng(dd - ayBas)) + vv
                       Call A2C_YazTekHucre(ws, satir, col, ucakNo, renk)
                   End If
               Next vv
sonrakiGun:
           Next j
sonrakiKayit:
       Next kayitIdx
   Next ui
End Sub
 
Sub A2C_AylikPlanOlustur(plan() As Variant, ucakSayisi As Long, ilkUcak As Long, _
   planBasTarih As Date, gunSayisi As Long)
   On Error GoTo Hata
   Dim ws As Worksheet
   Application.DisplayAlerts = False
   On Error Resume Next: ThisWorkbook.Sheets("OtomatikPlan").Delete: On Error GoTo Hata
   Application.DisplayAlerts = True
   Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   ws.Name = "OtomatikPlan": ws.Cells.Font.Name = "Calibri"
 
   Const BLOK_YUK As Integer = 21
   Dim planSonTarih As Date: planSonTarih = planBasTarih + gunSayisi - 1
   Dim aySayisi As Integer
   aySayisi = DateDiff("m", DateSerial(Year(planBasTarih), Month(planBasTarih), 1), _
                            DateSerial(Year(planSonTarih), Month(planSonTarih), 1)) + 1
   Dim mm As Integer
   For mm = 0 To aySayisi - 1
       Dim ayBas As Date: ayBas = DateAdd("m", mm, DateSerial(Year(planBasTarih), Month(planBasTarih), 1))
       Dim aySon As Date: aySon = DateSerial(Year(ayBas), Month(ayBas) + 1, 0)
       Dim baseRow As Long: baseRow = 1 + mm * BLOK_YUK
       Dim colMap() As Long
       Call A2C_AySutunHaritasi(ayBas, aySon, planBasTarih, colMap)
       Call A2C_BasliklariCiz(ws, baseRow, ayBas, aySon, planBasTarih, colMap)
       Call A2C_PlaniAyaCiz(ws, plan, ucakSayisi, ilkUcak, planBasTarih, ayBas, aySon, baseRow, colMap)
   Next mm
   ws.Activate: ws.Cells(1, 3).Select: ActiveWindow.FreezePanes = True: ws.Cells(1, 1).Select
   Exit Sub
Hata:
   MsgBox "OtomatikPlan hatasi: " & Err.Description, vbCritical
End Sub
 
