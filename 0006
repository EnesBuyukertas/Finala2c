Sub A2C_PinUygula(ByRef gun As Long, ByRef saat As Double, pinDeger As Double, basTarih As Date)
   If pinDeger <= 0 Then Exit Sub
   Dim pinT As Date: pinT = CDate(pinDeger)
   Dim pinGun As Long: pinGun = CLng(pinT - basTarih)
   Dim pinSaat As Double: pinSaat = 7#
   If pinGun > gun Or (pinGun = gun And pinSaat > saat) Then
       gun = pinGun: saat = pinSaat
       Call IlkUygunZaman(gun, saat, basTarih)
   End If
End Sub
 
Function A2C_DateTimeYaz(basTarih As Date, gunIdx As Long, saatVal As Double) As Date
