Function A2C_UcakSatiriBul(ws As Worksheet, ucakNo As Long) As Long
   Dim sonSatir As Long: sonSatir = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
   Dim r As Long
   For r = 2 To sonSatir
       If IsNumeric(ws.Cells(r, 1).Value) Then
           If CLng(ws.Cells(r, 1).Value) = ucakNo Then
               A2C_UcakSatiriBul = r: Exit Function
           End If
       End If
   Next r
   A2C_UcakSatiriBul = 0
End Function
 
