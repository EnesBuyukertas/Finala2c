' ====================================================
Sub UcakSureDegisimi()
   On Error GoTo Hata
   If Not A2C_SheetVarMi("PlanDetay") Then MsgBox "Once PlanOlustur calistirin!", vbExclamation: Exit Sub
   Dim ws As Worksheet: Set ws = ThisWorkbook.Sheets("PlanDetay")
   Dim ucakNo As Long: ucakNo = CLng(InputBox("Ucak numarasi:", "Sure Degisimi"))
   Dim r As Long: r = A2C_UcakSatiriBul(ws, ucakNo)
   If r = 0 Then MsgBox "Ucak bulunamadi!", vbExclamation: Exit Sub
   Dim asamaNo As Integer
   asamaNo = CInt(InputBox(A2C_StageSecimiMesaji(), "Sure Degisimi", "1"))
   If asamaNo < 1 Or asamaNo > 8 Then MsgBox "Gecersiz asama!", vbExclamation: Exit Sub
   Dim degisim As Double: degisim = CDbl(InputBox("Kac saat degisim? (+ arttir, - azalt)", "Sure Degisimi", "2"))
   Dim col As Long: col = 3 + (asamaNo - 1)
   If Not IsNumeric(ws.Cells(r, col).Value) Then ws.Cells(r, col).Value = 0
   ws.Cells(r, col).Value = CDbl(ws.Cells(r, col).Value) + degisim
   MsgBox "Kaydedildi. PlanOlustur'u tekrar calistirin.", vbInformation
   Exit Sub
Hata: MsgBox "Hata: " & Err.Description, vbCritical
End Sub
 
' ====================================================
' MAKRO: DURUS EKLEME
' Ucak no ve durus saatini sorar, plani yeniden olusturur
' ====================================================
Sub DurusEkleme()
   On Error GoTo Hata
   If Not A2C_SheetVarMi("PlanDetay") Then
       MsgBox "Once PlanOlustur calistirin!", vbExclamation: Exit Sub
   End If
   If gPlanUcakSayisi = 0 Then
       MsgBox "Once PlanOlustur calistirin! (Global plan verisi bos)", vbExclamation: Exit Sub
   End If
 
   Dim ws As Worksheet: Set ws = ThisWorkbook.Sheets("PlanDetay")
 
   ' Ucak no sor
   Dim ucakNoStr As String
   ucakNoStr = InputBox("Hangi ucaga durus eklenecek? (Ucak numarasi girin):", "Durus Ekleme")
   If Trim(ucakNoStr) = "" Then Exit Sub
   Dim ucakNo As Long: ucakNo = CLng(ucakNoStr)
 
   Dim r As Long: r = A2C_UcakSatiriBul(ws, ucakNo)
   If r = 0 Then
       MsgBox "Ucak " & ucakNo & " bulunamadi! PlanDetay'da kayitli degil.", vbExclamation: Exit Sub
   End If
 
   ' Mevcut durusa bak
   Dim mevcutDurus As Double: mevcutDurus = 0
   If IsNumeric(ws.Cells(r, 2).Value) Then mevcutDurus = CDbl(ws.Cells(r, 2).Value)
 
   ' Kac saat sor
   Dim degisimStr As String
   degisimStr = InputBox("Kac saat durus?" & vbCrLf & _
                         "(+ ekler, - azaltir. Ornek: 7 veya -3)" & vbCrLf & _
                         "Mevcut durus: " & mevcutDurus & " saat", "Durus Ekleme", "7")
   If Trim(degisimStr) = "" Then Exit Sub
   Dim degisim As Double: degisim = CDbl(degisimStr)
 
   Dim yeniDurus As Double: yeniDurus = Application.Max(0, mevcutDurus + degisim)
   ws.Cells(r, 2).Value = yeniDurus
 
   ' Mevcut ayarlarla plani yeniden hesapla ve ciz
   Application.ScreenUpdating = False
   Call PlanHesaplaVeCiz
   Application.ScreenUpdating = True
 
   MsgBox "Durus guncellendi ve plan yeniden olusturuldu!" & vbCrLf & _
          "Ucak " & ucakNo & ": " & yeniDurus & " saat durus.", vbInformation
   Exit Sub
Hata: MsgBox "Hata: " & Err.Description, vbCritical
End Sub
 
