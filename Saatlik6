Sub StepTarihDegisimi()
   On Error GoTo Hata4
   If Not AyarlariOku() Then MsgBox "Once UretimPlaniOlustur calistirin!", vbExclamation: Exit Sub
 
   Dim wsP As Worksheet: Set wsP = ThisWorkbook.Sheets("PlanDetay")
   Dim ucakSayisi As Long: ucakSayisi = wsP.Cells(wsP.Rows.Count, 1).End(xlUp).Row - 1
   If ucakSayisi < 1 Then MsgBox "PlanDetay bos!", vbExclamation: Exit Sub
 
   Dim hedefUcak As Long: hedefUcak = CLng(InputBox("Ucak numarasi:", "Step Tarih Degisimi"))
   Dim hedefIdx As Long: hedefIdx = -1
   Dim i As Long
   For i = 0 To ucakSayisi - 1
       If CLng(wsP.Cells(i + 2, 1).Value) = hedefUcak Then hedefIdx = i: Exit For
   Next i
   If hedefIdx = -1 Then MsgBox "Ucak bulunamadi!", vbExclamation: Exit Sub
 
   Dim adimAdi(1 To 8) As String
   adimAdi(1) = "COJI 1": adimAdi(2) = "WINDSHIELD": adimAdi(3) = "MATE"
   adimAdi(4) = "OUT OF": adimAdi(5) = "LAY OFF":    adimAdi(6) = "BOYA"
   adimAdi(7) = "SEALANT": adimAdi(8) = "FINAL"
 
   Dim adimStr As String
   adimStr = InputBox("Hangi adim?" & vbCrLf & _
                      "1=COJI1  2=WINDSHIELD  3=MATE" & vbCrLf & _
                      "4=OUT OF  5=LAY OFF  6=BOYA  7=SEALANT  8=FINAL", "Step Tarih Degisimi", "1")
   Dim adimNo As Integer: adimNo = CInt(adimStr)
   If adimNo < 1 Or adimNo > 8 Then MsgBox "Gecersiz adim!", vbExclamation: Exit Sub
 
   Dim mevcutPin As String: mevcutPin = Format(Now, "DD.MM.YYYY HH:MM")
   Dim pvM As Variant: pvM = wsP.Cells(hedefIdx + 2, 29 + adimNo).Value
   If IsNumeric(pvM) And CDbl(pvM) > 0 Then mevcutPin = Format(CDate(CDbl(pvM)), "DD.MM.YYYY HH:MM")
 
   ' Tum verileri PlanDetay silinmeden once oku
   Dim ucNo() As Long, ucDurus() As Double
   Dim ucC1Sure() As Double, ucWinSure() As Double, ucMateSure() As Double
   Dim ucOutSure() As Double, ucLaySure() As Double, ucBoyaSure() As Double
   Dim ucSealSure() As Double, ucFinalSure() As Double
   ReDim ucNo(0 To ucakSayisi - 1):       ReDim ucDurus(0 To ucakSayisi - 1)
   ReDim ucC1Sure(0 To ucakSayisi - 1):   ReDim ucWinSure(0 To ucakSayisi - 1)
   ReDim ucMateSure(0 To ucakSayisi - 1): ReDim ucOutSure(0 To ucakSayisi - 1)
   ReDim ucLaySure(0 To ucakSayisi - 1):  ReDim ucBoyaSure(0 To ucakSayisi - 1)
   ReDim ucSealSure(0 To ucakSayisi - 1): ReDim ucFinalSure(0 To ucakSayisi - 1)
   Call PlanDetayOku(ucNo, ucDurus, ucC1Sure, ucWinSure, ucMateSure, ucOutSure, ucLaySure, ucBoyaSure, ucSealSure, ucFinalSure, ucakSayisi)
 
   Dim ucPinDt() As Double
   Call PinOku(ucPinDt, ucakSayisi)
 
   ' Yeni tarihi sor
   Dim yeniDt As Double
   yeniDt = TarihSaatGir("Ucak " & hedefUcak & " - " & adimAdi(adimNo) & vbCrLf & _
                          "Yeni baslangic (bos birak=sabitlemeyi kaldir):", mevcutPin)
 
   If yeniDt < 0 Then
       ucPinDt(hedefIdx, adimNo - 1) = 0
   Else
       ucPinDt(hedefIdx, adimNo - 1) = yeniDt
   End If
 
   Application.ScreenUpdating = False
   Call GuncelleVeCiz(ucNo, ucDurus, ucC1Sure, ucWinSure, ucMateSure, ucOutSure, ucLaySure, ucBoyaSure, ucSealSure, ucFinalSure, ucakSayisi)
 
   ' GuncelleVeCiz PinOku'yu cagirip sifirdan okur, o yuzden
   ' dogru pin degerlerini PlanDetay'a tekrar yaziyoruz
   Dim wsP2 As Worksheet: Set wsP2 = ThisWorkbook.Sheets("PlanDetay")
   Dim adm As Integer
   For adm = 0 To 7
       If ucPinDt(hedefIdx, adm) > 0 Then
           wsP2.Cells(hedefIdx + 2, 30 + adm).Value = ucPinDt(hedefIdx, adm)
           wsP2.Cells(hedefIdx + 2, 30 + adm).NumberFormat = "DD.MM.YYYY HH:MM"
           wsP2.Cells(hedefIdx + 2, 30 + adm).Interior.Color = RGB(255, 220, 150)
       Else
           wsP2.Cells(hedefIdx + 2, 30 + adm).Value = 0
           wsP2.Cells(hedefIdx + 2, 30 + adm).Interior.ColorIndex = xlNone
       End If
   Next adm
 
   Application.ScreenUpdating = True
   If yeniDt < 0 Then
       MsgBox "Sabitleme kaldirildi!", vbInformation
   Else
       MsgBox "Ucak " & hedefUcak & " - " & adimAdi(adimNo) & " baslangici sabitlendi!", vbInformation
   End If
   Exit Sub
Hata4:
   Application.ScreenUpdating = True
   MsgBox "Hata: " & Err.Description, vbCritical
End Sub
 
' ====================================================
' GENEL BAKIS SAYFASI
' Saat bazli hesaplarin vardiya bazli ozet gorunumu
' Her hucre = 1 vardiya, ucak no + renk, saat yok
' Ayni vardiyadaki birden fazla ucak alt alta
' ====================================================
Sub GenelBakisOlustur( _
   ucNo() As Long, ucDurus() As Double, _
   ucC1BasDt() As Double, ucC1BitDt() As Double, ucC1Hat() As Integer, _
   ucWinBasDt() As Double, ucWinBitDt() As Double, ucWinHat() As Integer, _
   ucMateBasDt() As Double, ucMateBitDt() As Double, ucMateHat() As Integer, _
   ucOutBasDt() As Double, ucOutBitDt() As Double, _
   ucLayBasDt() As Double, ucLayBitDt() As Double, _
   ucBoyaBasDt() As Double, ucBoyaBitDt() As Double, _
   ucSealBasDt() As Double, ucSealBitDt() As Double, _
   ucFinalBasDt() As Double, ucFinalBitDt() As Double, _
   ucDurusBasDt() As Double, ucDurusBitDt() As Double, _
   ucakSayisi As Long, aySayisi As Integer, enErkenDt As Double)
 
   Dim ws As Worksheet
   On Error Resume Next: Application.DisplayAlerts = False
   ThisWorkbook.Sheets("GenelBakis").Delete
   Application.DisplayAlerts = True: On Error GoTo 0
   Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   ws.Name = "GenelBakis": ws.Cells.Font.Name = "Calibri"
 
   Const DATA_SATIR As Integer = 17
   Const BLOK_YUK   As Integer = 22
 
   Dim satirEtiket(1 To DATA_SATIR) As String
   Dim satirRenk(1 To DATA_SATIR) As Long
   satirEtiket(1) = "COJI 1 - Hat 1":     satirRenk(1) = RGB(255, 255, 180)
   satirEtiket(2) = "COJI 1 - Hat 2":     satirRenk(2) = RGB(255, 255, 180)
   satirEtiket(3) = "WINDSHIELD - Hat 1": satirRenk(3) = RGB(180, 220, 255)
   satirEtiket(4) = "WINDSHIELD - Hat 2": satirRenk(4) = RGB(180, 220, 255)
   satirEtiket(5) = "WINDSHIELD - Hat 3": satirRenk(5) = RGB(180, 220, 255)
   satirEtiket(6) = "WINDSHIELD - Hat 4": satirRenk(6) = RGB(180, 220, 255)
   satirEtiket(7) = "WINDSHIELD - Hat 5": satirRenk(7) = RGB(180, 220, 255)
   satirEtiket(8) = "MATE - Hat 1":       satirRenk(8) = RGB(200, 255, 200)
   satirEtiket(9) = "MATE - Hat 2":       satirRenk(9) = RGB(200, 255, 200)
   satirEtiket(10) = "MATE - Hat 3":      satirRenk(10) = RGB(200, 255, 200)
   satirEtiket(11) = "MATE - Hat 4":      satirRenk(11) = RGB(200, 255, 200)
   satirEtiket(12) = "MATE - Hat 5":      satirRenk(12) = RGB(200, 255, 200)
   satirEtiket(13) = "OUT OF":            satirRenk(13) = RGB(255, 200, 160)
   satirEtiket(14) = "LAY OFF":           satirRenk(14) = RGB(220, 200, 255)
   satirEtiket(15) = "BOYA":              satirRenk(15) = RGB(255, 180, 180)
   satirEtiket(16) = "SEALANT":           satirRenk(16) = RGB(200, 240, 240)
   satirEtiket(17) = "FINAL":             satirRenk(17) = RGB(180, 255, 180)
 
   Dim basAy As Integer: basAy = Month(DtTarih(enErkenDt))
   Dim basYil As Integer: basYil = Year(DtTarih(enErkenDt))
 
   Dim mm As Integer, curAy As Integer, curYil As Integer
   Dim ayBas As Date, aySon As Date, gunSay As Long, baseRow As Long
   Dim col As Long, j As Long, dd As Date, ll As Integer, v As Integer
 
   For mm = 0 To aySayisi - 1
       curAy = basAy + mm
       curYil = basYil
       Do While curAy > 12: curAy = curAy - 12: curYil = curYil + 1: Loop
       ayBas = DateSerial(curYil, curAy, 1)
       aySon = DateSerial(curYil, curAy + 1, 0)
       gunSay = Day(aySon)
       baseRow = 1 + mm * BLOK_YUK
 
       ' Ay etiketi
       ws.Range(ws.Cells(baseRow + 3, C_AYADI), ws.Cells(baseRow + 3 + DATA_SATIR - 1, C_AYADI)).Merge
       With ws.Cells(baseRow + 3, C_AYADI)
           .Value = AyAdi(curAy): .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
           .Orientation = 90: .Font.Bold = True: .Font.Size = 11
           .Font.Color = RGB(255, 255, 255): .Interior.Color = RGB(0, 80, 160)
       End With
       ws.Columns(C_AYADI).ColumnWidth = 3.5
 
       ' Satir etiketleri
       For ll = 1 To DATA_SATIR
           With ws.Cells(baseRow + 2 + ll, C_LABEL)
               .Value = satirEtiket(ll): .Font.Bold = True: .Font.Size = 8
               .VerticalAlignment = xlCenter: .Interior.Color = satirRenk(ll)
           End With
       Next ll
       ws.Columns(C_LABEL).ColumnWidth = 18
 
       ' Gunleri ve vardiyeleri olustur
       col = C_VERI
       For j = 0 To gunSay - 1
           dd = ayBas + j
           If TatilMi(dd) Then
               ws.Cells(baseRow, col).Value = GunKisa(dd) & " " & Day(dd)
               ws.Cells(baseRow, col).Font.Size = 7: ws.Cells(baseRow, col).Font.Bold = True
               ws.Cells(baseRow, col).HorizontalAlignment = xlCenter
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col)).Interior.Color = RGB(215, 215, 215)
               If Weekday(dd, vbMonday) = 7 Then ws.Cells(baseRow, col).Font.Color = RGB(180, 0, 0)
               ws.Columns(col).ColumnWidth = 6
               col = col + 1
           Else
               ' Gun etiketi
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow, col + gNormalVardiya - 1)).Merge
               ws.Cells(baseRow, col).Value = GunKisa(dd) & " " & Day(dd)
               ws.Cells(baseRow, col).HorizontalAlignment = xlCenter
               ws.Cells(baseRow, col).Font.Size = 8: ws.Cells(baseRow, col).Font.Bold = True
 
               Dim vBasStr As String, vBitStr As String
               For v = 1 To gNormalVardiya
                   Dim vCol As Long: vCol = col + v - 1
                   ws.Cells(baseRow + 1, vCol).Value = "S" & v
                   ws.Cells(baseRow + 1, vCol).HorizontalAlignment = xlCenter
                   ws.Cells(baseRow + 1, vCol).Font.Size = 7: ws.Cells(baseRow + 1, vCol).Font.Bold = True
                   Select Case v
                       Case 1: vBasStr = "07:00": vBitStr = "15:00"
                       Case 2: vBasStr = "15:00": vBitStr = "23:00"
                       Case 3: vBasStr = "23:00": vBitStr = "07:00"
                   End Select
                   ws.Cells(baseRow + 2, vCol).Value = vBasStr & "-" & vBitStr
                   ws.Cells(baseRow + 2, vCol).HorizontalAlignment = xlCenter
                   ws.Cells(baseRow + 2, vCol).Font.Size = 6
                   ws.Columns(vCol).ColumnWidth = 6
               Next v
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + gNormalVardiya - 1)).Borders.LineStyle = xlContinuous
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + gNormalVardiya - 1)).Borders.Weight = xlHairline
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + gNormalVardiya - 1)).Borders.Color = RGB(180, 180, 180)
               col = col + gNormalVardiya
           End If
       Next j
 
       ' Satir yukseklikleri
       ws.Rows(baseRow).RowHeight = 14: ws.Rows(baseRow + 1).RowHeight = 14: ws.Rows(baseRow + 2).RowHeight = 12
       For ll = 3 To 2 + DATA_SATIR: ws.Rows(baseRow + ll).RowHeight = 18: Next ll
 
       ' Ucaklari ciz - saat yok, sadece ucak no ve renk
       Dim ui As Long
       For ui = 0 To ucakSayisi - 1
           Dim rnk As Long: rnk = UcakRenk(ui)
           Call GenelBakisYaz(ws, ucNo(ui), rnk, ucC1BasDt(ui), ucC1BitDt(ui), baseRow + 2 + ucC1Hat(ui), ayBas, aySon, C_VERI, False)
           Call GenelBakisYaz(ws, ucNo(ui), rnk, ucWinBasDt(ui), ucWinBitDt(ui), baseRow + 2 + 2 + ucWinHat(ui), ayBas, aySon, C_VERI, False)
           Call GenelBakisYaz(ws, ucNo(ui), rnk, ucMateBasDt(ui), ucMateBitDt(ui), baseRow + 2 + 7 + ucMateHat(ui), ayBas, aySon, C_VERI, False)
           Call GenelBakisYaz(ws, ucNo(ui), rnk, ucOutBasDt(ui), ucOutBitDt(ui), baseRow + 15, ayBas, aySon, C_VERI, False)
           Call GenelBakisYaz(ws, ucNo(ui), rnk, ucLayBasDt(ui), ucLayBitDt(ui), baseRow + 16, ayBas, aySon, C_VERI, False)
           Call GenelBakisYaz(ws, ucNo(ui), rnk, ucBoyaBasDt(ui), ucBoyaBitDt(ui), baseRow + 17, ayBas, aySon, C_VERI, False)
           Call GenelBakisYaz(ws, ucNo(ui), rnk, ucSealBasDt(ui), ucSealBitDt(ui), baseRow + 18, ayBas, aySon, C_VERI, False)
           Call GenelBakisYaz(ws, ucNo(ui), rnk, ucFinalBasDt(ui), ucFinalBitDt(ui), baseRow + 19, ayBas, aySon, C_VERI, False)
           If ucDurus(ui) > 0 Then
               Call GenelBakisYaz(ws, ucNo(ui), RGB(50, 50, 50), ucDurusBasDt(ui), ucDurusBitDt(ui), baseRow + 2 + ucC1Hat(ui), ayBas, aySon, C_VERI, True)
           End If
       Next ui
   Next mm
 
   ws.Activate: ws.Cells(1, C_VERI).Select: ActiveWindow.FreezePanes = True: ws.Cells(1, 1).Select
End Sub
 
'Genel bakis icin hucre yaz - YazUcakVardiya ile ayni mantik, saat gosterilmez
Sub GenelBakisYaz(ws As Worksheet, ucakNo As Long, rnk As Long, _
   basDt As Double, bitDt As Double, satirNo As Long, _
   ayBas As Date, aySon As Date, veriBasCol As Long, isDurus As Boolean)
 
   Dim gunSay As Long: gunSay = Day(aySon)
   Dim col As Long: col = veriBasCol
   Dim j As Long, dd As Date, v As Integer
 
   For j = 0 To gunSay - 1
       dd = ayBas + j
       If TatilMi(dd) Then
           col = col + 1
       Else
           For v = 1 To gNormalVardiya
               Dim vCol As Long: vCol = col + v - 1
               Dim vBas As Double, vBit As Double
               If v = 3 Then
                   vBas = CDbl(dd) + 23# * 60# / 1440#
                   vBit = CDbl(dd) + 1# + 7# * 60# / 1440#
               Else
                   vBas = CDbl(dd) + CDbl(VardiyaBasDak(v)) / 1440#
                   vBit = CDbl(dd) + CDbl(VardiyaBitDak(v)) / 1440#
               End If
 
               If basDt < vBit And bitDt > vBas Then
                   Dim mevcut As String
                   If ws.Cells(satirNo, vCol).Value <> "" Then
                       mevcut = CStr(ws.Cells(satirNo, vCol).Value) & Chr(10)
                   Else
                       mevcut = ""
                   End If
                   If isDurus Then
                       ws.Cells(satirNo, vCol).Value = mevcut & "DURUS"
                       ws.Cells(satirNo, vCol).Interior.Color = RGB(50, 50, 50)
                       ws.Cells(satirNo, vCol).Font.Color = RGB(255, 255, 255)
                   Else
                       ws.Cells(satirNo, vCol).Value = mevcut & CStr(ucakNo)
                       ws.Cells(satirNo, vCol).Interior.Color = rnk
                       ws.Cells(satirNo, vCol).Font.Color = RGB(0, 0, 0)
                   End If
                   ws.Cells(satirNo, vCol).Font.Size = 7: ws.Cells(satirNo, vCol).Font.Bold = True
                   ws.Cells(satirNo, vCol).HorizontalAlignment = xlCenter
                   ws.Cells(satirNo, vCol).VerticalAlignment = xlCenter
                   ws.Cells(satirNo, vCol).WrapText = True
               End If
           Next v
           col = col + gNormalVardiya
       End If
   Next j
End Sub
