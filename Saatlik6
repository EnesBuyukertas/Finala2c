Option Explicit
 
' ====================================================
' GLOBAL DEGISKENLER
' ====================================================
Public gNormalVardiya As Integer
Public gTatilTarihBas() As Date
Public gTatilTarihBit() As Date
Public gTatilCalis() As Boolean
Public gTatilSayisi As Integer
 
' ====================================================
' SABITLER - ADIM SURELERI (SAAT)
' ====================================================
Const COJI1_SURE_SAAT      As Double = 87.5
Const WINDSHIELD_SURE_SAAT As Double = 85#
Const MATE_SURE_SAAT       As Double = 102.5
Const OUTOF_SURE_SAAT      As Double = 83#
Const LAYOFF_SURE_SAAT     As Double = 48.5
Const BOYA_SURE_SAAT       As Double = 30#
Const SEALANT_SURE_SAAT    As Double = 22.5
Const FINAL_SURE_SAAT      As Double = 30#
 
Const COJI1_HAT As Integer = 2
Const COJI2_HAT As Integer = 5
 
Const C_AYADI As Integer = 1
Const C_LABEL As Integer = 2
Const C_VERI  As Integer = 3
 
' ====================================================
' VARDIYA TANIMLARI
' S1: 07:00-15:00, mola 11:30-12:30 -> net 7 saat
' S2: 15:00-23:00, mola 18:00-19:00 -> net 7 saat
' S3: 23:00-07:00, mola 03:30-04:30 -> net 7 saat
' Dakika = gun icindeki dakika (0=00:00)
' ====================================================
Function VardiyaBasDak(vNo As Integer) As Long
   Select Case vNo
       Case 1: VardiyaBasDak = 7 * 60
       Case 2: VardiyaBasDak = 15 * 60
       Case 3: VardiyaBasDak = 23 * 60
       Case Else: VardiyaBasDak = 0
   End Select
End Function
 
Function VardiyaBitDak(vNo As Integer) As Long
   Select Case vNo
       Case 1: VardiyaBitDak = 15 * 60
       Case 2: VardiyaBitDak = 23 * 60
       Case 3: VardiyaBitDak = 24 * 60 + 7 * 60  ' 31*60 = ertesi gun 07:00
       Case Else: VardiyaBitDak = 0
   End Select
End Function
 
Function MolaBasDak(vNo As Integer) As Long
   Select Case vNo
       Case 1: MolaBasDak = 11 * 60 + 30
       Case 2: MolaBasDak = 18 * 60
       Case 3: MolaBasDak = 24 * 60 + 3 * 60 + 30
       Case Else: MolaBasDak = 0
   End Select
End Function
 
Function MolaBitDak(vNo As Integer) As Long
   Select Case vNo
       Case 1: MolaBitDak = 12 * 60 + 30
       Case 2: MolaBitDak = 19 * 60
       Case 3: MolaBitDak = 24 * 60 + 4 * 60 + 30
       Case Else: MolaBitDak = 0
   End Select
End Function
 
' ====================================================
' ZAMAN FONKSIYONLARI
' DateTime = Excel serial number (gun + saat/1440)
' ====================================================
 
' DateTime'den saat string (HH:MM)
Function DtSaat(dt As Double) As String
   Dim toplamDak As Long
   toplamDak = CLng((dt - Int(dt)) * 1440 + 0.5)
   toplamDak = toplamDak Mod 1440
   If toplamDak < 0 Then toplamDak = toplamDak + 1440
   DtSaat = Format(toplamDak \ 60, "00") & ":" & Format(toplamDak Mod 60, "00")
End Function
 
' DateTime'den tarih
Function DtTarih(dt As Double) As Date
   DtTarih = CDate(Int(dt))
End Function
 
' Hangi vardiyadayiz? 0 = vardiya disinda
Function HangiVardiya(dt As Double) As Integer
   Dim gunDak As Long
   gunDak = CLng((dt - Int(dt)) * 1440 + 0.5) Mod 1440
   If gunDak < 0 Then gunDak = gunDak + 1440
 
   Dim v As Integer
   For v = 1 To gNormalVardiya
       If v = 3 Then
           ' Gece vardiyas: 23:00 - 07:00
           If gunDak >= 23 * 60 Or gunDak < 7 * 60 Then
               HangiVardiya = v: Exit Function
           End If
       Else
           If gunDak >= VardiyaBasDak(v) And gunDak < VardiyaBitDak(v) Then
               HangiVardiya = v: Exit Function
           End If
       End If
   Next v
   HangiVardiya = 0
End Function
 
' Vardiyanin bitis DateTime
Function VardiyaBitisDt(dt As Double, vNo As Integer) As Double
   Dim gun As Long: gun = Int(dt)
   Dim gunDak As Long: gunDak = CLng((dt - Int(dt)) * 1440 + 0.5) Mod 1440
   If gunDak < 0 Then gunDak = gunDak + 1440
 
   If vNo = 3 Then
       If gunDak < 7 * 60 Then
           VardiyaBitisDt = gun + 7 * 60 / 1440#
       Else
           VardiyaBitisDt = gun + 1 + 7 * 60 / 1440#
       End If
   Else
       VardiyaBitisDt = gun + VardiyaBitDak(vNo) / 1440#
   End If
End Function
 
' Vardiyanin mola baslangic DateTime
Function MolaBasDt(dt As Double, vNo As Integer) As Double
   Dim gun As Long: gun = Int(dt)
   Dim gunDak As Long: gunDak = CLng((dt - Int(dt)) * 1440 + 0.5) Mod 1440
   If gunDak < 0 Then gunDak = gunDak + 1440
 
   If vNo = 3 Then
       If gunDak < 7 * 60 Then
           MolaBasDt = gun + (3 * 60 + 30) / 1440#
       Else
           MolaBasDt = gun + 1 + (3 * 60 + 30) / 1440#
       End If
   Else
       MolaBasDt = gun + MolaBasDak(vNo) / 1440#
   End If
End Function
 
' Vardiyanin mola bitis DateTime
Function MolaBitDt(dt As Double, vNo As Integer) As Double
   Dim gun As Long: gun = Int(dt)
   Dim gunDak As Long: gunDak = CLng((dt - Int(dt)) * 1440 + 0.5) Mod 1440
   If gunDak < 0 Then gunDak = gunDak + 1440
 
   If vNo = 3 Then
       If gunDak < 7 * 60 Then
           MolaBitDt = gun + (4 * 60 + 30) / 1440#
       Else
           MolaBitDt = gun + 1 + (4 * 60 + 30) / 1440#
       End If
   Else
       MolaBitDt = gun + MolaBitDak(vNo) / 1440#
   End If
End Function
 
' Bir sonraki vardiyanin baslangic DateTime
Function SonrakiVardiyaBas(dt As Double) As Double
   Dim gun As Long: gun = Int(dt)
   Dim gunDak As Long: gunDak = CLng((dt - Int(dt)) * 1440 + 0.5) Mod 1440
   If gunDak < 0 Then gunDak = gunDak + 1440
 
   Dim v As Integer
   For v = 1 To gNormalVardiya
       If VardiyaBasDak(v) > gunDak Then
           SonrakiVardiyaBas = gun + VardiyaBasDak(v) / 1440#
           Exit Function
       End If
   Next v
   ' Bu gunde vardiya kalmadi, ertesi gun S1
   SonrakiVardiyaBas = gun + 1 + VardiyaBasDak(1) / 1440#
End Function
 
' Verilen dt'ye net saat ekle (molalari ve tatilleri atlayarak)
Function SaatEkle(basDt As Double, netSaat As Double) As Double
   Dim kalan As Double: kalan = netSaat
   Dim simdi As Double: simdi = basDt
 
   Dim guvenceSayac As Long: guvenceSayac = 0
 
   Do While kalan > 0.0001
       guvenceSayac = guvenceSayac + 1
       If guvenceSayac > 100000 Then Exit Do  ' sonsuz dongu onlemi
 
       ' Tatil kontrolu
       If TatilMi(DtTarih(simdi)) Then
           simdi = SonrakiCalismaDt(simdi)
       End If
 
       Dim vNo As Integer: vNo = HangiVardiya(simdi)
       If vNo = 0 Then
           simdi = SonrakiVardiyaBas(simdi)
           ' Tatil olabilir
           If TatilMi(DtTarih(simdi)) Then
               simdi = SonrakiCalismaDt(simdi)
           End If
       Else
           Dim mBas As Double: mBas = MolaBasDt(simdi, vNo)
           Dim mBit As Double: mBit = MolaBitDt(simdi, vNo)
           Dim vBit As Double: vBit = VardiyaBitisDt(simdi, vNo)
 
           ' Molada miyiz?
           If simdi >= mBas And simdi < mBit Then
               simdi = mBit
           End If
 
           ' Vardiyanin kalanini hesapla (molasiz)
           Dim netKalan As Double
           If simdi < mBas Then
               ' Moladan once
               Dim molayaKadar As Double: molayaKadar = (mBas - simdi) * 24#
               Dim molaSonrasiKadar As Double: molaSonrasiKadar = (vBit - mBit) * 24#
               netKalan = molayaKadar + molaSonrasiKadar
 
               If kalan <= molayaKadar Then
                   ' Moladan once biter
                   simdi = simdi + kalan / 24#
                   kalan = 0
               ElseIf kalan <= netKalan Then
                   ' Moladan sonra biter, bu vardiyanin icinde
                   simdi = mBit + (kalan - molayaKadar) / 24#
                   kalan = 0
               Else
                   ' Bu vardiyanin tamami kullanildi
                   kalan = kalan - netKalan
                   simdi = SonrakiVardiyaBas(vBit)
                   If TatilMi(DtTarih(simdi)) Then simdi = SonrakiCalismaDt(simdi)
               End If
           Else
               ' Moladan sonra
               netKalan = (vBit - simdi) * 24#
               If netKalan <= 0 Then
                   simdi = SonrakiVardiyaBas(vBit)
                   If TatilMi(DtTarih(simdi)) Then simdi = SonrakiCalismaDt(simdi)
               ElseIf kalan <= netKalan Then
                   simdi = simdi + kalan / 24#
                   kalan = 0
               Else
                   kalan = kalan - netKalan
                   simdi = SonrakiVardiyaBas(vBit)
                   If TatilMi(DtTarih(simdi)) Then simdi = SonrakiCalismaDt(simdi)
               End If
           End If
       End If
   Loop
 
   SaatEkle = simdi
End Function
 
' Tatili atlayarak ilk calisma gununu bul
Function SonrakiCalismaDt(dt As Double) As Double
   Dim d As Date: d = DtTarih(dt)
   Do While TatilMi(d): d = d + 1: Loop
   SonrakiCalismaDt = CDbl(d) + VardiyaBasDak(1) / 1440#
End Function
 
' Tatil gunundeyse sonraki is gunune at, vardiyadaysa orada kal
Function TatilAtlaVeVardiyaBul(dt As Double) As Double
   Dim d As Date: d = DtTarih(dt)
   If TatilMi(d) Then
       dt = SonrakiCalismaDt(dt)
   End If
   If HangiVardiya(dt) = 0 Then
       dt = SonrakiVardiyaBas(dt)
       d = DtTarih(dt)
       If TatilMi(d) Then dt = SonrakiCalismaDt(dt)
   End If
   TatilAtlaVeVardiyaBul = dt
End Function
 
