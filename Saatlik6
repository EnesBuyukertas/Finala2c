' ====================================================
' ANA HESAPLAMA
' ====================================================
Sub TumHesapla( _
   ucNo() As Long, ucDurus() As Double, _
   ucC1Sure() As Double, ucWinSure() As Double, ucMateSure() As Double, _
   ucOutSure() As Double, ucLaySure() As Double, ucBoyaSure() As Double, _
   ucSealSure() As Double, ucFinalSure() As Double, _
   ucakSayisi As Long, c1BasDt As Double, c2BasDt As Double, _
   ucPinDt() As Double, _
   ucDurusBasDt() As Double, ucDurusBitDt() As Double, _
   ucC1BasDt() As Double, ucC1BitDt() As Double, ucC1Hat() As Integer, _
   ucWinBasDt() As Double, ucWinBitDt() As Double, ucWinHat() As Integer, _
   ucMateBasDt() As Double, ucMateBitDt() As Double, ucMateHat() As Integer, _
   ucOutBasDt() As Double, ucOutBitDt() As Double, _
   ucLayBasDt() As Double, ucLayBitDt() As Double, _
   ucBoyaBasDt() As Double, ucBoyaBitDt() As Double, _
   ucSealBasDt() As Double, ucSealBitDt() As Double, _
   ucFinalBasDt() As Double, ucFinalBitDt() As Double)
 
   ReDim ucDurusBasDt(0 To ucakSayisi - 1): ReDim ucDurusBitDt(0 To ucakSayisi - 1)
   ReDim ucC1BasDt(0 To ucakSayisi - 1):    ReDim ucC1BitDt(0 To ucakSayisi - 1):  ReDim ucC1Hat(0 To ucakSayisi - 1)
   ReDim ucWinBasDt(0 To ucakSayisi - 1):   ReDim ucWinBitDt(0 To ucakSayisi - 1): ReDim ucWinHat(0 To ucakSayisi - 1)
   ReDim ucMateBasDt(0 To ucakSayisi - 1):  ReDim ucMateBitDt(0 To ucakSayisi - 1):ReDim ucMateHat(0 To ucakSayisi - 1)
   ReDim ucOutBasDt(0 To ucakSayisi - 1):   ReDim ucOutBitDt(0 To ucakSayisi - 1)
   ReDim ucLayBasDt(0 To ucakSayisi - 1):   ReDim ucLayBitDt(0 To ucakSayisi - 1)
   ReDim ucBoyaBasDt(0 To ucakSayisi - 1):  ReDim ucBoyaBitDt(0 To ucakSayisi - 1)
   ReDim ucSealBasDt(0 To ucakSayisi - 1):  ReDim ucSealBitDt(0 To ucakSayisi - 1)
   ReDim ucFinalBasDt(0 To ucakSayisi - 1): ReDim ucFinalBitDt(0 To ucakSayisi - 1)
 
   ' Hat kuyruk pozisyonlari
   Dim c1Son(1 To COJI1_HAT) As Double
   Dim c2Son(1 To COJI2_HAT) As Double
   Dim h As Integer
   For h = 1 To COJI1_HAT: c1Son(h) = c1BasDt: Next h
   For h = 1 To COJI2_HAT: c2Son(h) = c2BasDt: Next h
 
   Dim enErken As Double
   If c1BasDt < c2BasDt Then enErken = c1BasDt Else enErken = c2BasDt
   Dim outSon As Double: outSon = enErken
   Dim laySon As Double: laySon = enErken
   Dim boyaSon As Double: boyaSon = enErken
   Dim sealSon As Double: sealSon = enErken
   Dim finalSon As Double: finalSon = enErken
 
   Dim i As Long
   Dim sBas As Double, sBit As Double
   Dim enDusuk As Double
   Dim c1H As Integer, c2H As Integer
   Dim pinDt As Double
 
   For i = 0 To ucakSayisi - 1
 
       ' --- DURUS ---
       If ucDurus(i) > 0 Then
           enDusuk = c1Son(1): c1H = 1
           For h = 2 To COJI1_HAT
               If c1Son(h) < enDusuk Then enDusuk = c1Son(h): c1H = h
           Next h
           sBas = TatilAtlaVeVardiyaBul(c1Son(c1H))
           ucDurusBasDt(i) = sBas
           sBit = SaatEkle(sBas, ucDurus(i))
           ucDurusBitDt(i) = sBit
           c1Son(c1H) = sBit
       End If
 
       ' --- COJI1 ---
       enDusuk = c1Son(1): c1H = 1
       For h = 2 To COJI1_HAT
           If c1Son(h) < enDusuk Then enDusuk = c1Son(h): c1H = h
       Next h
       sBas = TatilAtlaVeVardiyaBul(c1Son(c1H))
       If ucPinDt(i, 0) > 0 Then
           pinDt = TatilAtlaVeVardiyaBul(ucPinDt(i, 0))
           If pinDt > sBas Then sBas = pinDt
       End If
       ucC1BasDt(i) = sBas: ucC1Hat(i) = c1H
       sBit = SaatEkle(sBas, ucC1Sure(i))
       ucC1BitDt(i) = sBit: c1Son(c1H) = sBit
 
       ' --- WINDSHIELD (COJI2, COJI1 ile paralel) ---
       enDusuk = c2Son(1): c2H = 1
       For h = 2 To COJI2_HAT
           If c2Son(h) < enDusuk Then enDusuk = c2Son(h): c2H = h
       Next h
       If c2Son(c2H) > ucC1BasDt(i) Then
           sBas = TatilAtlaVeVardiyaBul(c2Son(c2H))
       Else
           sBas = ucC1BasDt(i)
       End If
       If ucPinDt(i, 1) > 0 Then
           pinDt = TatilAtlaVeVardiyaBul(ucPinDt(i, 1))
           If pinDt > sBas Then sBas = pinDt
       End If
       ucWinBasDt(i) = sBas: ucWinHat(i) = c2H
       sBit = SaatEkle(sBas, ucWinSure(i))
       ucWinBitDt(i) = sBit: c2Son(c2H) = sBit
 
       ' --- MATE (COJI2, COJI1 ve WINDSHIELD bittikten sonra) ---
       Dim mateReq As Double
       If ucC1BitDt(i) >= ucWinBitDt(i) Then
           mateReq = ucC1BitDt(i)
       Else
           mateReq = ucWinBitDt(i)
       End If
       enDusuk = c2Son(1): c2H = 1
       For h = 2 To COJI2_HAT
           If c2Son(h) < enDusuk Then enDusuk = c2Son(h): c2H = h
       Next h
       If c2Son(c2H) > mateReq Then
           sBas = TatilAtlaVeVardiyaBul(c2Son(c2H))
       Else
           sBas = TatilAtlaVeVardiyaBul(mateReq)
       End If
       If ucPinDt(i, 2) > 0 Then
           pinDt = TatilAtlaVeVardiyaBul(ucPinDt(i, 2))
           If pinDt > sBas Then sBas = pinDt
       End If
       ucMateBasDt(i) = sBas: ucMateHat(i) = c2H
       sBit = SaatEkle(sBas, ucMateSure(i))
       ucMateBitDt(i) = sBit: c2Son(c2H) = sBit
 
       Dim sonraki As Double: sonraki = ucMateBitDt(i)
 
       ' --- OUT OF ---
       If outSon > sonraki Then sBas = TatilAtlaVeVardiyaBul(outSon) Else sBas = TatilAtlaVeVardiyaBul(sonraki)
       If ucPinDt(i, 3) > 0 Then
           pinDt = TatilAtlaVeVardiyaBul(ucPinDt(i, 3))
           If pinDt > sBas Then sBas = pinDt
       End If
       ucOutBasDt(i) = sBas
       sBit = SaatEkle(sBas, ucOutSure(i))
       ucOutBitDt(i) = sBit: outSon = sBit: sonraki = sBit
 
       ' --- LAY OFF ---
       If laySon > sonraki Then sBas = TatilAtlaVeVardiyaBul(laySon) Else sBas = TatilAtlaVeVardiyaBul(sonraki)
       If ucPinDt(i, 4) > 0 Then
           pinDt = TatilAtlaVeVardiyaBul(ucPinDt(i, 4))
           If pinDt > sBas Then sBas = pinDt
       End If
       ucLayBasDt(i) = sBas
       sBit = SaatEkle(sBas, ucLaySure(i))
       ucLayBitDt(i) = sBit: laySon = sBit: sonraki = sBit
 
       ' --- BOYA ---
       If boyaSon > sonraki Then sBas = TatilAtlaVeVardiyaBul(boyaSon) Else sBas = TatilAtlaVeVardiyaBul(sonraki)
       If ucPinDt(i, 5) > 0 Then
           pinDt = TatilAtlaVeVardiyaBul(ucPinDt(i, 5))
           If pinDt > sBas Then sBas = pinDt
       End If
       ucBoyaBasDt(i) = sBas
       sBit = SaatEkle(sBas, ucBoyaSure(i))
       ucBoyaBitDt(i) = sBit: boyaSon = sBit: sonraki = sBit
 
       ' --- SEALANT ---
       If sealSon > sonraki Then sBas = TatilAtlaVeVardiyaBul(sealSon) Else sBas = TatilAtlaVeVardiyaBul(sonraki)
       If ucPinDt(i, 6) > 0 Then
           pinDt = TatilAtlaVeVardiyaBul(ucPinDt(i, 6))
           If pinDt > sBas Then sBas = pinDt
       End If
       ucSealBasDt(i) = sBas
       sBit = SaatEkle(sBas, ucSealSure(i))
       ucSealBitDt(i) = sBit: sealSon = sBit: sonraki = sBit
 
       ' --- FINAL ---
       If finalSon > sonraki Then sBas = TatilAtlaVeVardiyaBul(finalSon) Else sBas = TatilAtlaVeVardiyaBul(sonraki)
       If ucPinDt(i, 7) > 0 Then
           pinDt = TatilAtlaVeVardiyaBul(ucPinDt(i, 7))
           If pinDt > sBas Then sBas = pinDt
       End If
       ucFinalBasDt(i) = sBas
       sBit = SaatEkle(sBas, ucFinalSure(i))
       ucFinalBitDt(i) = sBit: finalSon = sBit
 
   Next i
End Sub
 
' ====================================================
' GORSEL OLUSTUR
' ====================================================
Sub GorselOlustur( _
   ucNo() As Long, ucDurus() As Double, _
   ucC1BasDt() As Double, ucC1BitDt() As Double, ucC1Hat() As Integer, _
   ucWinBasDt() As Double, ucWinBitDt() As Double, ucWinHat() As Integer, _
   ucMateBasDt() As Double, ucMateBitDt() As Double, ucMateHat() As Integer, _
   ucOutBasDt() As Double, ucOutBitDt() As Double, _
   ucLayBasDt() As Double, ucLayBitDt() As Double, _
   ucBoyaBasDt() As Double, ucBoyaBitDt() As Double, _
   ucSealBasDt() As Double, ucSealBitDt() As Double, _
   ucFinalBasDt() As Double, ucFinalBitDt() As Double, _
   ucDurusBasDt() As Double, ucDurusBitDt() As Double, _
   ucakSayisi As Long, aySayisi As Integer, enErkenDt As Double)
 
   Dim ws As Worksheet
   On Error Resume Next: Application.DisplayAlerts = False
   ThisWorkbook.Sheets("OtomatikPlan").Delete
   Application.DisplayAlerts = True: On Error GoTo 0
   Set ws = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   ws.Name = "OtomatikPlan": ws.Cells.Font.Name = "Calibri"
 
   Const DATA_SATIR As Integer = 17
   Const BLOK_YUK   As Integer = 22
 
   Dim satirEtiket(1 To DATA_SATIR) As String
   Dim satirRenk(1 To DATA_SATIR) As Long
   satirEtiket(1) = "COJI 1 - Hat 1":     satirRenk(1) = RGB(255, 255, 180)
   satirEtiket(2) = "COJI 1 - Hat 2":     satirRenk(2) = RGB(255, 255, 180)
   satirEtiket(3) = "WINDSHIELD - Hat 1": satirRenk(3) = RGB(180, 220, 255)
   satirEtiket(4) = "WINDSHIELD - Hat 2": satirRenk(4) = RGB(180, 220, 255)
   satirEtiket(5) = "WINDSHIELD - Hat 3": satirRenk(5) = RGB(180, 220, 255)
   satirEtiket(6) = "WINDSHIELD - Hat 4": satirRenk(6) = RGB(180, 220, 255)
   satirEtiket(7) = "WINDSHIELD - Hat 5": satirRenk(7) = RGB(180, 220, 255)
   satirEtiket(8) = "MATE - Hat 1":       satirRenk(8) = RGB(200, 255, 200)
   satirEtiket(9) = "MATE - Hat 2":       satirRenk(9) = RGB(200, 255, 200)
   satirEtiket(10) = "MATE - Hat 3":      satirRenk(10) = RGB(200, 255, 200)
   satirEtiket(11) = "MATE - Hat 4":      satirRenk(11) = RGB(200, 255, 200)
   satirEtiket(12) = "MATE - Hat 5":      satirRenk(12) = RGB(200, 255, 200)
   satirEtiket(13) = "OUT OF":            satirRenk(13) = RGB(255, 200, 160)
   satirEtiket(14) = "LAY OFF":           satirRenk(14) = RGB(220, 200, 255)
   satirEtiket(15) = "BOYA":             satirRenk(15) = RGB(255, 180, 180)
   satirEtiket(16) = "SEALANT":          satirRenk(16) = RGB(200, 240, 240)
   satirEtiket(17) = "FINAL":            satirRenk(17) = RGB(180, 255, 180)
 
   Dim mm As Integer, curAy As Integer, curYil As Integer
   Dim ayBas As Date, aySon As Date, gunSay As Long, baseRow As Long
   Dim col As Long, j As Long, dd As Date, ll As Integer, v As Integer
 
   ' Baslangic ayi ve yili enErkenDt'den al
   Dim basAy As Integer: basAy = Month(DtTarih(enErkenDt))
   Dim basYil As Integer: basYil = Year(DtTarih(enErkenDt))
 
   For mm = 0 To aySayisi - 1
       curAy = basAy + mm
       curYil = basYil
       Do While curAy > 12: curAy = curAy - 12: curYil = curYil + 1: Loop
       ayBas = DateSerial(curYil, curAy, 1)
       aySon = DateSerial(curYil, curAy + 1, 0)
       gunSay = Day(aySon)
       baseRow = 1 + mm * BLOK_YUK
 
       ' Ay etiketi
       ws.Range(ws.Cells(baseRow + 3, C_AYADI), ws.Cells(baseRow + 3 + DATA_SATIR - 1, C_AYADI)).Merge
       With ws.Cells(baseRow + 3, C_AYADI)
           .Value = AyAdi(curAy): .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
           .Orientation = 90: .Font.Bold = True: .Font.Size = 11
           .Font.Color = RGB(255, 255, 255): .Interior.Color = RGB(0, 80, 160)
       End With
       ws.Columns(C_AYADI).ColumnWidth = 3.5
 
       ' Satir etiketleri
       For ll = 1 To DATA_SATIR
           With ws.Cells(baseRow + 2 + ll, C_LABEL)
               .Value = satirEtiket(ll): .Font.Bold = True: .Font.Size = 8
               .VerticalAlignment = xlCenter: .Interior.Color = satirRenk(ll)
           End With
       Next ll
       ws.Columns(C_LABEL).ColumnWidth = 18
 
       ' Gunleri ve vardiyeleri olustur
       col = C_VERI
       For j = 0 To gunSay - 1
           dd = ayBas + j
           If TatilMi(dd) Then
               ws.Cells(baseRow, col).Value = GunKisa(dd) & " " & Day(dd)
               ws.Cells(baseRow, col).Font.Size = 7: ws.Cells(baseRow, col).Font.Bold = True
               ws.Cells(baseRow, col).HorizontalAlignment = xlCenter
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col)).Interior.Color = RGB(215, 215, 215)
               If Weekday(dd, vbMonday) = 7 Then ws.Cells(baseRow, col).Font.Color = RGB(180, 0, 0)
               ws.Columns(col).ColumnWidth = 8
               col = col + 1
           Else
               ' Gun etiketi
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow, col + gNormalVardiya - 1)).Merge
               ws.Cells(baseRow, col).Value = GunKisa(dd) & " " & Day(dd)
               ws.Cells(baseRow, col).HorizontalAlignment = xlCenter
               ws.Cells(baseRow, col).Font.Size = 8: ws.Cells(baseRow, col).Font.Bold = True
 
               ' Vardiya sutunlari
               Dim vBasStr As String, vBitStr As String
               For v = 1 To gNormalVardiya
                   Dim vCol As Long: vCol = col + v - 1
                   ws.Cells(baseRow + 1, vCol).Value = "S" & v
                   ws.Cells(baseRow + 1, vCol).HorizontalAlignment = xlCenter
                   ws.Cells(baseRow + 1, vCol).Font.Size = 7: ws.Cells(baseRow + 1, vCol).Font.Bold = True
                   Select Case v
                       Case 1: vBasStr = "07:00": vBitStr = "15:00"
                       Case 2: vBasStr = "15:00": vBitStr = "23:00"
                       Case 3: vBasStr = "23:00": vBitStr = "07:00"
                   End Select
                   ws.Cells(baseRow + 2, vCol).Value = vBasStr & "-" & vBitStr
                   ws.Cells(baseRow + 2, vCol).HorizontalAlignment = xlCenter
                   ws.Cells(baseRow + 2, vCol).Font.Size = 6
                   ws.Columns(vCol).ColumnWidth = 13
               Next v
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + gNormalVardiya - 1)).Borders.LineStyle = xlContinuous
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + gNormalVardiya - 1)).Borders.Weight = xlHairline
               ws.Range(ws.Cells(baseRow, col), ws.Cells(baseRow + 2 + DATA_SATIR, col + gNormalVardiya - 1)).Borders.Color = RGB(180, 180, 180)
               col = col + gNormalVardiya
           End If
       Next j
 
       ' Satir yukseklikleri
       ws.Rows(baseRow).RowHeight = 14: ws.Rows(baseRow + 1).RowHeight = 14: ws.Rows(baseRow + 2).RowHeight = 12
       For ll = 3 To 2 + DATA_SATIR: ws.Rows(baseRow + ll).RowHeight = 32: Next ll
 
       ' Ucaklari ciz
       Dim ui As Long
       For ui = 0 To ucakSayisi - 1
           Dim rnk As Long: rnk = UcakRenk(ui)
           ' COJI1
           Call YazUcakVardiya(ws, ucNo(ui), rnk, ucC1BasDt(ui), ucC1BitDt(ui), baseRow + 2 + ucC1Hat(ui), ayBas, aySon, C_VERI, False)
           ' WINDSHIELD
           Call YazUcakVardiya(ws, ucNo(ui), rnk, ucWinBasDt(ui), ucWinBitDt(ui), baseRow + 2 + 2 + ucWinHat(ui), ayBas, aySon, C_VERI, False)
           ' MATE
           Call YazUcakVardiya(ws, ucNo(ui), rnk, ucMateBasDt(ui), ucMateBitDt(ui), baseRow + 2 + 7 + ucMateHat(ui), ayBas, aySon, C_VERI, False)
           ' Tek hatlar
           Call YazUcakVardiya(ws, ucNo(ui), rnk, ucOutBasDt(ui), ucOutBitDt(ui), baseRow + 15, ayBas, aySon, C_VERI, False)
           Call YazUcakVardiya(ws, ucNo(ui), rnk, ucLayBasDt(ui), ucLayBitDt(ui), baseRow + 16, ayBas, aySon, C_VERI, False)
           Call YazUcakVardiya(ws, ucNo(ui), rnk, ucBoyaBasDt(ui), ucBoyaBitDt(ui), baseRow + 17, ayBas, aySon, C_VERI, False)
           Call YazUcakVardiya(ws, ucNo(ui), rnk, ucSealBasDt(ui), ucSealBitDt(ui), baseRow + 18, ayBas, aySon, C_VERI, False)
           Call YazUcakVardiya(ws, ucNo(ui), rnk, ucFinalBasDt(ui), ucFinalBitDt(ui), baseRow + 19, ayBas, aySon, C_VERI, False)
           ' Durus
           If ucDurus(ui) > 0 Then
               Call YazUcakVardiya(ws, ucNo(ui), RGB(30, 30, 30), ucDurusBasDt(ui), ucDurusBitDt(ui), baseRow + 2 + ucC1Hat(ui), ayBas, aySon, C_VERI, True)
           End If
       Next ui
   Next mm
 
   ws.Activate: ws.Cells(1, C_VERI).Select: ActiveWindow.FreezePanes = True: ws.Cells(1, 1).Select
End Sub
 
' Bir satira ucak bilgisi yaz (bu aydaki vardiyelere gore)
Sub YazUcakVardiya(ws As Worksheet, ucakNo As Long, rnk As Long, _
   basDt As Double, bitDt As Double, satirNo As Long, _
   ayBas As Date, aySon As Date, veriBasCol As Long, isDurus As Boolean)
 
   Dim gunSay As Long: gunSay = Day(aySon)
   Dim col As Long: col = veriBasCol
   Dim j As Long, v As Integer, dd As Date
 
   For j = 0 To gunSay - 1
       dd = ayBas + j
       If TatilMi(dd) Then
           col = col + 1
       Else
           For v = 1 To gNormalVardiya
               Dim vCol As Long: vCol = col + v - 1
               ' Bu vardiyanin baslangic ve bitis DateTime
               Dim vBasDt As Double, vBitDt As Double
               If v = 3 Then
                   vBasDt = CDbl(dd) + 23 * 60 / 1440#
                   vBitDt = CDbl(dd) + 1 + 7 * 60 / 1440#
               Else
                   vBasDt = CDbl(dd) + VardiyaBasDak(v) / 1440#
                   vBitDt = CDbl(dd) + VardiyaBitDak(v) / 1440#
               End If
 
               ' Ucak bu vardiyadaymi?
               If basDt < vBitDt And bitDt > vBasDt Then
                   Dim gosBas As Double: gosBas = IIf(basDt > vBasDt, basDt, vBasDt)
                   Dim gosBit As Double: gosBit = IIf(bitDt < vBitDt, bitDt, vBitDt)
 
                   Dim mevcutIcerik As String
                   If ws.Cells(satirNo, vCol).Value <> "" Then
                       mevcutIcerik = CStr(ws.Cells(satirNo, vCol).Value) & Chr(10)
                   Else
                       mevcutIcerik = ""
                   End If
 
                   If isDurus Then
                       ws.Cells(satirNo, vCol).Value = mevcutIcerik & "DURUS"
                       ws.Cells(satirNo, vCol).Interior.Color = RGB(50, 50, 50)
                       ws.Cells(satirNo, vCol).Font.Color = RGB(255, 255, 255)
                   Else
                       ws.Cells(satirNo, vCol).Value = mevcutIcerik & ucakNo & " " & DtSaat(gosBas) & "-" & DtSaat(gosBit)
                       ws.Cells(satirNo, vCol).Interior.Color = rnk
                       ws.Cells(satirNo, vCol).Font.Color = RGB(0, 0, 0)
                   End If
                   ws.Cells(satirNo, vCol).Font.Size = 7: ws.Cells(satirNo, vCol).Font.Bold = True
                   ws.Cells(satirNo, vCol).HorizontalAlignment = xlCenter
                   ws.Cells(satirNo, vCol).VerticalAlignment = xlCenter
                   ws.Cells(satirNo, vCol).WrapText = True
               End If
           Next v
           col = col + gNormalVardiya
       End If
   Next j
End Sub
 
' ====================================================
' AYARLAR KAYDET / OKU
' ====================================================
Sub AyarlariKaydet(c1BasDt As Double, c2BasDt As Double, aySayisi As Integer)
   Dim wsA As Worksheet
   On Error Resume Next: Application.DisplayAlerts = False
   ThisWorkbook.Sheets("Ayarlar").Delete
   Application.DisplayAlerts = True: On Error GoTo 0
   Set wsA = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   wsA.Name = "Ayarlar": wsA.Visible = xlSheetHidden
   wsA.Cells(1, 1).Value = gNormalVardiya
   wsA.Cells(1, 2).Value = gTatilSayisi
   wsA.Cells(1, 3).Value = c1BasDt
   wsA.Cells(1, 4).Value = c2BasDt
   wsA.Cells(1, 5).Value = aySayisi
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       wsA.Cells(tt + 2, 1).Value = CDbl(gTatilTarihBas(tt))
       wsA.Cells(tt + 2, 2).Value = CDbl(gTatilTarihBit(tt))
       If gTatilCalis(tt) Then wsA.Cells(tt + 2, 3).Value = 1 Else wsA.Cells(tt + 2, 3).Value = 0
   Next tt
End Sub
 
Function AyarlariOku() As Boolean
   On Error GoTo AyarYok
   Dim wsA As Worksheet: Set wsA = ThisWorkbook.Sheets("Ayarlar")
   gNormalVardiya = CInt(wsA.Cells(1, 1).Value)
   gTatilSayisi = CInt(wsA.Cells(1, 2).Value)
   Call TatilleriOlustur
   Dim tt As Integer
   For tt = 0 To gTatilSayisi - 1
       gTatilCalis(tt) = (wsA.Cells(tt + 2, 3).Value = 1)
   Next tt
   AyarlariOku = True: Exit Function
AyarYok:
   AyarlariOku = False
End Function
 
Sub BaslangicBilgisiOku(ByRef c1BasDt As Double, ByRef c2BasDt As Double, ByRef aySayisi As Integer)
   Dim wsA As Worksheet: Set wsA = ThisWorkbook.Sheets("Ayarlar")
   c1BasDt = CDbl(wsA.Cells(1, 3).Value)
   c2BasDt = CDbl(wsA.Cells(1, 4).Value)
   aySayisi = CInt(wsA.Cells(1, 5).Value)
End Sub
 
' ====================================================
' PLAN DETAY
' ====================================================
Sub PlanDetayKaydet( _
   ucNo() As Long, ucDurus() As Double, _
   ucC1Sure() As Double, ucWinSure() As Double, ucMateSure() As Double, _
   ucOutSure() As Double, ucLaySure() As Double, ucBoyaSure() As Double, _
   ucSealSure() As Double, ucFinalSure() As Double, _
   ucC1Hat() As Integer, ucC1BasDt() As Double, ucC1BitDt() As Double, _
   ucWinHat() As Integer, ucWinBasDt() As Double, ucWinBitDt() As Double, _
   ucMateHat() As Integer, ucMateBasDt() As Double, ucMateBitDt() As Double, _
   ucOutBasDt() As Double, ucOutBitDt() As Double, _
   ucLayBasDt() As Double, ucLayBitDt() As Double, _
   ucBoyaBasDt() As Double, ucBoyaBitDt() As Double, _
   ucSealBasDt() As Double, ucSealBitDt() As Double, _
   ucFinalBasDt() As Double, ucFinalBitDt() As Double, _
   ucakSayisi As Long, ucPinDt() As Double)
 
   Dim wsL As Worksheet
   On Error Resume Next: Application.DisplayAlerts = False
   ThisWorkbook.Sheets("PlanDetay").Delete
   Application.DisplayAlerts = True: On Error GoTo 0
   Set wsL = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.Count))
   wsL.Name = "PlanDetay": wsL.Cells.Font.Name = "Calibri"
 
   Dim baslik As Variant
   baslik = Array("Ucak", "Durus(s)", "C1(s)", "Win(s)", "Mate(s)", "Out(s)", "Lay(s)", "Boya(s)", "Seal(s)", "Final(s)", _
                  "C1Hat", "C1Bas", "C1Bit", "WinHat", "WinBas", "WinBit", "MateHat", "MateBas", "MateBit", _
                  "OutBas", "OutBit", "LayBas", "LayBit", "BoyaBas", "BoyaBit", "SealBas", "SealBit", "FinalBas", "FinalBit", _
                  "PinC1", "PinWin", "PinMate", "PinOut", "PinLay", "PinBoya", "PinSeal", "PinFinal")
   Dim k As Integer
   For k = 0 To UBound(baslik)
       wsL.Cells(1, k + 1).Value = baslik(k)
   Next k
   With wsL.Range(wsL.Cells(1, 1), wsL.Cells(1, UBound(baslik) + 1))
       .Font.Bold = True: .Interior.Color = RGB(0, 80, 160): .Font.Color = RGB(255, 255, 255)
   End With
 
   Dim fmt As String: fmt = "DD.MM.YYYY HH:MM"
   Dim i As Long
   For i = 0 To ucakSayisi - 1
       Dim r As Long: r = i + 2
       wsL.Cells(r, 1).Value = ucNo(i):   wsL.Cells(r, 2).Value = ucDurus(i)
       wsL.Cells(r, 3).Value = ucC1Sure(i): wsL.Cells(r, 4).Value = ucWinSure(i)
       wsL.Cells(r, 5).Value = ucMateSure(i): wsL.Cells(r, 6).Value = ucOutSure(i)
       wsL.Cells(r, 7).Value = ucLaySure(i): wsL.Cells(r, 8).Value = ucBoyaSure(i)
       wsL.Cells(r, 9).Value = ucSealSure(i): wsL.Cells(r, 10).Value = ucFinalSure(i)
       wsL.Cells(r, 11).Value = ucC1Hat(i)
       wsL.Cells(r, 12).Value = ucC1BasDt(i):   wsL.Cells(r, 12).NumberFormat = fmt
       wsL.Cells(r, 13).Value = ucC1BitDt(i):   wsL.Cells(r, 13).NumberFormat = fmt
       wsL.Cells(r, 14).Value = ucWinHat(i)
       wsL.Cells(r, 15).Value = ucWinBasDt(i):  wsL.Cells(r, 15).NumberFormat = fmt
       wsL.Cells(r, 16).Value = ucWinBitDt(i):  wsL.Cells(r, 16).NumberFormat = fmt
       wsL.Cells(r, 17).Value = ucMateHat(i)
       wsL.Cells(r, 18).Value = ucMateBasDt(i): wsL.Cells(r, 18).NumberFormat = fmt
       wsL.Cells(r, 19).Value = ucMateBitDt(i): wsL.Cells(r, 19).NumberFormat = fmt
       wsL.Cells(r, 20).Value = ucOutBasDt(i):  wsL.Cells(r, 20).NumberFormat = fmt
       wsL.Cells(r, 21).Value = ucOutBitDt(i):  wsL.Cells(r, 21).NumberFormat = fmt
       wsL.Cells(r, 22).Value = ucLayBasDt(i):  wsL.Cells(r, 22).NumberFormat = fmt
       wsL.Cells(r, 23).Value = ucLayBitDt(i):  wsL.Cells(r, 23).NumberFormat = fmt
       wsL.Cells(r, 24).Value = ucBoyaBasDt(i): wsL.Cells(r, 24).NumberFormat = fmt
       wsL.Cells(r, 25).Value = ucBoyaBitDt(i): wsL.Cells(r, 25).NumberFormat = fmt
       wsL.Cells(r, 26).Value = ucSealBasDt(i): wsL.Cells(r, 26).NumberFormat = fmt
       wsL.Cells(r, 27).Value = ucSealBitDt(i): wsL.Cells(r, 27).NumberFormat = fmt
       wsL.Cells(r, 28).Value = ucFinalBasDt(i):wsL.Cells(r, 28).NumberFormat = fmt
       wsL.Cells(r, 29).Value = ucFinalBitDt(i):wsL.Cells(r, 29).NumberFormat = fmt
       Dim adm As Integer
       For adm = 0 To 7
           If ucPinDt(i, adm) > 0 Then
               wsL.Cells(r, 30 + adm).Value = ucPinDt(i, adm)
               wsL.Cells(r, 30 + adm).NumberFormat = fmt
               wsL.Cells(r, 30 + adm).Interior.Color = RGB(255, 220, 150)
           Else
               wsL.Cells(r, 30 + adm).Value = 0
           End If
       Next adm
       wsL.Range(wsL.Cells(r, 1), wsL.Cells(r, 29)).Interior.Color = UcakRenk(i)
   Next i
   wsL.Columns("A:AL").AutoFit
End Sub
 
Sub PlanDetayOku( _
   ucNo() As Long, ucDurus() As Double, _
   ucC1Sure() As Double, ucWinSure() As Double, ucMateSure() As Double, _
   ucOutSure() As Double, ucLaySure() As Double, ucBoyaSure() As Double, _
   ucSealSure() As Double, ucFinalSure() As Double, ucakSayisi As Long)
   Dim wsP As Worksheet: Set wsP = ThisWorkbook.Sheets("PlanDetay")
   Dim i As Long
   For i = 0 To ucakSayisi - 1
       ucNo(i) = CLng(wsP.Cells(i + 2, 1).Value)
       ucDurus(i) = CDbl(wsP.Cells(i + 2, 2).Value)
       ucC1Sure(i) = CDbl(wsP.Cells(i + 2, 3).Value)
       ucWinSure(i) = CDbl(wsP.Cells(i + 2, 4).Value)
       ucMateSure(i) = CDbl(wsP.Cells(i + 2, 5).Value)
       ucOutSure(i) = CDbl(wsP.Cells(i + 2, 6).Value)
       ucLaySure(i) = CDbl(wsP.Cells(i + 2, 7).Value)
       ucBoyaSure(i) = CDbl(wsP.Cells(i + 2, 8).Value)
       ucSealSure(i) = CDbl(wsP.Cells(i + 2, 9).Value)
       ucFinalSure(i) = CDbl(wsP.Cells(i + 2, 10).Value)
   Next i
End Sub
 
Sub PinOku(ucPinDt() As Double, ucakSayisi As Long)
   ReDim ucPinDt(0 To ucakSayisi - 1, 0 To 7)
   Dim wsP As Worksheet
   On Error Resume Next: Set wsP = ThisWorkbook.Sheets("PlanDetay"): On Error GoTo 0
   If wsP Is Nothing Then Exit Sub
   Dim i As Long, adm As Integer
   For i = 0 To ucakSayisi - 1
       For adm = 0 To 7
           Dim pv As Variant: pv = wsP.Cells(i + 2, 30 + adm).Value
           If IsNumeric(pv) Then
               If CDbl(pv) > 0 Then ucPinDt(i, adm) = CDbl(pv)
           End If
       Next adm
   Next i
End Sub
 
' ====================================================
' GUNCELLE VE CIZ
' ====================================================
Sub GuncelleVeCiz( _
   ucNo() As Long, ucDurus() As Double, _
   ucC1Sure() As Double, ucWinSure() As Double, ucMateSure() As Double, _
   ucOutSure() As Double, ucLaySure() As Double, ucBoyaSure() As Double, _
   ucSealSure() As Double, ucFinalSure() As Double, ucakSayisi As Long)
 
   Dim c1BasDt As Double, c2BasDt As Double, aySayisi As Integer
   Call BaslangicBilgisiOku(c1BasDt, c2BasDt, aySayisi)
 
   Dim ucPinDt() As Double
   Call PinOku(ucPinDt, ucakSayisi)
 
   Dim ucDurusBasDt() As Double, ucDurusBitDt() As Double
   Dim ucC1BasDt() As Double, ucC1BitDt() As Double, ucC1Hat() As Integer
   Dim ucWinBasDt() As Double, ucWinBitDt() As Double, ucWinHat() As Integer
   Dim ucMateBasDt() As Double, ucMateBitDt() As Double, ucMateHat() As Integer
   Dim ucOutBasDt() As Double, ucOutBitDt() As Double
   Dim ucLayBasDt() As Double, ucLayBitDt() As Double
   Dim ucBoyaBasDt() As Double, ucBoyaBitDt() As Double
   Dim ucSealBasDt() As Double, ucSealBitDt() As Double
   Dim ucFinalBasDt() As Double, ucFinalBitDt() As Double
 
   Call TumHesapla(ucNo, ucDurus, ucC1Sure, ucWinSure, ucMateSure, ucOutSure, ucLaySure, ucBoyaSure, ucSealSure, ucFinalSure, _
                   ucakSayisi, c1BasDt, c2BasDt, ucPinDt, _
                   ucDurusBasDt, ucDurusBitDt, _
                   ucC1BasDt, ucC1BitDt, ucC1Hat, ucWinBasDt, ucWinBitDt, ucWinHat, _
                   ucMateBasDt, ucMateBitDt, ucMateHat, _
                   ucOutBasDt, ucOutBitDt, ucLayBasDt, ucLayBitDt, _
                   ucBoyaBasDt, ucBoyaBitDt, ucSealBasDt, ucSealBitDt, ucFinalBasDt, ucFinalBitDt)
 
   Dim enErkenDt As Double
   If c1BasDt <= c2BasDt Then enErkenDt = c1BasDt Else enErkenDt = c2BasDt
 
   Call GorselOlustur(ucNo, ucDurus, _
                      ucC1BasDt, ucC1BitDt, ucC1Hat, ucWinBasDt, ucWinBitDt, ucWinHat, _
                      ucMateBasDt, ucMateBitDt, ucMateHat, _
                      ucOutBasDt, ucOutBitDt, ucLayBasDt, ucLayBitDt, _
                      ucBoyaBasDt, ucBoyaBitDt, ucSealBasDt, ucSealBitDt, ucFinalBasDt, ucFinalBitDt, _
                      ucDurusBasDt, ucDurusBitDt, ucakSayisi, aySayisi, enErkenDt)
 
   Call PlanDetayKaydet(ucNo, ucDurus, ucC1Sure, ucWinSure, ucMateSure, ucOutSure, ucLaySure, ucBoyaSure, ucSealSure, ucFinalSure, _
                        ucC1Hat, ucC1BasDt, ucC1BitDt, ucWinHat, ucWinBasDt, ucWinBitDt, ucMateHat, ucMateBasDt, ucMateBitDt, _
                        ucOutBasDt, ucOutBitDt, ucLayBasDt, ucLayBitDt, ucBoyaBasDt, ucBoyaBitDt, ucSealBasDt, ucSealBitDt, _
                        ucFinalBasDt, ucFinalBitDt, ucakSayisi, ucPinDt)
 
   Call GenelBakisOlustur(ucNo, ucDurus, _
                          ucC1BasDt, ucC1BitDt, ucC1Hat, ucWinBasDt, ucWinBitDt, ucWinHat, _
                          ucMateBasDt, ucMateBitDt, ucMateHat, _
                          ucOutBasDt, ucOutBitDt, ucLayBasDt, ucLayBitDt, _
                          ucBoyaBasDt, ucBoyaBitDt, ucSealBasDt, ucSealBitDt, ucFinalBasDt, ucFinalBitDt, _
                          ucDurusBasDt, ucDurusBitDt, ucakSayisi, aySayisi, enErkenDt)
End Sub
 
' ====================================================
' TARIH-SAAT GIRISI
' ====================================================
Function TarihSaatGir(mesaj As String, varsayilan As String) As Double
   Dim girdi As String
   girdi = InputBox(mesaj & vbCrLf & "(Ornek: 01.04.2026 07:00)", "Tarih ve Saat", varsayilan)
   If Trim(girdi) = "" Then TarihSaatGir = -1: Exit Function
   On Error GoTo HataTS
   Dim parcalar() As String: parcalar = Split(Trim(girdi), " ")
   Dim tarihKismi As Date: tarihKismi = CDate(parcalar(0))
   Dim saatDak As Long: saatDak = 0
   If UBound(parcalar) >= 1 Then
       Dim sp() As String: sp = Split(parcalar(1), ":")
       saatDak = CLng(sp(0)) * 60 + CLng(sp(1))
   End If
   TarihSaatGir = CDbl(tarihKismi) + saatDak / 1440#
   Exit Function
HataTS:
   MsgBox "Gecersiz format! Ornek: 01.04.2026 07:00", vbExclamation
   TarihSaatGir = -1
End Function
 
